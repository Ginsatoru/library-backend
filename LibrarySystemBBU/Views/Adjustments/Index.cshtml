@model IEnumerable<LibrarySystemBBU.Models.Adjustment>
@using LibrarySystemBBU.Models

@{
    ViewData["Title"] = "Adjustments";

    string CatalogLabel(Catalog? c)
        => c == null
            ? "—"
            : (string.IsNullOrWhiteSpace(c.ISBN) ? c.Title : $"{c.Title} ({c.ISBN})");

    var total = Model?.Count() ?? 0;
    var inc = Model?.Count(x => x.QuantityChange >= 0) ?? 0;
    var dec = total - inc;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .adj-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .adj-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .adj-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .adj-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .adj-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .adj-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .adj-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .adj-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .adj-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .adj-btn-success {
        background: #f0fdf4;
        color: #15803d;
        border-color: #bbf7d0;
    }

        .adj-btn-success:hover {
            background: #dcfce7;
            color: #166534;
            border-color: #86efac;
            text-decoration: none;
        }

    .adj-segmented {
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .adj-seg-btn {
        padding: 6px 14px;
        font-size: .82rem;
        font-weight: 500;
        border: none;
        background: #fff;
        color: #6b7280;
        cursor: pointer;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
    }

        .adj-seg-btn:not(:last-child) {
            border-right: 1px solid #e5e7eb;
        }

        .adj-seg-btn.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

    .adj-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        background: #fff;
        flex: 1;
        min-width: 200px;
        max-width: 360px;
        transition: border-color .15s;
    }

        .adj-search-wrap:focus-within {
            border-color: #000080;
        }

        .adj-search-wrap i {
            color: #9ca3af;
            font-size: .85rem;
        }

    .adj-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: .83rem;
        color: #111827;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

        .adj-search-input::placeholder {
            color: #9ca3af;
        }

    .adj-search-clear {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        padding: 0;
        font-size: .85rem;
    }

        .adj-search-clear:hover {
            color: #6b7280;
        }

    .adj-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
        flex-wrap: wrap;
    }

    .adj-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .adj-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .adj-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .adj-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .adj-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .adj-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .adj-table tbody tr:last-child {
                border-bottom: none;
            }

            .adj-table tbody tr:hover {
                background: #f9fafb;
            }

        .adj-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

            .adj-table tbody td.muted {
                color: #6b7280;
            }

        .adj-table .text-end {
            text-align: right;
        }

    .badge-plus {
        background: #dcfce7;
        color: #166534;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }

    .badge-minus {
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .78rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }

    .adj-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .adj-action-btn {
        padding: 4px 10px;
        font-size: .74rem;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: background .15s;
    }

        .adj-action-btn:hover {
            background: #f3f4f6;
            color: #111827;
            text-decoration: none;
        }

    .alert-warning {
        background: #fffbeb;
        border: 1px solid #fef3c7;
        border-radius: 12px;
        padding: 1rem;
        color: #92400e;
        font-size: .88rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="adj-page">

    <div class="adj-page-title">Adjustments</div>

    <div class="adj-toolbar">
        <a class="adj-btn adj-btn-primary" asp-action="Create"><i class="bi bi-plus-circle"></i> Create Adjustment</a>

        <div class="adj-segmented">
            <button type="button" class="adj-seg-btn active" data-filter="all"><i class="bi bi-grid"></i> All</button>
            <button type="button" class="adj-seg-btn" data-filter="damage"><i class="bi bi-tools"></i> Damage</button>
            <button type="button" class="adj-seg-btn" data-filter="lost"><i class="bi bi-x-octagon"></i> Lost</button>
        </div>

        <div class="adj-search-wrap">
            <i class="bi bi-search"></i>
            <input id="globalSearch" class="adj-search-input" placeholder="Search date, type, catalog, reason, user…" />
            <button class="adj-search-clear" type="button" id="clearSearch"><i class="bi bi-x-circle"></i></button>
        </div>

        <a class="adj-btn" asp-action="Export"><i class="bi bi-download"></i> Export</a>

        <div class="adj-stats">
            <span class="adj-stat-pill"><i class="bi bi-layers"></i> Total: <strong id="statTotal">@total</strong></span>
            <span class="adj-stat-pill"><i class="bi bi-arrow-up-circle-fill" style="color:#22c55e"></i> + <strong id="statInc">@inc</strong></span>
            <span class="adj-stat-pill"><i class="bi bi-arrow-down-circle-fill" style="color:#ef4444"></i> − <strong id="statDec">@dec</strong></span>
        </div>
    </div>

    <div class="adj-table-wrap">
        <table class="adj-table" id="adjTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Catalog</th>
                    <th>Quantity</th>
                    <th>Reason</th>
                    <th>Adjusted By</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        var qty = item.QuantityChange;
                        var badgeClass = qty >= 0 ? "badge-plus" : "badge-minus";
                        var icon = qty >= 0 ? "bi-arrow-up-circle-fill" : "bi-arrow-down-circle-fill";
                        <tr data-type="@item.AdjustmentType.ToString().ToLower()">
                            <td class="muted">@item.AdjustmentDate.ToString("yyyy-MM-dd")</td>
                            <td>@item.AdjustmentType</td>
                            <td>@CatalogLabel(item.Catalog)</td>
                            <td>
                                <span class="@badgeClass">
                                    <i class="bi @icon"></i>
                                    @(qty >= 0 ? "+" : "−") @Math.Abs(qty)
                                </span>
                            </td>
                            <td class="muted">@item.Reason</td>
                            <td class="muted">@(item.AdjustedByUser?.UserName ?? "—")</td>
                            <td>
                                <div class="adj-actions">
                                    <a class="adj-action-btn" asp-action="Details" asp-route-id="@item.AdjustmentId"><i class="bi bi-eye"></i> Details</a>
                                    <a class="adj-action-btn" asp-action="Edit" asp-route-id="@item.AdjustmentId"><i class="bi bi-pencil-square"></i> Edit</a>
                                    <a class="adj-action-btn" asp-action="Delete" asp-route-id="@item.AdjustmentId"><i class="bi bi-trash3"></i> Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align:center; color:#9ca3af; padding:2rem;">
                            <i class="bi bi-inboxes" style="font-size:1.2rem;"></i>
                            <div class="mt-2">No adjustments found.</div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="noMatches" class="alert-warning d-none">
        <i class="bi bi-question-circle"></i>
        <span>No matching results for your filters.</span>
    </div>

</div>

@section Scripts {
    <script>
        (function() {
            const filterBtns = document.querySelectorAll('.adj-seg-btn');
            const search = document.getElementById('globalSearch');
            const clearBtn = document.getElementById('clearSearch');
            const table = document.getElementById('adjTable');
            const rows = () => Array.from(document.querySelectorAll('#adjTable tbody tr'));
            const noMsg = document.getElementById('noMatches');

            const statTotal = document.getElementById('statTotal');
            const statInc = document.getElementById('statInc');
            const statDec = document.getElementById('statDec');

            function applyFilter() {
                const activeFilter = document.querySelector('.adj-seg-btn.active')?.dataset.filter || 'all';
                const searchTerm = (search.value || '').trim().toLowerCase();

                let visibleCount = 0;
                let incCount = 0;
                let decCount = 0;

                rows().forEach(row => {
                    if (row.cells.length === 1) return; // Skip "No adjustments" row

                    const type = (row.dataset.type || '').toLowerCase();
                    const text = row.innerText.toLowerCase();

                    let show = true;

                    // Apply type filter
                    if (activeFilter !== 'all') {
                        show = type === activeFilter;
                    }

                    // Apply search filter
                    if (show && searchTerm) {
                        show = text.includes(searchTerm);
                    }

                    row.style.display = show ? '' : 'none';

                    if (show) {
                        visibleCount++;
                        // Check if it's increase or decrease
                        const qtyCell = row.cells[3];
                        if (qtyCell) {
                            const isPlus = qtyCell.querySelector('.badge-plus') !== null;
                            if (isPlus) incCount++; else decCount++;
                        }
                    }
                });

                // Update stats
                statTotal.textContent = visibleCount;
                statInc.textContent = incCount;
                statDec.textContent = decCount;

                // Show/hide no results message
                noMsg.classList.toggle('d-none', visibleCount > 0);
            }

            // Filter button clicks
            filterBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    filterBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    applyFilter();
                });
            });

            // Search with debounce
            let searchTimeout;
            search.addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(applyFilter, 200);
            });

            // Clear search
            clearBtn.addEventListener('click', () => {
                search.value = '';
                search.focus();
                applyFilter();
            });

            // Initial filter
            applyFilter();
        })();
    </script>
}