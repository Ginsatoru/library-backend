@model LibrarySystemBBU.Controllers.AdjustmentWithDetailsVM
@using Microsoft.AspNetCore.Mvc.Rendering
@using System.Linq

@{
    ViewData["Title"] = "Edit Adjustment";

    if (Model.Details == null)
        Model.Details = new List<LibrarySystemBBU.Controllers.AdjustmentDetailRowVM>();

    if (!Model.Details.Any())
        Model.Details.Add(new LibrarySystemBBU.Controllers.AdjustmentDetailRowVM());
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .adj-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .adj-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .adj-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .adj-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .adj-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .adj-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

    .adj-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .adj-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .adj-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .adj-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .adj-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .adj-section-title {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .adj-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .adj-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .adj-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .adj-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

    .adj-form-label {
        font-size: .8rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: .25rem;
    }

    .adj-form-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        transition: border-color .15s;
    }

        .adj-form-control:focus {
            outline: none;
            border-color: #000080;
        }

    .adj-form-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        background-color: #fff;
    }

    .adj-btn-sm {
        padding: 4px 10px;
        font-size: .74rem;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: background .15s;
    }

        .adj-btn-sm:hover {
            background: #f3f4f6;
        }

    .adj-btn-danger {
        background: #fee2e2;
        color: #991b1b;
        border-color: #fecaca;
    }

        .adj-btn-danger:hover {
            background: #fecaca;
        }

    .text-danger {
        color: #dc2626;
        font-size: .75rem;
        margin-top: .25rem;
    }
</style>

<div class="adj-page">
    <div class="adj-page-title">Edit Adjustment</div>

    <div class="adj-toolbar">
        <a asp-action="Index" class="adj-btn">
            <i class="bi bi-arrow-left"></i> Back
        </a>

        <span class="adj-stat-pill">
            <i class="bi bi-list-ol"></i>
            Rows: <strong id="statRows">@Model.Details.Count</strong>
        </span>

        <span class="adj-stat-pill">
            <i class="bi bi-plus-slash-minus"></i>
            Total Change: <strong id="statQty">@Model.QuantityChange</strong>
        </span>

        <span class="adj-stat-pill">
            <i class="bi bi-funnel"></i>
            Type: <strong id="statType">@Model.AdjustmentType</strong>
        </span>

        <button type="submit" form="adjForm" class="adj-btn adj-btn-primary ms-auto">
            <i class="bi bi-check2-circle"></i> Save Changes
        </button>
    </div>

    <form asp-action="Edit" method="post" id="adjForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="AdjustmentId" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- Adjustment Info -->
        <div class="adj-card">
            <div class="adj-section-title">
                <i class="bi bi-sliders"></i> Adjustment Info
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <div class="adj-form-label">Catalog</div>
                    <select asp-for="CatalogId"
                            class="adj-form-select"
                            id="headerCatalog"
                            asp-items="Model.Catalogs ?? new SelectList(Enumerable.Empty<SelectListItem>())">
                        <option value="">-- Select catalog --</option>
                    </select>
                    <span asp-validation-for="CatalogId" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="adj-form-label">Adjustment Type</div>
                    <select asp-for="AdjustmentType"
                            class="adj-form-select"
                            id="adjType"
                            asp-items="Model.AdjustmentTypes ?? new SelectList(Enumerable.Empty<SelectListItem>())">
                        <option value="">-- Select type --</option>
                    </select>
                    <span asp-validation-for="AdjustmentType" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="adj-form-label">Adjustment Date</div>
                    <input asp-for="AdjustmentDate" class="adj-form-control" type="date" />
                    <span asp-validation-for="AdjustmentDate" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="adj-form-label">Total Quantity (auto)</div>
                    <input asp-for="QuantityChange" class="adj-form-control" id="qtyTotal" readonly />
                    <span asp-validation-for="QuantityChange" class="text-danger"></span>
                </div>

                <div class="col-md-8">
                    <div class="adj-form-label">Reason</div>
                    <input asp-for="Reason" class="adj-form-control" />
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>

                <div class="col-md-4">
                    <div class="adj-form-label">Adjusted By</div>
                    <select asp-for="AdjustedByUserId"
                            class="adj-form-select"
                            asp-items="Model.Users ?? new SelectList(Enumerable.Empty<SelectListItem>())">
                        <option value="">-- Select user --</option>
                    </select>
                    <span asp-validation-for="AdjustedByUserId" class="text-danger"></span>
                </div>
            </div>
        </div>

        <!-- Details -->
        <div class="adj-card mt-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="adj-section-title mb-0">
                    <i class="bi bi-list-check"></i> Details
                </div>
                <button type="button" class="adj-btn" id="addRowBtn">
                    <i class="bi bi-plus-circle"></i> Add row
                </button>
            </div>

            <span asp-validation-for="Details" class="text-danger"></span>

            <div class="adj-table-wrap">
                <table class="adj-table" id="detailsTable">
                    <thead>
                        <tr>
                            <th class="book-col" style="width:35%">Book / Barcode</th>
                            <th style="width:15%">Qty</th>
                            <th>Note</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < Model.Details.Count; i++)
                        {
                            <tr class="detail-row">
                                <input type="hidden" asp-for="Details[@i].AdjustmentDetailId" />
                                <input type="hidden" asp-for="Details[@i].CatalogId" class="row-catalog" />

                                <td class="book-cell">
                                    <select asp-for="Details[@i].BookId"
                                            class="adj-form-select book-select"
                                            data-selected="@Model.Details[i].BookId"
                                            asp-items="Model.Books ?? new List<SelectListItem>()">
                                        <option value="">-- select book --</option>
                                    </select>
                                    <span asp-validation-for="Details[@i].BookId" class="text-danger"></span>
                                </td>

                                <td>
                                    <input asp-for="Details[@i].QuantityChanged" class="adj-form-control qty-input" type="number" />
                                    <span asp-validation-for="Details[@i].QuantityChanged" class="text-danger"></span>
                                </td>

                                <td>
                                    <input asp-for="Details[@i].Note" class="adj-form-control" />
                                    <span asp-validation-for="Details[@i].Note" class="text-danger"></span>
                                </td>

                                <td class="text-center">
                                    <button type="button" class="adj-btn-sm adj-btn-danger" onclick="removeDetailRow(this)">×</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button type="submit" class="adj-btn adj-btn-primary">
                <i class="bi bi-check2-circle"></i> Save Changes
            </button>
            <a asp-action="Index" class="adj-btn">
                <i class="bi bi-arrow-left"></i> Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const detailsBody   = document.querySelector('#detailsTable tbody');
        const addBtn        = document.getElementById('addRowBtn');
        const qtyTotal      = document.getElementById('qtyTotal');
        const adjType       = document.getElementById('adjType');
        const headerCatalog = document.getElementById('headerCatalog');
        const statQty       = document.getElementById('statQty');
        const statRows      = document.getElementById('statRows');
        const statType      = document.getElementById('statType');

        const booksUrl = '@Url.Action("GetBooksForCatalog", "Adjustments")';

        let currentBooks = [];

        // ── helpers ────────────────────────────────────────────────────────────

        function normalizeByType(v) {
            if (Number.isNaN(v)) return 0;
            const t = adjType?.value || '';
            if (t === 'Decrease' || t === 'Damage' || t === 'Lost') return -Math.abs(v);
            if (t === 'Increase') return Math.abs(v);
            return v;
        }

        function updateTypeHint(sum) {
            const hint = document.getElementById('typeHint');
            if (!hint) return;
            const t = adjType?.value || '';
            if (t === 'Decrease' || t === 'Damage' || t === 'Lost') {
                hint.innerHTML = "For <strong>Damage/Decrease/Lost</strong>, enter positive numbers; we'll store them as negative. Current total: <strong>" + sum + "</strong>";
            } else if (t === 'Increase') {
                hint.innerHTML = "For <strong>Increase</strong>, enter positive numbers. Current total: <strong>" + sum + "</strong>";
            } else {
                hint.innerHTML = "Tip: Enter positive or negative numbers as needed. Current total: <strong>" + sum + "</strong>";
            }
        }

        function recalcTotal() {
            let sum = 0, rows = 0;
            detailsBody.querySelectorAll('.qty-input').forEach(inp => {
                rows++;
                sum += normalizeByType(Number(inp.value));
            });
            if (qtyTotal)  qtyTotal.value        = sum;
            if (statQty)   statQty.textContent    = sum;
            if (statRows)  statRows.textContent   = rows;
            if (statType && adjType) statType.textContent = adjType.value || '—';
            updateTypeHint(sum);
        }

        function wireQtyInputs(container) {
            container.querySelectorAll('.qty-input').forEach(inp => {
                inp.addEventListener('input', recalcTotal);
            });
        }

        function updateBookColumnVisibility() {
            const showBook = ['Damage', 'Lost'].includes(adjType?.value || '');

            document.querySelectorAll('.book-col').forEach(th => th.style.display = showBook ? '' : 'none');
            document.querySelectorAll('.book-cell').forEach(td => {
                td.style.display = showBook ? '' : 'none';
                const sel = td.querySelector('select');
                if (sel) sel.disabled = !showBook;
            });

            document.querySelectorAll('.qty-input').forEach(inp => {
                if (showBook) { inp.value = 1; inp.readOnly = true; }
                else          { inp.readOnly = false; }
            });

            recalcTotal();
        }

        // ── book loading ────────────────────────────────────────────────────────

        async function loadBooksForCatalog(preserveSelected) {
            const catId = headerCatalog?.value;
            if (!catId) {
                currentBooks = [];
                updateAllBookSelects(preserveSelected);
                return;
            }
            try {
                const resp = await fetch(booksUrl + '?catalogId=' + encodeURIComponent(catId));
                if (!resp.ok) return;
                currentBooks = await resp.json();
                updateAllBookSelects(preserveSelected);
            } catch (e) {
                console.error('Error loading books', e);
            }
        }

        function updateAllBookSelects(preserveSelected) {
            detailsBody.querySelectorAll('.book-select').forEach(sel => {
                // prefer data-selected (set by Razor on page load), fall back to current value
                const chosen = sel.dataset.selected || sel.value || '';

                sel.innerHTML = '<option value="">-- select book --</option>';
                currentBooks.forEach(b => {
                    const opt = document.createElement('option');
                    opt.value = b.id;
                    opt.textContent = b.text;
                    if (chosen && String(chosen) === String(b.id)) opt.selected = true;
                    sel.appendChild(opt);
                });

                // once restored, keep dataset in sync so subsequent reloads work
                if (sel.value) sel.dataset.selected = sel.value;
            });

            const catId = headerCatalog?.value || '';
            detailsBody.querySelectorAll('.row-catalog').forEach(h => h.value = catId);
        }

        function buildBookOptions(selectedId) {
            let html = '<option value="">-- select book --</option>';
            currentBooks.forEach(b => {
                const sel = selectedId && String(selectedId) === String(b.id) ? ' selected' : '';
                html += `<option value="${b.id}"${sel}>${b.text}</option>`;
            });
            return html;
        }

        // ── add row ─────────────────────────────────────────────────────────────

        addBtn.addEventListener('click', function () {
            const index = detailsBody.querySelectorAll('tr.detail-row').length;
            const catId = headerCatalog?.value || '';
            const row = document.createElement('tr');
            row.className = 'detail-row';
            row.innerHTML = `
                <input type="hidden" name="Details[${index}].AdjustmentDetailId" value="" />
                <input type="hidden" name="Details[${index}].CatalogId" class="row-catalog" value="${catId}" />
                <td class="book-cell">
                    <select name="Details[${index}].BookId" class="adj-form-select book-select" data-selected="">
                        ${buildBookOptions('')}
                    </select>
                </td>
                <td>
                    <input name="Details[${index}].QuantityChanged" class="adj-form-control qty-input" type="number" value="" />
                </td>
                <td>
                    <input name="Details[${index}].Note" class="adj-form-control" value="" />
                </td>
                <td class="text-center">
                    <button type="button" class="adj-btn-sm adj-btn-danger" onclick="removeDetailRow(this)">×</button>
                </td>`;

            detailsBody.appendChild(row);
            wireQtyInputs(row);
            updateBookColumnVisibility();
            recalcTotal();
        });

        function removeDetailRow(btn) {
            btn.closest('tr')?.remove();
            recalcTotal();
        }
        window.removeDetailRow = removeDetailRow;

        // ── event listeners ─────────────────────────────────────────────────────

        adjType?.addEventListener('change', () => {
            updateBookColumnVisibility();
            recalcTotal();
        });

        headerCatalog?.addEventListener('change', () => {
            // user manually changed catalog — do NOT preserve old book selections
            detailsBody.querySelectorAll('.book-select').forEach(s => s.dataset.selected = '');
            loadBooksForCatalog(false);
        });

                        // ── init ────────────────────────────────────────────────────────────────

        wireQtyInputs(detailsBody);
        recalcTotal();
        updateBookColumnVisibility();

        // Pre-populate currentBooks from already-rendered server-side options
        // so addRow() works without needing a fetch first
        if (headerCatalog?.value) {
            fetch(booksUrl + '?catalogId=' + encodeURIComponent(headerCatalog.value))
                .then(r => r.json())
                .then(data => {
                    currentBooks = data;
                    // DO NOT call updateAllBookSelects() here — server already rendered correct values
                })
                .catch(e => console.error(e));
        }

        // Only reload + repopulate when user manually changes catalog
        headerCatalog?.addEventListener('change', () => {
            detailsBody.querySelectorAll('.book-select').forEach(s => s.dataset.selected = '');
            loadBooksForCatalog(false);
        });
    </script>
}
