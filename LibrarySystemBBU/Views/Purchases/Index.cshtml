@model IEnumerable<LibrarySystemBBU.Models.Purchase>
@using System.Linq

@{
    ViewData["Title"] = "Purchases";

    var total = Model?.Count() ?? 0;
    var qtySum = Model?.Sum(x => x.Quantity) ?? 0;
    var costSum = Model?.Sum(x => x.Cost) ?? 0m;

    var suppliers = Model?
        .Select(x => x.Supplier ?? "")
        .Where(s => !string.IsNullOrWhiteSpace(s))
        .Distinct()
        .OrderBy(s => s)
        .ToList() ?? new List<string>();
}

@functions {
    string BookLabel(LibrarySystemBBU.Models.Book? b)
    {
        if (b == null) return string.Empty;
        var baseTitle = !string.IsNullOrWhiteSpace(b.Title)
            ? b.Title
            : (!string.IsNullOrWhiteSpace(b.Catalog?.Title) ? b.Catalog!.Title : $"Book #{b.BookId}");
        var text = !string.IsNullOrWhiteSpace(b.Catalog?.ISBN)
            ? $"{baseTitle} — {b.Catalog!.ISBN}" : baseTitle;
        if (text.StartsWith("Book #") && !string.IsNullOrWhiteSpace(b.Barcode))
            text = $"{text} — {b.Barcode}";
        return text;
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .pur-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .pur-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .pur-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .pur-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .pur-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .pur-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .pur-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .pur-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .pur-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .pur-segmented {
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .pur-seg-btn {
        padding: 6px 13px;
        font-size: .82rem;
        font-weight: 500;
        border: none;
        background: #fff;
        color: #6b7280;
        cursor: pointer;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
    }

        .pur-seg-btn:not(:last-child) {
            border-right: 1px solid #e5e7eb;
        }

        .pur-seg-btn.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

    .pur-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        background: #fff;
        flex: 1;
        min-width: 200px;
        max-width: 360px;
        transition: border-color .15s;
    }

        .pur-search-wrap:focus-within {
            border-color: #000080;
        }

        .pur-search-wrap i {
            color: #9ca3af;
            font-size: .85rem;
        }

    .pur-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: .83rem;
        color: #111827;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

        .pur-search-input::placeholder {
            color: #9ca3af;
        }

    .pur-search-clear {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        padding: 0;
        font-size: .85rem;
    }

        .pur-search-clear:hover {
            color: #6b7280;
        }

    .pur-select {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 10px;
        font-size: .82rem;
        font-family: 'Inter', sans-serif;
        color: #374151;
        background: #fff;
        cursor: pointer;
        outline: none;
    }

        .pur-select:focus {
            border-color: #000080;
        }

    .pur-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
        flex-wrap: wrap;
    }

    .pur-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .pur-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .pur-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .pur-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .pur-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .pur-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .pur-table tbody tr:last-child {
                border-bottom: none;
            }

            .pur-table tbody tr:hover {
                background: #f9fafb;
            }

        .pur-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

            .pur-table tbody td.muted {
                color: #6b7280;
            }

        .pur-table .text-end {
            text-align: right;
        }

    .pur-supplier-pill {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: .72rem;
        font-weight: 600;
        background: #f0f2ff;
        color: #000080;
        border: 1px solid #c7cbee;
        border-radius: 20px;
        padding: 2px 9px;
    }

    .pur-pager {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 0;
    }

    #purNoMatches {
        text-align: center;
        padding: 2rem;
        color: #9ca3af;
        font-size: .85rem;
        display: none;
    }
</style>

<div class="pur-page">

    <div class="pur-page-title">Purchases</div>

    <div class="pur-toolbar">
        <a asp-action="Create" class="pur-btn pur-btn-primary">
            <i class="bi bi-plus-circle"></i> New Purchase
        </a>

        <div class="pur-segmented">
            <button type="button" class="pur-seg-btn active" data-filter="all">
                <i class="bi bi-grid"></i> All
            </button>
            <button type="button" class="pur-seg-btn" data-filter="thisMonth">
                <i class="bi bi-calendar-month"></i> This Month
            </button>
            <button type="button" class="pur-seg-btn" data-filter="last30">
                <i class="bi bi-clock-history"></i> Last 30
            </button>
            <button type="button" class="pur-seg-btn" data-filter="today">
                <i class="bi bi-calendar-event"></i> Today
            </button>
        </div>

        <select id="supplierFilter" class="pur-select">
            <option value="">All suppliers</option>
            @foreach (var s in suppliers)
            {
                <option value="@s">@s</option>
            }
        </select>

        <div class="pur-search-wrap">
            <i class="bi bi-search"></i>
            <input id="globalSearch" class="pur-search-input"
                   placeholder="Search date, book, supplier, qty, cost…" />
            <button class="pur-search-clear" type="button" id="clearSearch">
                <i class="bi bi-x-circle"></i>
            </button>
        </div>

        <a asp-action="Export" class="pur-btn">
            <i class="bi bi-download"></i> Export
        </a>

        <div class="pur-stats">
            <span class="pur-stat-pill">
                <i class="bi bi-layers"></i> Total: <strong id="statTotal">@total</strong>
            </span>
            <span class="pur-stat-pill">
                <i class="bi bi-123"></i> Qty: <strong id="statQty">@qtySum</strong>
            </span>
            <span class="pur-stat-pill">
                <i class="bi bi-cash-coin"></i> Cost: <strong id="statCost">@costSum.ToString("N2")</strong>
            </span>
        </div>
    </div>

    <div class="pur-table-wrap">
        <table class="pur-table" id="purchasesTable">
            <thead>
                <tr>
                    <th>Purchase Date</th>
                    <th>Book</th>
                    <th>Supplier</th>
                    <th class="text-end">Quantity</th>
                    <th class="text-end">Cost</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-date="@item.PurchaseDate.ToString("yyyy-MM-dd")"
                        data-supplier="@((item.Supplier ?? "").ToLower())"
                        data-qty="@item.Quantity"
                        data-cost="@item.Cost">
                        <td class="muted">@item.PurchaseDate.ToString("yyyy-MM-dd")</td>
                        <td style="font-weight:500;color:#111827;">@BookLabel(item.Book)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Supplier))
                            {
                                <span class="pur-supplier-pill">
                                    <i class="bi bi-truck"></i> @item.Supplier
                                </span>
                            }
                        </td>
                        <td class="text-end">@item.Quantity</td>
                        <td class="text-end">@item.Cost.ToString("N2")</td>
                        <td class="muted">@item.Notes</td>
                        <td style="white-space:nowrap;display:flex;gap:4px;padding:8px 16px;">
                            <a class="pur-btn" style="padding:4px 10px;font-size:.74rem;"
                               asp-action="Details" asp-route-id="@item.PurchaseId">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a class="pur-btn" style="padding:4px 10px;font-size:.74rem;"
                               asp-action="Edit" asp-route-id="@item.PurchaseId">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a class="pur-btn" style="padding:4px 10px;font-size:.74rem;"
                               asp-action="Delete" asp-route-id="@item.PurchaseId">
                                <i class="bi bi-trash3"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div id="purNoMatches">No matching results for your filters / search.</div>
    </div>

    <div class="pur-pager">
        <button type="button" class="pur-btn" id="prevPage">
            <i class="bi bi-chevron-left"></i> Prev
        </button>
        <span id="pageInfo" style="font-size:.82rem;color:#6b7280;">Page 1 / 1</span>
        <button type="button" class="pur-btn" id="nextPage">
            Next <i class="bi bi-chevron-right"></i>
        </button>
    </div>

</div>

@section Scripts {
    <script>
        (() => {
            const PAGE_SIZE = 50;
            let pageIndex = 1;
            let activeFilter = 'all';

            const search     = document.getElementById('globalSearch');
            const clearBtn   = document.getElementById('clearSearch');
            const supSel     = document.getElementById('supplierFilter');
            const segBtns    = Array.from(document.querySelectorAll('.pur-seg-btn'));
            const statTotal  = document.getElementById('statTotal');
            const statQty    = document.getElementById('statQty');
            const statCost   = document.getElementById('statCost');
            const prevBtn    = document.getElementById('prevPage');
            const nextBtn    = document.getElementById('nextPage');
            const pageInfo   = document.getElementById('pageInfo');
            const noMsg      = document.getElementById('purNoMatches');
            const allRows    = Array.from(document.querySelectorAll('#purchasesTable tbody tr'));

            const today = new Date(new Date().toISOString().slice(0, 10));
            const addDays = (d, n) => new Date(d.getTime() + n * 86400000);
            const firstOfMonth = d => new Date(d.getFullYear(), d.getMonth(), 1);

            function inPreset(dateStr, preset) {
                if (!preset || preset === 'all') return true;
                const dt = new Date(dateStr);
                if (preset === 'today')     return dt.getTime() === today.getTime();
                if (preset === 'last30')    return dt >= addDays(today, -30) && dt <= today;
                if (preset === 'thisMonth') return dt >= firstOfMonth(today) && dt <= today;
                return true;
            }

            function apply() {
                const q   = (search.value || '').trim().toLowerCase();
                const sup = supSel.value.toLowerCase();

                const matched = allRows.filter(r => {
                    const dt   = r.getAttribute('data-date');
                    const rs   = r.getAttribute('data-supplier') || '';
                    const txt  = (r.innerText || '').toLowerCase();
                    return inPreset(dt, activeFilter)
                        && (!sup || rs === sup)
                        && (!q   || txt.includes(q));
                });

                // Stats
                let qty = 0, cost = 0;
                matched.forEach(r => {
                    qty  += parseInt(r.getAttribute('data-qty')  || '0');
                    cost += parseFloat(r.getAttribute('data-cost') || '0');
                });
                statTotal.textContent = matched.length.toLocaleString();
                statQty.textContent   = qty.toString();
                statCost.textContent  = (isNaN(cost) ? 0 : cost)
                    .toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                // Pagination
                const tp = Math.max(1, Math.ceil(matched.length / PAGE_SIZE));
                pageIndex = Math.min(Math.max(1, pageIndex), tp);
                const visible = new Set(
                    matched.slice((pageIndex - 1) * PAGE_SIZE, pageIndex * PAGE_SIZE)
                );

                allRows.forEach(r => r.style.display = visible.has(r) ? '' : 'none');

                pageInfo.textContent = `Page ${matched.length ? pageIndex : 0} / ${matched.length ? tp : 0}`;
                prevBtn.disabled = pageIndex <= 1 || !matched.length;
                nextBtn.disabled = pageIndex >= tp || !matched.length;
                noMsg.style.display = matched.length === 0 ? 'block' : 'none';
            }

            segBtns.forEach(b => b.addEventListener('click', () => {
                segBtns.forEach(x => x.classList.remove('active'));
                b.classList.add('active');
                activeFilter = b.dataset.filter;
                pageIndex = 1;
                apply();
            }));

            let st;
            search.addEventListener('input', () => { clearTimeout(st); st = setTimeout(() => { pageIndex = 1; apply(); }, 200); });
            clearBtn.addEventListener('click', () => { search.value = ''; pageIndex = 1; apply(); });
            supSel.addEventListener('change', () => { pageIndex = 1; apply(); });

            prevBtn.addEventListener('click', () => { pageIndex--; apply(); });
            nextBtn.addEventListener('click', () => { pageIndex++; apply(); });

            apply();
        })();
    </script>
}
