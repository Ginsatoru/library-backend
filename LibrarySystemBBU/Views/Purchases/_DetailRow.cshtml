@model LibrarySystemBBU.Models.PurchaseDetail
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    var idx = ViewData["index"]?.ToString() ?? "0";
    var bookSelect = (SelectList)ViewData["bookSelect"];
}

<tr class="align-middle">
    <td style="display:none;">
        <input type="hidden" name="PurchaseDetails[@(idx)].PurchaseDetailId" value="@Model.PurchaseDetailId" />
        <input type="hidden" name="PurchaseDetails[@(idx)].PurchaseId" value="@Model.PurchaseId" />
    </td>

    <!-- Book -->
    <td style="min-width:240px;">
        <select class="book-select"
                name="PurchaseDetails[@(idx)].BookId"
                id="PurchaseDetails_@(idx)__BookId"
                style="width:100%;">
            @if (Model.BookId != 0 && Model.Book != null)
            {
                var bookTitle = !string.IsNullOrWhiteSpace(Model.Book.Title)
                ? Model.Book.Title
                : (Model.Book.Catalog?.Title ?? $"Book #{Model.BookId}");
                var bookLabel = Model.Book.Catalog?.ISBN != null
                ? $"{bookTitle} — {Model.Book.Catalog.ISBN}" : bookTitle;
                <option value="@Model.BookId" selected="selected">@bookLabel</option>
            }
            else
            {
                <option value="">— select a book —</option>
            }
        </select>
        <span class="text-danger" style="font-size:.72rem;"
              data-valmsg-for="PurchaseDetails[@(idx)].BookId"
              data-valmsg-replace="true"></span>
    </td>

    <!-- Quantity -->
    <td style="width:110px;">
        <input class="dr-input" type="number" min="1" step="1"
               name="PurchaseDetails[@(idx)].Quantity"
               id="PurchaseDetails_@(idx)__Quantity"
               value="@(Model.Quantity == 0 ? "" : Model.Quantity.ToString())"
               placeholder="0" />
        <span class="text-danger" style="font-size:.72rem;"
              data-valmsg-for="PurchaseDetails[@(idx)].Quantity"
              data-valmsg-replace="true"></span>
    </td>

    <!-- Unit Price -->
    <td style="width:130px;">
        <input class="dr-input" type="number" min="0" step="0.01"
               name="PurchaseDetails[@(idx)].UnitPrice"
               id="PurchaseDetails_@(idx)__UnitPrice"
               value="@(Model.UnitPrice == 0 ? "" : Model.UnitPrice.ToString("0.##"))"
               placeholder="0.00" />
        <span class="text-danger" style="font-size:.72rem;"
              data-valmsg-for="PurchaseDetails[@(idx)].UnitPrice"
              data-valmsg-replace="true"></span>
    </td>

    <!-- Line Total (readonly) -->
    <td style="width:130px;">
        <input class="dr-input" type="number" min="0" step="0.01" readonly
               name="PurchaseDetails[@(idx)].LineTotal"
               id="PurchaseDetails_@(idx)__LineTotal"
               value="@(Model.LineTotal == 0 ? "" : Model.LineTotal.ToString("0.##"))"
               placeholder="0.00" />
        <span class="dr-auto-label">auto</span>
    </td>

    <!-- Remove -->
    <td style="width:46px;text-align:center;">
        <button class="btn-remove-row dr-remove-btn" type="button" title="Remove row">
            <i class="bi bi-trash3"></i>
        </button>
    </td>
</tr>


