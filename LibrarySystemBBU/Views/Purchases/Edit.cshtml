@model LibrarySystemBBU.Models.Purchase
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Edit Purchase";
    var bookSelect = (SelectList)ViewData["BookId"];
    var list = (Model.PurchaseDetails ?? Enumerable.Empty<LibrarySystemBBU.Models.PurchaseDetail>()).ToList();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

<style>
    .pe-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .pe-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .pe-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .pe-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .pe-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .pe-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .pe-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .pe-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .pe-header-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        margin-bottom: 1.25rem;
    }

    .pe-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .pe-card-header {
        padding: 14px 20px;
        border-bottom: 1px solid #f3f4f6;
        font-size: .7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 6px;
        background: #f9fafb;
    }

    .pe-card-body {
        padding: 20px;
    }

    .pe-label {
        display: block;
        font-size: .75rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 5px;
    }

    .pe-input {
        width: 100%;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: .84rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        background: #fff;
        outline: none;
        transition: border-color .15s;
    }

        .pe-input:focus {
            border-color: #000080;
            box-shadow: 0 0 0 3px rgba(0,0,128,.07);
        }

    .pe-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 2fr;
        gap: 16px;
    }

    @@media (max-width: 700px) {
        .pe-form-grid {
            grid-template-columns: 1fr;
        }
    }

    /* Table */
    .pe-table-wrap {
        overflow-x: auto;
    }

    .pe-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .pe-table thead th {
            padding: 11px 14px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .pe-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
        }

            .pe-table tbody tr:last-child {
                border-bottom: none;
            }

        .pe-table tbody td {
            padding: 10px 14px;
            vertical-align: middle;
        }

        .pe-table tfoot td {
            padding: 10px 14px;
            background: #f9fafb;
            border-top: 1px solid #e5e7eb;
            font-weight: 600;
            font-size: .82rem;
        }

        .pe-table .text-end {
            text-align: right;
        }

    .pe-row-input {
        border: 1px solid #e5e7eb;
        border-radius: 7px;
        padding: 7px 10px;
        font-size: .83rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        background: #fff;
        width: 100%;
        outline: none;
        transition: border-color .15s;
    }

        .pe-row-input:focus {
            border-color: #000080;
        }

        .pe-row-input[readonly] {
            background: #f9fafb;
            color: #6b7280;
        }

    .pe-row-actions {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .pe-remove-btn {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1px solid #fecaca;
        background: #fff;
        color: #dc2626;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        transition: background .15s;
    }

        .pe-remove-btn:hover {
            background: #fef2f2;
        }

    .pe-sticky-footer {
        position: sticky;
        bottom: 0;
        background: #fff;
        border-top: 1px solid #e5e7eb;
        padding: 12px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-radius: 0 0 14px 14px;
        z-index: 10;
    }

    .pe-footer-note {
        font-size: .76rem;
        color: #9ca3af;
    }

    /* Select2 sync */
    .select2-container .select2-selection--single {
        height: 36px;
        border-radius: 7px;
        border-color: #e5e7eb;
        display: flex;
        align-items: center;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: normal;
        padding-top: 0;
        padding-bottom: 0;
        font-size: .83rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        display: flex;
        align-items: center;
        height: 100%;
    }

    .select2-container--default .select2-selection--single .select2-selection__placeholder {
        color: #9ca3af;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 34px;
        top: 1px;
    }

    .select2-container--default.select2-container--focus .select2-selection--single {
        border-color: #000080;
        box-shadow: 0 0 0 3px rgba(0,0,128,.07);
        outline: none;
    }

    .dr-input {
        border: 1px solid #e5e7eb;
        border-radius: 7px;
        padding: 7px 10px;
        font-size: .83rem;
        font-family: 'Inter', sans-serif;
        color: #111827;
        background: #fff;
        width: 100%;
        outline: none;
        transition: border-color .15s;
        text-align: right;
    }

        .dr-input:focus {
            border-color: #000080;
            box-shadow: 0 0 0 3px rgba(0,0,128,.06);
        }

        .dr-input[readonly] {
            background: #f9fafb;
            color: #9ca3af;
            cursor: default;
        }

    .dr-remove-btn {
        width: 30px;
        height: 30px;
        border-radius: 7px;
        border: 1px solid #fecaca;
        background: #fff;
        color: #dc2626;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        transition: background .15s;
        flex-shrink: 0;
    }

        .dr-remove-btn:hover {
            background: #fef2f2;
        }

    .dr-auto-label {
        font-size: .68rem;
        color: #9ca3af;
        display: block;
        text-align: right;
        margin-top: 2px;
    }
</style>

<div class="pe-page">

    <div class="pe-header-bar">
        <div class="pe-page-title" style="margin-bottom:0;">Edit Purchase</div>
        <a asp-action="Index" class="pe-btn">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PurchaseId" />

        <!-- Header fields -->
        <div class="pe-card">
            <div class="pe-card-header"><i class="bi bi-receipt"></i> Purchase Information</div>
            <div class="pe-card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:.82rem;"></div>
                <div class="pe-form-grid">
                    <div>
                        <label asp-for="PurchaseDate" class="pe-label">
                            <i class="bi bi-calendar3" style="color:#000080;"></i> Purchase Date
                        </label>
                        <input asp-for="PurchaseDate" class="pe-input" />
                        <span asp-validation-for="PurchaseDate" class="text-danger" style="font-size:.75rem;"></span>
                    </div>
                    <div>
                        <label asp-for="Supplier" class="pe-label">
                            <i class="bi bi-truck" style="color:#000080;"></i> Supplier
                        </label>
                        <input asp-for="Supplier" class="pe-input" />
                        <span asp-validation-for="Supplier" class="text-danger" style="font-size:.75rem;"></span>
                    </div>
                    <div>
                        <label asp-for="Notes" class="pe-label">
                            <i class="bi bi-stickies" style="color:#000080;"></i> Notes
                        </label>
                        <input asp-for="Notes" class="pe-input" />
                        <span asp-validation-for="Notes" class="text-danger" style="font-size:.75rem;"></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Line items -->
        <div class="pe-card">
            <div class="pe-card-header" style="justify-content:space-between;">
                <span style="display:flex;align-items:center;gap:6px;">
                    <i class="bi bi-table"></i> Line Items
                </span>
                <div style="display:flex;gap:6px;">
                    <button type="button" class="pe-btn" id="add3Btn" style="font-size:.76rem;padding:5px 11px;">
                        <i class="bi bi-plus-circle"></i> Add 3 Rows
                    </button>
                    <button type="button" class="pe-btn pe-btn-primary" id="addRowBtn" style="font-size:.76rem;padding:5px 11px;">
                        <i class="bi bi-plus-circle"></i> Add Row
                    </button>
                </div>
            </div>

            <div class="pe-table-wrap">
                <table class="pe-table" id="detailsTable">
                    <thead>
                        <tr>
                            <th style="min-width:260px;">Book</th>
                            <th class="text-end" style="width:110px;">Quantity</th>
                            <th class="text-end" style="width:130px;">Unit Price</th>
                            <th class="text-end" style="width:130px;">Line Total</th>
                            <th style="width:46px;"></th>
                        </tr>
                    </thead>
                    <tbody id="detailBody">
                        @for (var i = 0; i < list.Count; i++)
                        {
                            var d = list[i];
                            @await Html.PartialAsync("_DetailRow", d,
                            new ViewDataDictionary(ViewData) { { "index", i }, { "bookSelect", bookSelect } })
                                                }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td>Totals</td>
                            <td class="text-end"><span id="footerQty">0</span></td>
                            <td class="text-end">—</td>
                            <td class="text-end"><span id="footerCost">0.00</span></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="pe-sticky-footer">
                <span class="pe-footer-note">
                    <i class="bi bi-info-circle"></i> Line Total = Quantity × Unit Price (auto)
                </span>
                <div style="display:flex;gap:8px;">
                    <button type="submit" class="pe-btn pe-btn-primary">
                        <i class="bi bi-floppy-disk"></i> Save
                    </button>
                    <a asp-action="Index" class="pe-btn">
                        <i class="bi bi-x-lg"></i> Cancel
                    </a>
                </div>
            </div>
        </div>

        <!-- Hidden template row -->
        <table class="d-none">
            <tbody id="detailRowTemplate">
                @await Html.PartialAsync(
                                "_DetailRow",
                                new LibrarySystemBBU.Models.PurchaseDetail(),
                                new ViewDataDictionary(ViewData) {
                                { "index", "__index__" },
                                { "bookSelect", bookSelect }
                                })
            </tbody>
        </table>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        (function () {
            const body       = document.getElementById('detailBody');
            const template   = document.getElementById('detailRowTemplate').innerHTML;
            const addBtn     = document.getElementById('addRowBtn');
            const add3Btn    = document.getElementById('add3Btn');
            const footerQty  = document.getElementById('footerQty');
            const footerCost = document.getElementById('footerCost');

                    function initSelect2(scope) {
            $(scope).find('select.book-select').each(function () {
                const $sel = $(this);
                const hiddenId = $sel.data('hidden-id');

                $sel.select2({
                    placeholder: 'Search book by title, ISBN, barcode…',
                    width: '100%',
                    minimumInputLength: 1,
                    delay: 300,
                    ajax: {
                        url: '/Purchases/SearchBooks',
                        dataType: 'json',
                        data: function (params) {
                            return { term: params.term, page: params.page || 1 };
                        },
                        processResults: function (data) {
                            return { results: data.results, pagination: data.pagination };
                        }
                    }
                });

                // Sync selected catalog GUID into the hidden input
                $sel.on('select2:select', function (e) {
                    const val = e.params.data.id || '';
                    $('#' + hiddenId).val(val);
                });

                $sel.on('select2:clear select2:unselect', function () {
                    $('#' + hiddenId).val('');
                });
            });
        }

            function parseNum(v, dp) {
                const n = parseFloat(v);
                return Number.isFinite(n) ? (dp != null ? Number(n.toFixed(dp)) : n) : 0;
            }

            function recalcFooter() {
                let qty = 0, cost = 0;
                body.querySelectorAll('tr').forEach(tr => {
                    qty  += parseNum(tr.querySelector('input[id$="__Quantity"]')?.value  || '0', 0);
                    cost += parseNum(tr.querySelector('input[id$="__LineTotal"]')?.value || '0', 2);
                });
                footerQty.textContent  = qty.toString();
                footerCost.textContent = (isNaN(cost) ? 0 : cost)
                    .toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function wireRow(tr) {
                const q  = tr.querySelector('input[id$="__Quantity"]');
                const up = tr.querySelector('input[id$="__UnitPrice"]');
                const lt = tr.querySelector('input[id$="__LineTotal"]');
                if (lt) lt.readOnly = true;
                function recalc() {
                    const qty   = parseNum(q?.value  || '0', 0);
                    const price = parseNum(up?.value || '0', 2);
                    if (lt) lt.value = (qty * price).toFixed(2);
                    recalcFooter();
                }
                q?.addEventListener('input', recalc);
                up?.addEventListener('input', recalc);
                recalc();
            }

            function addRow(focus = true) {
                const index   = body.querySelectorAll('tr').length;
                const html    = template.replaceAll('__index__', index);
                const wrapper = document.createElement('tbody');
                wrapper.innerHTML = html.trim();
                const tr = wrapper.querySelector("tr");
                body.appendChild(tr);
                initSelect2(tr);
                wireRow(tr);
                if (focus) tr.querySelector('select, input')?.focus();
                recalcFooter();
            }

            Array.from(body.querySelectorAll('tr')).forEach(tr => { initSelect2(tr); wireRow(tr); });

            addBtn.addEventListener('click',  () => addRow(true));
            add3Btn.addEventListener('click', () => { addRow(false); addRow(false); addRow(true); });

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.btn-remove-row');
                if (btn) {
                    e.preventDefault();
                    const tr = btn.closest('tr');
                    if (tr?.parentNode) {
                        $(tr).find('select.book-select').each(function () { $(this).select2('destroy'); });
                        tr.parentNode.removeChild(tr);
                        recalcFooter();
                    }
                }
            });

            recalcFooter();
        })();
    </script>
}
