@model LibrarySystemBBU.Controllers.LibraryLogsController.LibraryLogFormVM
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Create Library Log";
    var today = DateTime.Today.ToString("yyyy-MM-dd");
    var bookList = (SelectList)ViewBag.BookList;

    string status = string.IsNullOrWhiteSpace(Model?.Status) ? "Pending" : Model!.Status!;
    string StatusBadge(string s) => s switch
    {
        "Approved" => "status-approved",
        "Returned" => "status-returned",
        _ => "status-pending"
    };
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .logs-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .logs-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .logs-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .logs-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none !important;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .logs-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none !important;
        }

    .logs-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .logs-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .logs-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .logs-card-header {
        padding: 14px 16px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
        color: #111827;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .logs-card-body {
        padding: 1.25rem;
    }

    .logs-form-label {
        font-size: .8rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: .25rem;
    }

    .logs-form-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        transition: border-color .15s;
    }

        .logs-form-control:focus {
            outline: none;
            border-color: #000080;
        }

    .logs-form-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        background-color: #fff;
    }

        .logs-form-select:focus {
            outline: none;
            border-color: #000080;
        }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .74rem;
        font-weight: 500;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-approved {
        background: #dcfce7;
        color: #166534;
    }

    .status-returned {
        background: #e0f2fe;
        color: #0369a1;
    }

    .logs-picker-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 1rem;
    }

    @@media (max-width: 768px) {
        .logs-picker-grid {
            grid-template-columns: 1fr;
        }
    }

    .logs-picker-col {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        background: #fff;
    }

    .logs-picker-header {
        padding: 10px 12px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        font-size: .8rem;
        font-weight: 600;
        color: #374151;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .logs-picker-search {
        padding: 8px;
        border-bottom: 1px solid #e5e7eb;
    }

    .logs-picker-search-input {
        width: 100%;
        padding: 6px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: .8rem;
    }

        .logs-picker-search-input:focus {
            outline: none;
            border-color: #000080;
        }

    .logs-picker-body {
        padding: 12px;
        max-height: 320px;
        overflow-y: auto;
    }

    .logs-book-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 10px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        margin-bottom: 6px;
        background: #fff;
        transition: background .15s;
        gap: 10px;
    }

        .logs-book-item:hover {
            background: #f9fafb;
        }

    .logs-book-title {
        font-size: .85rem;
        font-weight: 500;
        color: #111827;
    }

    .logs-pick-btn {
        padding: 4px 10px;
        font-size: .7rem;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        cursor: pointer;
        white-space: nowrap;
    }

        .logs-pick-btn:hover {
            background: #000080;
            color: #fff;
            border-color: #000080;
        }

    .logs-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        font-size: .8rem;
        margin: 0 6px 6px 0;
    }

    .logs-chip-remove {
        background: none;
        border: none;
        color: #6b7280;
        cursor: pointer;
        padding: 2px;
        display: inline-flex;
        align-items: center;
    }

        .logs-chip-remove:hover {
            color: #dc2626;
        }

    .logs-muted {
        color: #6b7280;
        font-size: .85rem;
    }

    .logs-hint {
        font-size: .8rem;
        color: #6b7280;
        margin-top: .5rem;
    }

    a, a:hover {
        text-decoration: none !important;
    }
</style>

<div class="logs-page">
    <div class="logs-page-title">Create Library Log</div>

    <form asp-action="Create" method="post" id="logForm">
        @Html.AntiForgeryToken()

        <div class="logs-card">
            <div class="logs-card-header">
                <i class="bi bi-journal-plus"></i> Log Information
                <div class="ms-auto d-flex align-items-center gap-3">
                    <span class="status-badge @StatusBadge(status)">
                        <i class="bi bi-hourglass-split"></i> @status
                    </span>
                    <span class="logs-muted">
                        <i class="bi bi-calendar-date"></i> Visit Date: @today
                    </span>
                </div>
            </div>

            <div class="logs-card-body">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="logs-form-label">Student Name</div>
                        <input asp-for="StudentName" class="logs-form-control" placeholder="e.g., Chan Dany" />
                        <span asp-validation-for="StudentName" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <div class="logs-form-label">Phone Number</div>
                        <input asp-for="PhoneNumber" class="logs-form-control" placeholder="012345678" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <div class="logs-form-label">Gender</div>
                        <select asp-for="Gender" class="logs-form-select">
                            <option value="">-- Select Gender --</option>
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <div class="logs-form-label">Visit Date</div>
                        <input type="text" class="logs-form-control" value="@today" readonly />
                        <input type="hidden" asp-for="VisitDate" value="@today" />
                        <span asp-validation-for="VisitDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <div class="logs-form-label">Purpose</div>
                        <input asp-for="Purpose" class="logs-form-control" placeholder="Reading, Research, Computer use..." />
                        <span asp-validation-for="Purpose" class="text-danger"></span>
                    </div>
                    <div class="col-md-12">
                        <div class="logs-form-label">Notes</div>
                        <textarea asp-for="Notes" class="logs-form-control" rows="3" placeholder="Any additional notes..."></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <input type="hidden" asp-for="Status" value="Pending" />
                    <input type="hidden" asp-for="ApprovedUtc" />
                    <input type="hidden" asp-for="ReturnedUtc" />
                </div>
            </div>
        </div>

        <div class="logs-card">
            <div class="logs-card-header">
                <i class="bi bi-bookshelf"></i> Books (Pick multiple)
            </div>
            <div class="logs-card-body">
                <div class="logs-picker-grid">
                    <!-- Available -->
                    <div class="logs-picker-col">
                        <div class="logs-picker-header">
                            <i class="bi bi-search"></i> Available Books
                        </div>
                        <div class="logs-picker-search">
                            <input id="q" class="logs-picker-search-input" placeholder="Search title or barcode..." />
                        </div>
                        <div class="logs-picker-body" id="listBody">
                            @foreach (var opt in bookList)
                            {
                                <div class="logs-book-item" data-id="@opt.Value" data-text="@opt.Text">
                                    <span class="logs-book-title">@opt.Text</span>
                                    <button type="button" class="logs-pick-btn" data-id="@opt.Value" data-text="@opt.Text">Pick</button>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Selected -->
                    <div class="logs-picker-col">
                        <div class="logs-picker-header">
                            <i class="bi bi-check2-circle"></i> Selected Books
                        </div>
                        <div class="logs-picker-body" id="chosenBody">
                            <div class="logs-muted" id="emptyHint">None selected yet.</div>
                        </div>
                    </div>
                </div>

                <div id="hiddenInputs"></div>

                <div class="logs-hint">
                    <i class="bi bi-info-circle"></i>
                    Select books from the left to add them. Click × on a chip to remove.
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-3">
            <a asp-action="Index" class="logs-btn">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <button type="submit" class="logs-btn logs-btn-primary">
                <i class="bi bi-check2-circle"></i> Create
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var SELECTED = {};   // id -> text

            var listBody     = document.getElementById('listBody');
            var chosenBody   = document.getElementById('chosenBody');
            var hiddenInputs = document.getElementById('hiddenInputs');
            var emptyHint    = document.getElementById('emptyHint');
            var searchInput  = document.getElementById('q');

            function rebuildHidden() {
                hiddenInputs.innerHTML = '';
                var idx = 0;
                Object.keys(SELECTED).forEach(function (id) {
                    var inp = document.createElement('input');
                    inp.type  = 'hidden';
                    inp.name  = 'BookIds[' + idx + ']';
                    inp.value = id;
                    hiddenInputs.appendChild(inp);
                    idx++;
                });
            }

            function updateEmptyHint() {
                if (Object.keys(SELECTED).length === 0) {
                    emptyHint.style.display = '';
                } else {
                    emptyHint.style.display = 'none';
                }
            }

            function removeChip(id) {
                delete SELECTED[id];

                // Show row again in available list
                var row = listBody.querySelector('.logs-book-item[data-id="' + id + '"]');
                if (row) row.style.display = '';

                // Re-apply search filter
                applySearch();

                rebuildHidden();
                updateEmptyHint();
            }

            function addChip(id, text) {
                var chip = document.createElement('span');
                chip.className   = 'logs-chip';
                chip.setAttribute('data-id', id);

                var label = document.createElement('span');
                label.textContent = text || id;

                var removeBtn = document.createElement('button');
                removeBtn.type      = 'button';
                removeBtn.className = 'logs-chip-remove';
                removeBtn.title     = 'Remove';
                removeBtn.innerHTML = '<i class="bi bi-x-lg"></i>';
                removeBtn.addEventListener('click', function () {
                    chip.remove();
                    removeChip(id);
                });

                chip.appendChild(label);
                chip.appendChild(removeBtn);
                chosenBody.appendChild(chip);
            }

            function pickBook(id, text) {
                if (SELECTED[id]) return;   // already selected

                SELECTED[id] = text;

                // Hide from available list
                var row = listBody.querySelector('.logs-book-item[data-id="' + id + '"]');
                if (row) row.style.display = 'none';

                addChip(id, text);
                rebuildHidden();
                updateEmptyHint();
            }

            function applySearch() {
                var kw = searchInput.value.toLowerCase().trim();
                var items = listBody.querySelectorAll('.logs-book-item');
                items.forEach(function (item) {
                    var id = item.getAttribute('data-id');
                    if (SELECTED[id]) {
                        item.style.display = 'none';
                        return;
                    }
                    var text = (item.getAttribute('data-text') || '').toLowerCase();
                    item.style.display = (!kw || text.includes(kw)) ? '' : 'none';
                });
            }

            // Wire pick buttons
            listBody.querySelectorAll('.logs-pick-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var id   = btn.getAttribute('data-id');
                    var text = btn.getAttribute('data-text');
                    pickBook(id, text);
                });
            });

            // Search
            searchInput.addEventListener('input', applySearch);

            updateEmptyHint();
        })();
    </script>
}
