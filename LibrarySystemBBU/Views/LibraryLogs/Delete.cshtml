@model LibrarySystemBBU.Models.LibraryLog
@{
    ViewData["Title"] = "Delete Library Log";

    string status = Model?.Status ?? "Pending";
    string statusClass = status switch
    {
        "Approved" => "status-approved",
        "Returned" => "status-returned",
        _ => "status-pending"
    };
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    .logs-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .logs-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .logs-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .logs-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .logs-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none !important;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .logs-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none !important;
        }

    .logs-btn-danger {
        background: #fee2e2;
        color: #991b1b;
        border-color: #fecaca;
    }

        .logs-btn-danger:hover {
            background: #fecaca;
            color: #7f1d1d;
        }

    .logs-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .logs-card-header {
        padding: 14px 16px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
        color: #111827;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .logs-card-body {
        padding: 1.25rem;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .74rem;
        font-weight: 500;
    }

    .status-pending {
        background: #fef3c7;
        color: #92400e;
    }

    .status-approved {
        background: #dcfce7;
        color: #166534;
    }

    .status-returned {
        background: #e0f2fe;
        color: #0369a1;
    }

    .logs-alert-warning {
        background: #fffbeb;
        border: 1px solid #fef3c7;
        border-radius: 12px;
        padding: 1rem;
        color: #92400e;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .logs-info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        margin: 1rem 0;
    }

    .logs-info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .logs-info-label {
        font-size: .75rem;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .logs-info-value {
        font-size: .95rem;
        color: #111827;
    }

    .logs-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 10px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        font-size: .8rem;
        margin: 0 6px 6px 0;
    }

    .logs-muted {
        color: #6b7280;
        font-size: .85rem;
    }

    a, a:hover {
        text-decoration: none !important;
    }

    .btn, .btn:hover {
        text-decoration: none !important;
    }
</style>

<div class="logs-page">
    <div class="logs-page-title">Delete Library Log</div>

    <div class="logs-card">
        <div class="logs-card-header">
            <i class="bi bi-exclamation-triangle" style="color:#991b1b;"></i> Confirm Deletion
            <span class="status-badge @statusClass ms-auto">
                <i class="bi @(status == "Approved" ? "bi-check-circle-fill" : status == "Returned" ? "bi-arrow-return-left" : "bi-hourglass-split")"></i>
                @status
            </span>
        </div>

        <div class="logs-card-body">
            @if (!string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
            {
                <div class="logs-alert-warning">
                    <i class="bi bi-shield-exclamation"></i>
                    Only <strong>Pending</strong> logs can be deleted.
                </div>
                <div class="d-flex justify-content-end">
                    <a asp-action="Details" asp-route-id="@Model.LogId" class="logs-btn">
                        <i class="bi bi-arrow-left"></i> Back to Details
                    </a>
                </div>
            }
            else
            {
                <div class="logs-alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>Are you sure?</strong> This action cannot be undone.
                </div>

                <div class="logs-info-grid">
                    <div class="logs-info-item">
                        <span class="logs-info-label">Student Name</span>
                        <span class="logs-info-value">@Model.StudentName</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Phone Number</span>
                        <span class="logs-info-value">@Model.PhoneNumber</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Gender</span>
                        <span class="logs-info-value">@Model.Gender</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Visit Date</span>
                        <span class="logs-info-value">@Model.VisitDate.ToString("yyyy-MM-dd")</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Purpose</span>
                        <span class="logs-info-value">@Model.Purpose</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Notes</span>
                        <span class="logs-info-value">@Model.Notes</span>
                    </div>
                    <div class="logs-info-item">
                        <span class="logs-info-label">Created (UTC)</span>
                        <span class="logs-info-value">@Model.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                </div>

                <div class="mb-3">
                    <span class="logs-info-label">Books</span>
                    <div class="mt-2">
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            foreach (var it in Model.Items)
                            {
                                var title = it.Book?.Catalog?.Title ?? it.Book?.Title ?? "(Unknown)";
                                var code = it.Book?.Barcode ?? "—";
                                <span class="logs-chip">
                                    <i class="bi bi-journal-bookmark"></i>
                                    @($"{title} ({code})")
                                </span>
                            }
                        }
                        else
                        {
                            <span class="logs-muted">—</span>
                        }
                    </div>
                </div>

                <form asp-action="Delete" method="post" id="deleteForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="LogId" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="logs-btn">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="logs-btn logs-btn-danger">
                            <i class="bi bi-trash3"></i> Delete
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            const form = document.getElementById('deleteForm');
            if (!form) return;

            form.addEventListener('submit', async (e) => {
                e.preventDefault();

                const result = await Swal.fire({
                    title: 'Delete this log?',
                    text: 'This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Yes, delete',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#6b7280'
                });

                if (result.isConfirmed) {
                    form.submit();
                }
            });
        })();
    </script>
}