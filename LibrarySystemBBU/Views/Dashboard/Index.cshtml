@model LibrarySystemBBU.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@* Bootstrap and Font Awesome are already loaded in _Layout.cshtml — do NOT re-add them here *@

<style>
    /* Remove all box shadows from every element and hover states */
    *,
    *::before,
    *::after,
    :focus,
    :hover,
    :active,
    .card,
    .card:hover,
    .kpi,
    .kpi:hover,
    .chip,
    .chip:hover,
    .btn,
    .btn:hover,
    .search input,
    .search input:hover,
    .search input:focus,
    #search-results,
    #search-results .result,
    #search-results .result:hover,
    .head,
    .quick,
    .wrap > *,
    .card-body-glass,
    .card-head,
    .opts button,
    .opts button:hover,
    input[type="date"],
    input[type="date"]:hover,
    input[type="date"]:focus {
        box-shadow: none !important;
        outline: none !important;
    }

        /* Remove all gradients */
        .card,
        .kpi,
        .chip,
        .btn,
        .search input,
        #search-results,
        #search-results .result,
        .card-body-glass,
        .card-head,
        .opts button,
        input[type="date"],
        .head,
        .quick,
        .wrap {
            background: transparent !important;
            background-image: none !important;
        }

    /* Set light gray background for cards and KPI boxes */
    .card {
        background-color: #f8f9fa !important;
        border: 1px solid #e9ecef;
    }

    .kpi {
        background-color: #f8f9fa !important;
        border: 1px solid #e9ecef;
    }

    /* Remove gradient from chart background */
    #monthlyChart {
        background-color: transparent !important;
    }

    /* Remove any border that might look like a shadow */
    .kpi,
    .card,
    .search input,
    #search-results .result,
    .chip,
    .btn {
        border: 1px solid #e9ecef;
    }

        /* Ensure focus states are visible but without shadows */
        .search input:focus,
        .btn:focus,
        .chip:focus,
        input[type="date"]:focus {
            border-color: #00b3ff;
            background-color: #ffffff !important;
        }

    /* Keep the card head subtle separation */
    .card-head {
        border-bottom: 1px solid #e9ecef;
        background-color: #f8f9fa !important;
    }

    /* Card body glass style - now solid light gray */
    .card-body-glass {
        background-color: #f8f9fa !important;
        padding: 1.25rem;
    }

    /* Search results background */
    #search-results {
        background-color: #ffffff !important;
    }

        #search-results .result:hover {
            background-color: #f1f3f5 !important;
        }

    /* Chip buttons */
    .chip {
        background-color: #f8f9fa !important;
    }

        .chip:hover {
            background-color: #e9ecef !important;
        }

    /* Buttons */
    .btn {
        background-color: #f8f9fa !important;
    }

        .btn:hover {
            background-color: #e9ecef !important;
        }

    /* Date inputs */
    input[type="date"] {
        background-color: #ffffff !important;
        border: 1px solid #e9ecef;
    }

    /* Search container styling */
    .search {
        position: relative;
        width: 300px;
        margin-top: 4px;
        margin-bottom: 4px;
    }

        .search .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            z-index: 10;
            pointer-events: none;
            font-size: 0.9rem;
        }

        .search input {
            background-color: #ffffff !important;
            width: 100%;
            padding: 0.5rem 1rem 0.5rem 2.2rem !important;
            border-radius: 32px;
            font-size: 0.9rem;
            height: 38px;
        }

    /* Head section */
    .head {
        background-color: transparent !important;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

        .head .title {
            display: flex;
            align-items: center;
            font-size: 1.5rem;
            font-weight: 500;
            line-height: 1.2;
        }

            .head .title .dot {
                display: inline-block;
                width: 8px;
                height: 8px;
                background-color: #00b3ff;
                border-radius: 50%;
                margin-right: 12px;
            }

        .head .quick {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

    .quick .chip {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        height: 38px;
    }

    .head-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    canvas {
        background-color: transparent !important;
    }

    .bg-primary, .bg-secondary, .bg-success, .bg-info, .bg-warning, .bg-danger {
        background-image: none !important;
    }

    body {
        background-color: #ffffff;
    }

    /* REMOVE UNDERLINES ON TEXT HOVER */
    a,
    a:hover,
    a:focus,
    a:active,
    .kpi a,
    .kpi a:hover,
    .kpi a:focus,
    .kpi a:active,
    .chip,
    .chip:hover,
    .chip:focus,
    .chip:active,
    .btn,
    .btn:hover,
    .btn:focus,
    .btn:active,
    .quick a,
    .quick a:hover,
    .quick a:focus,
    .quick a:active,
    #search-results .result,
    #search-results .result:hover,
    #search-results .result:focus,
    #search-results .result:active,
    .card a,
    .card a:hover,
    .card a:focus,
    .card a:active {
        text-decoration: none !important;
        border-bottom: none !important;
        outline: none !important;
    }

        .kpi a i {
            display: inline-block;
            transition: transform 0.2s ease;
        }

        .kpi a:hover i {
            transform: translateX(4px);
        }

    .text-decoration-none {
        text-decoration: none !important;
    }

    #search-results .result span,
    #search-results .result b {
        text-decoration: none !important;
        border-bottom: none !important;
    }

    @@media (max-width: 768px) {
        .head {
            flex-direction: column;
            align-items: flex-start;
        }

        .head-right {
            width: 100%;
            flex-direction: column;
            align-items: stretch;
        }

        .search {
            width: 100%;
            margin-top: 0;
        }
    }

    #search-results {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1000;
        max-height: 400px;
        overflow-y: auto;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        margin-top: 4px;
    }
</style>

<div class="wrap">

    <!-- HEADER -->
    <div class="head">
        <div class="title">Dashboard</div>

        <div class="head-right">
            <div class="search" role="search">
                <i class="fas fa-search search-icon" aria-hidden="true"></i>
                <label class="sr-only" for="q">Search</label>
                <input id="q" placeholder="Search anything..." autocomplete="off"
                       aria-autocomplete="list" aria-controls="search-results" aria-expanded="false">
                <div id="search-results" role="listbox" tabindex="-1"></div>
            </div>

            <div class="quick">
                <a class="chip" href="@Url.Action("Create", "Catalogs")"><i class="fas fa-plus"></i> Add Catalog</a>
                <a class="chip" href="@Url.Action("Create", "Members")"><i class="fas fa-user-plus"></i> Add Member</a>
                <a class="chip" href="@Url.Action("Create", "BookBorrows")"><i class="fas fa-file-signature"></i> New Borrow</a>
            </div>
        </div>
    </div>

    <!-- KPI GRID -->
    <div class="row g-3 g-md-4 mb-1">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-layer-group"></i></span>
                <div class="label">Total Catalog</div>
                <div class="val">@Model.TotalCatalog</div>
                <a href="@Url.Action("Index", "Catalogs")">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-users"></i></span>
                <div class="label">Total Members</div>
                <div class="val">@Model.TotalMembers</div>
                <a href="@Url.Action("Index", "Members")">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-file-signature"></i></span>
                <div class="label">Total Book Borrows</div>
                <div class="val">@Model.TotalBorrows</div>
                <a href="@Url.Action("Index", "BookBorrows")">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-undo"></i></span>
                <div class="label">Total Returned</div>
                <div class="val">@Model.ReturnedBorrows</div>
                <a href="@Url.Action("Index", "BookBorrows")#returned">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-times-circle"></i></span>
                <div class="label">Total Not Return</div>
                <div class="val">@Model.NotReturn</div>
                <a href="@Url.Action("Index", "BookBorrows")#notreturned">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-exclamation-triangle"></i></span>
                <div class="label">Overdue Book Borrows</div>
                <div class="val">@Model.OverdueBorrows</div>
                <a href="@Url.Action("Index", "BookBorrows")#due">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-cart-shopping"></i></span>
                <div class="label">Total Purchases</div>
                <div class="val">@Model.Purchases</div>
                <a href="@Url.Action("Index", "Purchases")">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="kpi">
                <span class="ico"><i class="fas fa-sliders-h"></i></span>
                <div class="label">Total Adjustments</div>
                <div class="val">@Model.Adjustments</div>
                <a href="@Url.Action("Index", "Adjustments")">View <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <!-- CHART -->
    <div class="card mt-3" style="border-radius: var(--radius-lg);">
        <div class="card-head">
            <div class="card-title">
                <i class="fas fa-chart-line"></i>
                Monthly Book Borrow Statistics
            </div>
            <form id="excelForm" class="opts" method="get" action="@Url.Action("DownloadExcel", "Dashboard")">
                <label class="sr-only" for="startDate">Start</label>
                <input id="startDate" name="start" type="date" required>
                <label class="sr-only" for="endDate">End</label>
                <input id="endDate" name="end" type="date" required>

                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <label class="me-2"><input type="checkbox" name="totals" value="TotalBorrows" checked> Book Borrows</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="ReturnedBorrows" checked> Returned</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="NotReturn" checked> Not Return</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="OverdueBorrows"> Overdue</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="Purchases"> Purchases</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="Adjustments"> Adjustments</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="TotalBooks"> Books</label>
                    <label class="me-2"><input type="checkbox" name="totals" value="TotalMembers"> Members</label>
                </div>

                <button type="submit" class="btn btn-sm px-3">
                    <i class="fas fa-download me-1"></i> Download Excel
                </button>
            </form>
        </div>
        <div class="card-body-glass">
            <canvas id="monthlyChart" height="76" aria-label="Monthly book borrow chart" role="img"></canvas>
        </div>
    </div>

</div>

@* jQuery is already loaded in _Layout.cshtml — do NOT re-add it here *@
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // ---- Chart ----
    const ctx = document.getElementById('monthlyChart').getContext('2d');
    const labels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.MonthlyLabels));
    const series = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.MonthlyBorrowStats));

    new Chart(ctx, {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Book Borrows',
                data: series,
                fill: true,
                backgroundColor: 'rgba(0, 179, 255, 0.1)',
                borderColor: '#00b3ff',
                borderWidth: 2,
                tension: 0.35,
                pointBackgroundColor: '#ffffff',
                pointBorderColor: '#00007a',
                pointRadius: 4,
                pointHoverRadius: 5,
                segment: {
                    borderColor: s => s.p0.parsed.y > s.p1.parsed.y ? '#f97373' : '#22c55e'
                }
            }]
        },
        options: {
            interaction: { intersect: false, mode: 'index' },
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0, color: '#6c757d' },
                    grid: { color: 'rgba(108, 117, 125, 0.2)' }
                },
                x: {
                    ticks: { color: '#6c757d' },
                    grid: { display: false }
                }
            }
        }
    });

    // ---- Universal Search ----
    (function () {
        const $box = $('#q');
        const $res = $('#search-results');
        let activeIndex = -1;

        function render(items) {
            $res.empty();
            if (!items.length) {
                $res.hide();
                $box.attr('aria-expanded', 'false');
                return;
            }
            items.forEach((r, i) => {
                const icon = r.type === 'Book'
                    ? 'fa-book'
                    : r.type === 'Member'
                        ? 'fa-user'
                        : 'fa-file-signature';

                const label = r.type === 'Book'
                    ? `<b>${r.title}</b>${r.author ? ' — ' + r.author : ''}${r.isbn ? ' — ' + r.isbn : ''}${r.barcode ? ' — ' + r.barcode : ''}`
                    : r.type === 'Member'
                        ? `<b>${r.fullName || ''}</b>${r.phone ? ' — ' + r.phone : ''}${r.email ? ' — ' + r.email : ''}`
                        : `Book Borrow #${r.loanId} — <b>${r.member || ''}</b> (${(r.loanDate || '').toString().substring(0, 10)} → ${(r.dueDate || '').toString().substring(0, 10)})`;

                $res.append(
                    `<div class="result" role="option" id="r-${i}" tabindex="-1" aria-selected="false"
                           data-type="${r.type}" data-id="${r.loanId || r.bookId || r.memberId}">
                        <i class="fas ${icon}"></i>
                        <span>${label}</span>
                     </div>`
                );
            });
            $res.show();
            $box.attr('aria-expanded', 'true');
        }

        function move(sel) {
            const items = $res.find('.result');
            if (!items.length) return;
            items.attr('aria-selected', 'false');
            activeIndex = (sel + items.length) % items.length;
            const $active = $(items[activeIndex]);
            $active.attr('aria-selected', 'true');
            $active[0].scrollIntoView({ block: 'nearest' });
        }

        $box.on('input', function () {
            const q = $(this).val().trim();
            if (q.length < 2) {
                $res.hide();
                $(this).attr('aria-expanded', 'false');
                return;
            }
            $.getJSON('@Url.Action("Search", "Dashboard")', { q }, function (data) {
                render(data.results || []);
                activeIndex = -1;
            });
        });

        $box.on('keydown', function (e) {
            if (!$res.is(':visible')) return;
            if (e.key === 'ArrowDown') { e.preventDefault(); move(activeIndex + 1); }
            if (e.key === 'ArrowUp')   { e.preventDefault(); move(activeIndex - 1); }
            if (e.key === 'Enter' && activeIndex >= 0) {
                e.preventDefault();
                $('#r-' + activeIndex).trigger('mousedown');
            }
            if (e.key === 'Escape') {
                $res.hide();
                $box.attr('aria-expanded', 'false');
            }
        });

        $res.on('mousedown', '.result', function () {
            const type = $(this).data('type');
            if (type === 'Book')       { window.location = '@Url.Action("Index", "Books")'; }
            if (type === 'Member')     { window.location = '@Url.Action("Index", "Members")'; }
            if (type === 'BookBorrow') { window.location = '@Url.Action("Index", "BookBorrows")'; }
            $res.hide();
            $box.attr('aria-expanded', 'false');
        });

        $box.on('blur', function () {
            setTimeout(() => {
                $res.hide();
                $box.attr('aria-expanded', 'false');
            }, 160);
        });
    })();
</script>
