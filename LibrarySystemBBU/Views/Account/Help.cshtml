        </div>

        <!-- ══════════════════════════════════════════════════ -->
        <!-- ADJUSTMENTS -->
        <!-- ══════════════════════════════════════════════════ -->
        <div class="help-section" id="sec-adjustments">
            <div class="help-section-header">
                <div class="help-section-icon"><i class="bi bi-sliders"></i></div>
                <div>
                    <div class="help-section-title">Adjustments</div>
                    <div class="help-section-desc">Manual stock corrections for lost, damaged, or miscounted books.</div>
                </div>
            </div>

            <div class="help-card">
                <div class="help-card-head">
                    <div class="help-card-head-left">
                        <div class="help-card-num">1</div>
                        <div class="help-card-label">When to Use Adjustments</div>
                    </div>
                    <i class="bi bi-chevron-down help-card-chevron"></i>
                </div>
                <div class="help-card-body">
                    <p>Use adjustments when the physical stock doesn't match the system — for example, a book is confirmed lost, damaged beyond repair, or found after being marked missing. Adjustments record the reason and the quantity change, updating catalog stock counts immediately.</p>
                    <div class="help-warn"><i class="bi bi-exclamation-triangle-fill"></i> Adjustments cannot be undone. Double-check quantities and catalog selection before saving.</div>
                </div>
            </div>
        </div>

