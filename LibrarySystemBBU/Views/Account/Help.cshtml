                    <i class="bi bi-chevron-down help-card-chevron"></i>
                </div>
                <div class="help-card-body">
                    <table class="help-table">
                        <thead><tr><th>Role</th><th>Access Level</th></tr></thead>
                        <tbody>
                            <tr><td><strong>Admin</strong></td><td>Full access to all modules including Users and Roles</td></tr>
                            <tr><td><strong>Librarian</strong></td><td>Catalogs, Members, Borrows, Returns, Logs, Purchases</td></tr>
