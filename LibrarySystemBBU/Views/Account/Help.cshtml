                    <div class="help-tip"><i class="bi bi-lightbulb-fill"></i> Use a strong password with at least 8 characters including numbers and symbols.</div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    (function () {
        // ── Accordion ──────────────────────────────────────────
        document.querySelectorAll('.help-card-head').forEach(function (head) {
            head.addEventListener('click', function () {
                var card = this.closest('.help-card');
                card.classList.toggle('open');
            });
        });

        // ── Left nav scroll spy + click ───────────────────────
        var navLinks    = document.querySelectorAll('.help-nav-link[data-target]');
        var contentPane = document.querySelector('.help-content');

        navLinks.forEach(function (link) {
            link.addEventListener('click', function (e) {
                e.preventDefault();
                var target = document.getElementById(this.dataset.target);
                if (!target) return;
                // offsetTop relative to contentPane
                var top = target.getBoundingClientRect().top
                        - contentPane.getBoundingClientRect().top
                        + contentPane.scrollTop - 20;
                contentPane.scrollTo({ top: top, behavior: 'smooth' });
                setActive(this);
            });
        });

        function setActive(el) {
            navLinks.forEach(function (l) { l.classList.remove('active'); });
            el.classList.add('active');
        }

        // Scroll spy — watch content pane scroll, not window
        var sections = Array.from(document.querySelectorAll('.help-section[id]'));

        contentPane.addEventListener('scroll', function () {
            var paneTop = contentPane.getBoundingClientRect().top;
            var current = null;

            sections.forEach(function (s) {
                var sTop = s.getBoundingClientRect().top - paneTop;
                if (sTop <= 80) current = s;
            });

            if (current) {
                var link = document.querySelector('.help-nav-link[data-target="' + current.id + '"]');
                if (link) setActive(link);
            }
        });

        // ── Search ────────────────────────────────────────────
        var searchInput  = document.getElementById('helpSearch');
        var noResults    = document.getElementById('helpNoResults');
        var allSections  = document.querySelectorAll('.help-section');
        var allCards     = document.querySelectorAll('.help-card');

        searchInput.addEventListener('input', function () {
            var q = this.value.trim().toLowerCase();

            if (!q) {
                allSections.forEach(function (s) { s.style.display = ''; });
                allCards.forEach(function (c) { c.style.display = ''; });
                noResults.style.display = 'none';
                return;
            }

            var anyVisible = false;

            allSections.forEach(function (section) {
                var sectionText = section.innerText.toLowerCase();
                var sectionMatch = sectionText.includes(q);
                var anyCardMatch = false;

                section.querySelectorAll('.help-card').forEach(function (card) {
                    var cardText = card.innerText.toLowerCase();
                    var match = cardText.includes(q);
                    card.style.display = match ? '' : 'none';
                    if (match) {
                        anyCardMatch = true;
                        card.classList.add('open'); // auto-expand matched cards
                    }
                });

                var show = sectionMatch || anyCardMatch;
                section.style.display = show ? '' : 'none';
                if (show) anyVisible = true;
            });

            noResults.style.display = anyVisible ? 'none' : 'block';
        });
    })();
</script>
