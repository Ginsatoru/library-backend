@using Microsoft.AspNetCore.Http
@model LibrarySystemBBU.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<style>
    .prf-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
        padding: 24px 0;
    }

    /* ---- page title ---- */
    .prf-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: .2rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .prf-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .prf-subtitle {
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.5rem;
    }

    /* ---- layout grid ---- */
    .prf-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
        align-items: start;
    }

    @@media (min-width: 1024px) {
        .prf-grid {
            grid-template-columns: 300px 1fr;
            gap: 24px;
        }
    }

    /* ---- cards ---- */
    .prf-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .prf-card-header {
        padding: 12px 16px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
    }

    .prf-card-header-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .95rem;
    }

        .prf-card-header-title::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .prf-card-body {
        padding: 1.25rem;
    }

    /* ---- buttons ---- */
    .prf-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none !important;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .prf-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none !important;
        }

    .prf-btn-primary {
        background: #000080;
        color: #fff !important;
        border-color: #000080;
    }

        .prf-btn-primary:hover {
            background: #00006a;
            border-color: #00006a;
            color: #fff !important;
        }

    /* ---- photo section ---- */
    .prf-photo-wrap {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid #e5e7eb;
    }

    .prf-photo-box {
        position: relative;
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid #e5e7eb;
        background: #f3f4f6;
        flex-shrink: 0;
    }

        .prf-photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .prf-photo-edit-btn {
        position: absolute;
        right: 4px;
        bottom: 4px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: #fff;
        border: 1px solid #e5e7eb;
        box-shadow: 0 2px 8px rgba(0,0,0,.12);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        color: #374151;
        font-size: .85rem;
        transition: background .15s;
    }

        .prf-photo-edit-btn:hover {
            background: #f3f4f6;
        }

    .prf-name {
        font-size: 1.2rem;
        font-weight: 700;
        color: #111827;
        text-align: center;
        margin: 0;
    }

    .prf-role {
        font-size: .82rem;
        color: #6b7280;
        text-align: center;
    }

    .prf-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .75rem;
        font-weight: 600;
    }

    .prf-status-active {
        background: #dcfce7;
        color: #166534;
    }

    .prf-status-inactive {
        background: #fee2e2;
        color: #991b1b;
    }

    /* ---- stats row ---- */
    .prf-stats {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
        padding: 12px 16px;
        border-bottom: 1px solid #e5e7eb;
    }

    .prf-stat {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: .82rem;
        color: #374151;
        font-weight: 500;
    }

        .prf-stat i {
            color: #9ca3af;
        }

    .prf-since {
        padding: 10px 16px;
        font-size: .78rem;
        color: #9ca3af;
    }

    /* ---- readonly fields ---- */
    .prf-field {
        margin-bottom: 12px;
    }

    .prf-field-label {
        display: block;
        font-size: .73rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 5px;
    }

    .prf-readonly {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        background: #f9fafb;
        border: 1px solid #f3f4f6;
        border-radius: 8px;
        font-size: .85rem;
        color: #111827;
        min-height: 40px;
    }

        .prf-readonly i {
            color: #9ca3af;
            width: 16px;
            text-align: center;
            flex-shrink: 0;
        }

        .prf-readonly .muted {
            color: #6b7280;
        }

    .prf-readonly-chip {
        margin-left: auto;
        font-size: .72rem;
        padding: 3px 8px;
        border-radius: 20px;
        background: #f3f4f6;
        color: #9ca3af;
        border: 1px solid #e5e7eb;
        font-weight: 600;
        white-space: nowrap;
    }

    /* ---- info boxes ---- */
    .prf-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: 4px;
    }

    .prf-info-box {
        padding: 10px 12px;
        border-radius: 8px;
        background: #f0f4ff;
        border: 1px solid #dde5ff;
    }

        .prf-info-box .k {
            font-size: .73rem;
            color: #6b7280;
            margin-bottom: 2px;
        }

        .prf-info-box .v {
            font-weight: 700;
            color: #111827;
            font-size: .88rem;
        }

            .prf-info-box .v.ok {
                color: #166534;
            }

            .prf-info-box .v.bad {
                color: #991b1b;
            }

    .prf-divider {
        border-top: 1px solid #f3f4f6;
        margin: 14px 0;
    }

    .prf-section-label {
        font-size: .88rem;
        font-weight: 700;
        color: #111827;
        margin: 0 0 12px 0;
    }

    /* ---- modal ---- */
    .prf-modal-content {
        border: 0 !important;
        border-radius: 14px !important;
        overflow: hidden;
        font-family: 'Inter', sans-serif;
    }

    .prf-modal-header {
        padding: 14px 18px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb !important;
    }

    .prf-modal-title {
        font-weight: 700;
        color: #111827;
        font-size: 1rem;
        margin: 0;
    }

    .prf-modal-body {
        padding: 1.25rem;
        background: #fff;
    }

    .prf-modal-footer {
        padding: 12px 18px;
        background: #fff;
        border-top: 1px solid #e5e7eb !important;
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    /* ---- form inputs ---- */
    .prf-input,
    .prf-textarea {
        width: 100%;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: .85rem;
        color: #111827;
        outline: none;
        font-family: 'Inter', sans-serif;
        transition: border-color .15s;
    }

        .prf-input:focus,
        .prf-textarea:focus {
            background: #fff;
            border-color: #000080;
        }

        .prf-input[readonly] {
            opacity: .6;
            cursor: not-allowed;
        }

    .prf-form-label {
        display: block;
        font-size: .73rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .05em;
        margin-bottom: 5px;
    }

    .prf-form-hint {
        font-size: .75rem;
        color: #9ca3af;
        margin-top: 4px;
    }

    .prf-form-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
        margin-bottom: 12px;
    }

    @@media (min-width: 640px) {
        .prf-form-row.two {
            grid-template-columns: 1fr 1fr;
        }

        .prf-form-row.three {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }

    .prf-modal-mini-avatar {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        padding-bottom: 14px;
        border-bottom: 1px solid #f3f4f6;
    }

        .prf-modal-mini-avatar img {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #e5e7eb;
        }

        .prf-modal-mini-avatar .name {
            font-weight: 700;
            color: #111827;
            font-size: .95rem;
        }

        .prf-modal-mini-avatar .user {
            font-size: .82rem;
            color: #6b7280;
        }

    .text-danger {
        font-size: .8rem;
    }

    .swal2-popup {
        border-radius: 14px !important;
        font-family: 'Inter', sans-serif !important;
    }
</style>

<div class="prf-page">

    <div class="prf-page-title">My Profile</div>
    <div class="prf-subtitle">Manage your account information and preferences</div>

    <div class="prf-grid">

        <!-- LEFT: avatar card -->
        <div>
            <div class="prf-card">
                <div class="prf-photo-wrap">
                    @{
                        var fallbackAvatar = "https://ui-avatars.com/api/?name="
                        + (Model.FirstName + "+" + Model.LastName)
                        + "&background=000080&color=fff&size=256";
                        var avatarSrc = string.IsNullOrEmpty(Model.ProfilePicturePath)
                        ? fallbackAvatar
                        : Url.Content(Model.ProfilePicturePath);
                    }
                    <div class="prf-photo-box">
                        <img src="@avatarSrc" alt="Profile" />
                        <button type="button" class="prf-photo-edit-btn" id="btnOpenEditFromPhoto" title="Edit profile">
                            <i class="bi bi-camera"></i>
                        </button>
                    </div>

                    <div>
                        <div class="prf-name">@Model.FirstName @Model.LastName</div>
                        <div class="prf-role">@Model.RoleName</div>
                    </div>

                    <span class="prf-status-badge @(Model.IsActive ? "prf-status-active" : "prf-status-inactive")">
                        <i class="bi @(Model.IsActive ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                        @(Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                <div class="prf-stats">
                    <div class="prf-stat">
                        <i class="bi bi-person-badge"></i>
                        <span>@(string.IsNullOrWhiteSpace(Model.UserName) ? "-" : Model.UserName)</span>
                    </div>
                    <div class="prf-stat">
                        <i class="bi bi-shield"></i>
                        <span>@(string.IsNullOrWhiteSpace(Model.RoleName) ? "-" : Model.RoleName)</span>
                    </div>
                </div>

                @if (Model.Created.HasValue)
                {
                    <div class="prf-since">
                        <i class="bi bi-calendar3"></i> Member since @Model.Created.Value.ToString("MMMM yyyy")
                    </div>
                }
            </div>
        </div>

        <!-- RIGHT: info card -->
        <div>
            <div class="prf-card">
                <div class="prf-card-header">
                    <div class="prf-card-header-title">Personal Information</div>
                    <button type="button" class="prf-btn prf-btn-primary" id="btnOpenEdit">
                        <i class="bi bi-pencil-square"></i> Edit
                    </button>
                </div>

                <div class="prf-card-body">

                    <div class="prf-field">
                        <label class="prf-field-label">Full Name</label>
                        <div class="prf-readonly">
                            <i class="bi bi-person"></i>
                            <span>@Model.FirstName @Model.LastName</span>
                        </div>
                    </div>

                    <div class="prf-field">
                        <label class="prf-field-label">Email Address</label>
                        <div class="prf-readonly">
                            <i class="bi bi-envelope"></i>
                            <span class="@(User.IsInRole("Admin") || User.IsInRole("Librarian") ? "" : "muted")">@Model.Email</span>
                            @if (!User.IsInRole("Admin") && !User.IsInRole("Librarian"))
                            {
                                <span class="prf-readonly-chip">Cannot be changed</span>
                            }
                        </div>
                    </div>

                    <div class="prf-field">
                        <label class="prf-field-label">Phone</label>
                        <div class="prf-readonly">
                            <i class="bi bi-telephone"></i>
                            <span>@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</span>
                        </div>
                    </div>

                    <div class="prf-field">
                        <label class="prf-field-label">Address</label>
                        <div class="prf-readonly">
                            <i class="bi bi-geo-alt"></i>
                            <span>@(string.IsNullOrWhiteSpace(Model.Address) ? "-" : Model.Address)</span>
                        </div>
                    </div>

                    <div class="prf-field">
                        <label class="prf-field-label">Gender</label>
                        <div class="prf-readonly">
                            <i class="bi bi-gender-ambiguous"></i>
                            <span>@(string.IsNullOrWhiteSpace(Model.Gender) ? "-" : Model.Gender)</span>
                        </div>
                    </div>

                    <div class="prf-divider"></div>

                    <div class="prf-section-label">Account Information</div>

                    <div class="prf-field">
                        <label class="prf-field-label">Role</label>
                        <div class="prf-readonly">
                            <i class="bi bi-shield"></i>
                            <span class="muted">@Model.RoleName</span>
                            <span class="prf-readonly-chip">Read only</span>
                        </div>
                    </div>

                    <div class="prf-field">
                        <label class="prf-field-label">Notes</label>
                        <div class="prf-readonly" style="align-items:flex-start;">
                            <i class="bi bi-sticky" style="margin-top:2px;"></i>
                            <span class="muted">@(string.IsNullOrWhiteSpace(Model.Notes) ? "-" : Model.Notes)</span>
                        </div>
                    </div>

                    <div class="prf-info-grid">
                        <div class="prf-info-box">
                            <div class="k">Member Since</div>
                            <div class="v">@(Model.Created.HasValue? Model.Created.Value.ToString("MMMM dd, yyyy") : "-")</div>
                        </div>
                        <div class="prf-info-box">
                            <div class="k">Account Status</div>
                            <div class="v @(Model.IsActive ? "ok" : "bad")">@(Model.IsActive ? "Active" : "Inactive")</div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editProfileModal" tabindex="-1" aria-labelledby="editProfileModalLabel" aria-hidden="true" style="z-index:10000;">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content prf-modal-content">

            <div class="prf-modal-header d-flex align-items-center justify-content-between">
                <h5 class="prf-modal-title" id="editProfileModalLabel">
                    <i class="bi bi-pencil-square me-2" style="color:#000080;"></i>Edit Profile
                </h5>
                <button type="button" class="prf-btn" id="btnCloseEdit" aria-label="Close">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="prf-modal-body">
                @{
                    var modalAvatarSrc = string.IsNullOrEmpty(Model.ProfilePicturePath)
                    ? "https://ui-avatars.com/api/?name=" + (Model.FirstName + "+" + Model.LastName) + "&background=000080&color=fff&size=256"
                    : Url.Content(Model.ProfilePicturePath);
                }

                <div class="prf-modal-mini-avatar">
                    <img src="@modalAvatarSrc" alt="Profile picture" />
                    <div>
                        <div class="name">@Model.FirstName @Model.LastName</div>
                        <div class="user">@Model.UserName</div>
                    </div>
                </div>

                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" id="editProfileForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-2"></div>

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProfilePicturePath" />
                    <input type="hidden" asp-for="Created" />
                    <input type="hidden" asp-for="Modified" />
                    <input type="hidden" asp-for="IsActive" />
                    <input type="hidden" asp-for="UserName" />
                    <input type="hidden" asp-for="CurrentPassword" id="CurrentPasswordHidden" />

                    <div class="prf-form-row two">
                        <div>
                            <label class="prf-form-label">New Profile Picture</label>
                            <input asp-for="Picture" class="prf-input" type="file" />
                            <span asp-validation-for="Picture" class="text-danger"></span>
                            <div class="prf-form-hint">Leave empty to keep current picture.</div>
                        </div>
                        <div>
                            <label asp-for="Email" class="prf-form-label"></label>
                            @if (User.IsInRole("Admin") || User.IsInRole("Librarian"))
                            {
                                <input asp-for="Email" class="prf-input" />
                                <div class="prf-form-hint">You can update the email address.</div>
                            }
                            else
                            {
                                <input asp-for="Email" class="prf-input" readonly />
                                <div class="prf-form-hint">Email cannot be changed.</div>
                            }
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="prf-form-row two">
                        <div>
                            <label asp-for="FirstName" class="prf-form-label"></label>
                            <input asp-for="FirstName" class="prf-input" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" class="prf-form-label"></label>
                            <input asp-for="LastName" class="prf-input" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="prf-form-row two">
                        <div>
                            <label asp-for="Phone" class="prf-form-label"></label>
                            <input asp-for="Phone" class="prf-input" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Address" class="prf-form-label"></label>
                            <input asp-for="Address" class="prf-input" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="prf-form-row three">
                        <div>
                            <label asp-for="RoleName" class="prf-form-label"></label>
                            <input asp-for="RoleName" class="prf-input" readonly />
                            <span asp-validation-for="RoleName" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Gender" class="prf-form-label"></label>
                            <input asp-for="Gender" class="prf-input" />
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="DateOfBirth" class="prf-form-label"></label>
                            <input asp-for="DateOfBirth" class="prf-input" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="prf-form-row" style="margin-bottom:12px;">
                        <div>
                            <label asp-for="Notes" class="prf-form-label"></label>
                            <textarea asp-for="Notes" class="prf-textarea" rows="2"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="prf-divider"></div>

                    <div class="prf-section-label">Change Password</div>

                    <div class="prf-form-row two">
                        <div>
                            <label class="prf-form-label">New Password (optional)</label>
                            <input asp-for="NewPassword" class="prf-input" type="password" autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <div class="prf-form-hint">Leave blank to keep current password.</div>
                        </div>
                        <div>
                            <label asp-for="ConfirmNewPassword" class="prf-form-label"></label>
                            <input asp-for="ConfirmNewPassword" class="prf-input" type="password" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                        </div>
                    </div>
                </form>
            </div>

            <div class="prf-modal-footer">
                <button type="button" class="prf-btn" id="btnCancelEdit">
                    <i class="bi bi-x-lg"></i> Cancel
                </button>
                <button type="button" class="prf-btn prf-btn-primary" id="btnSaveProfileModal">
                    <i class="bi bi-floppy"></i> Save changes
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var editBtn        = document.getElementById('btnOpenEdit');
            var editFromPhoto  = document.getElementById('btnOpenEditFromPhoto');
            var form           = document.getElementById('editProfileForm');
            var saveBtn        = document.getElementById('btnSaveProfileModal');
            var hiddenPwd      = document.getElementById('CurrentPasswordHidden');
            var modalElement   = document.getElementById('editProfileModal');
            var cancelBtn      = document.getElementById('btnCancelEdit');
            var closeBtn       = document.getElementById('btnCloseEdit');

            function showModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    bootstrap.Modal.getOrCreateInstance(modalElement).show();
                } else if (window.$ && typeof $(modalElement).modal === 'function') {
                    $(modalElement).modal('show');
                }
            }

            function hideModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    var inst = bootstrap.Modal.getInstance(modalElement);
                    if (inst) inst.hide();
                } else if (window.$ && typeof $(modalElement).modal === 'function') {
                    $(modalElement).modal('hide');
                }
            }

            if (editBtn)       editBtn.addEventListener('click', showModal);
            if (editFromPhoto) editFromPhoto.addEventListener('click', showModal);
            if (cancelBtn)     cancelBtn.addEventListener('click', hideModal);
            if (closeBtn)      closeBtn.addEventListener('click', hideModal);

            if (form && saveBtn && hiddenPwd) {
                saveBtn.addEventListener('click', async function (e) {
                    e.preventDefault();

                    if (typeof $ !== 'undefined' && typeof $(form).valid === 'function') {
                        if (!$(form).valid()) return;
                    }

                    hideModal();

                    var result = await Swal.fire({
                        title: 'Confirm changes',
                        text: 'Enter your current password to save profile changes.',
                        input: 'password',
                        inputLabel: 'Current password',
                        inputPlaceholder: 'Enter current password',
                        inputAttributes: { autocapitalize: 'off', autocomplete: 'current-password' },
                        showCancelButton: true,
                        confirmButtonText: 'Confirm & Save',
                        cancelButtonText: 'Cancel',
                        reverseButtons: true,
                        allowOutsideClick: false,
                        customClass: {
                            popup: 'swal2-popup',
                            confirmButton: 'prf-btn prf-btn-primary',
                            cancelButton: 'prf-btn'
                        },
                        buttonsStyling: false,
                        preConfirm: function (value) {
                            if (!value) Swal.showValidationMessage('Current password is required.');
                            return value;
                        }
                    });

                    if (!result.isConfirmed || !result.value) {
                        showModal();
                        return;
                    }

                    hiddenPwd.value = result.value;
                    form.submit();
                });
            }

            var successMsg = '@(TempData["ProfileSuccess"] ?? "")';
            var errorMsg   = '@(TempData["ProfileError"] ?? "")';
            var openEdit   = '@(TempData["OpenEditModal"] ?? "")';

            if (successMsg) {
                Swal.fire({ icon: 'success', title: 'Profile updated', text: successMsg,
                    customClass: { popup: 'swal2-popup', confirmButton: 'prf-btn prf-btn-primary' },
                    buttonsStyling: false });
            }

            if (errorMsg) {
                Swal.fire({ icon: 'error', title: 'Update failed', text: errorMsg,
                    customClass: { popup: 'swal2-popup', confirmButton: 'prf-btn prf-btn-primary' },
                    buttonsStyling: false }).then(function () { showModal(); });
            } else if (openEdit) {
                showModal();
            }
        });
    </script>
}
