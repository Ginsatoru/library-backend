@using Microsoft.AspNetCore.Http
@model LibrarySystemBBU.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

<style>
    :root {
        --navy: #000080;
        --bg: transparent; /* removed wrapper bg */
        --card: #ffffff;
        --border: #e5e7eb;
        --muted: #6b7280;
        --text: #111827;
        --shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
    }

    /* Page */
    .profile-wrap {
        min-height: calc(100vh - 120px);
        background: var(--bg);
        padding: 32px 16px;
    }

    .profile-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .profile-header {
        margin-bottom: 20px;
    }

        .profile-header h1 {
            font-size: clamp(1.8rem, 3vw, 2.4rem);
            font-weight: 800;
            color: var(--text);
            margin: 0 0 6px 0;
            letter-spacing: -0.02em;
        }

        .profile-header p {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
        }

    /* Layout */
    .profile-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 18px;
        align-items: start;
    }

    @@media (min-width: 1024px) {
        .profile-grid {
            grid-template-columns: 320px 1fr;
            gap: 24px;
        }
    }

    /* Cards */
    .cardx {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 2rem;
        box-shadow: var(--shadow);
    }

    .cardx-body {
        padding: 18px;
    }

    .cardx-title-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 14px;
    }

    .cardx-title {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
        margin: 0;
    }

    .divider {
        border-top: 1px solid #f3f4f6;
        margin: 16px 0;
    }

    /* Buttons */
    .btnx {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border: 0;
        cursor: pointer;
        text-decoration: none;
        user-select: none;
        transition: transform .12s ease, background .12s ease, box-shadow .12s ease, opacity .12s ease;
        font-weight: 600;
        white-space: nowrap;
    }

        .btnx:disabled {
            opacity: .6;
            cursor: not-allowed;
        }

    .btnx-primary {
        background: var(--navy);
        color: #fff;
        padding: 10px 14px;
        border-radius: 999px;
    }

        .btnx-primary:hover {
            background: rgba(0, 0, 128, 0.92);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 16px 40px rgba(0, 0, 128, 0.20);
        }

    .btnx-ghost {
        background: #f3f4f6;
        color: #374151;
        border: 1px solid #e5e7eb;
        padding: 10px 14px;
        border-radius: 999px;
    }

        .btnx-ghost:hover {
            background: #e5e7eb;
            color: #111827;
            transform: translateY(-1px);
        }

    .btnx-soft {
        background: rgba(59, 130, 246, 0.12);
        color: var(--navy);
        border: 1px solid rgba(59, 130, 246, 0.18);
        padding: 12px 14px;
        border-radius: 14px;
        width: 100%;
        justify-content: flex-start;
    }

        .btnx-soft:hover {
            background: rgba(59, 130, 246, 0.18);
            transform: translateY(-1px);
        }

    /* Left profile card */
    .photo-shell {
        padding: 6px;
    }

    .photo-box {
        position: relative;
        width: 100%;
        aspect-ratio: 1 / 1;
        background: #f3f4f6;
        border-radius: 1.5rem;
        overflow: hidden;
    }

        .photo-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .photo-fallback {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f1f5f9, #eff6ff);
        color: #cbd5e1;
        font-size: 56px;
    }

    .photo-action {
        position: absolute;
        right: 12px;
        bottom: 12px;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        background: rgba(255,255,255,0.92);
        border: 1px solid rgba(229, 231, 235, 0.9);
        box-shadow: 0 10px 25px rgba(15,23,42,0.12);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

        .photo-action:hover {
            background: #fff;
            transform: translateY(-1px);
        }

    .name-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

        .name-row h2 {
            margin: 0;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--text);
            line-height: 1.2;
        }

    .status-badge {
        width: 24px;
        height: 24px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .subtext {
        margin-top: 4px;
        color: var(--muted);
        font-size: 0.9rem;
    }

    .stats-row {
        display: flex;
        gap: 14px;
        align-items: center;
        flex-wrap: wrap;
    }

    .stat {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #4b5563;
        font-size: 0.9rem;
        font-weight: 600;
    }

        .stat i {
            color: #9ca3af;
        }

    .since {
        margin-top: 10px;
        color: #9ca3af;
        font-size: 0.78rem;
    }

    /* Right info blocks */
    .field {
        margin-bottom: 12px;
    }

        .field label {
            display: block;
            font-size: 0.78rem;
            font-weight: 700;
            color: #6b7280;
            margin-bottom: 6px;
            letter-spacing: .02em;
            text-transform: uppercase;
        }

    .readonly-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        background: #f9fafb;
        border: 1px solid #f3f4f6;
        border-radius: 14px;
        color: var(--text);
        min-height: 44px;
    }

        .readonly-row i {
            color: #9ca3af;
            width: 18px;
            text-align: center;
        }

        .readonly-row .muted {
            color: #6b7280;
        }

    .readonly-chip {
        margin-left: auto;
        font-size: 0.74rem;
        padding: 6px 10px;
        border-radius: 999px;
        background: #f3f4f6;
        color: #9ca3af;
        border: 1px solid #e5e7eb;
        font-weight: 700;
    }

    /* Info boxes */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    @@media (min-width: 640px) {
        .info-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    .info-box {
        padding: 12px 14px;
        border-radius: 14px;
        background: rgba(59, 130, 246, 0.08);
        border: 1px solid rgba(59, 130, 246, 0.12);
    }

        .info-box .k {
            font-size: 0.78rem;
            color: #6b7280;
            margin-bottom: 2px;
        }

        .info-box .v {
            font-weight: 800;
            color: #111827;
            font-size: 0.95rem;
        }

        .info-box.indigo {
            background: rgba(99, 102, 241, 0.08);
            border: 1px solid rgba(99, 102, 241, 0.12);
        }

    .ok {
        color: #16a34a;
        font-weight: 800;
    }

    .bad {
        color: #ef4444;
        font-weight: 800;
    }

    /* Bootstrap modal overrides */
    .modal-backdrop.show {
        opacity: .55;
    }

    .modal-content {
        border: 0;
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(15,23,42,0.35);
    }

    .modal-header {
        border-bottom: 1px solid #f3f4f6;
        padding: 16px 18px;
        background: #fff;
    }

    .modal-title {
        font-weight: 900;
        color: #111827;
        letter-spacing: -0.01em;
    }

    .modal-body {
        padding: 18px;
        background: #fff;
    }

    .modal-footer {
        border-top: 1px solid #f3f4f6;
        padding: 14px 18px;
        background: #fff;
    }

    .modal-close-btn {
        width: 40px;
        height: 40px;
        border-radius: 999px;
        border: 1px solid #e5e7eb;
        background: #f9fafb;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: transform .12s ease, background .12s ease;
    }

        .modal-close-btn:hover {
            background: #f3f4f6;
            transform: translateY(-1px);
        }

    /* Inputs */
    .inputx,
    .textareax {
        width: 100%;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 12px;
        color: #111827;
        outline: none;
        transition: box-shadow .12s ease, border-color .12s ease, background .12s ease;
    }

        .inputx:focus,
        .textareax:focus {
            background: #fff;
            border-color: rgba(0, 0, 128, 0.35);
            box-shadow: 0 0 0 3px rgba(0, 0, 128, 0.10);
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    @@media (min-width: 768px) {
        .form-row.two {
            grid-template-columns: 1fr 1fr;
        }

        .form-row.three {
            grid-template-columns: 1fr 1fr 1fr;
        }
    }

    .upload-hint {
        font-size: 0.78rem;
        color: #9ca3af;
        margin-top: 6px;
    }

    .text-danger {
        font-size: .82rem;
    }

    .swal2-popup {
        border-radius: 1.25rem !important;
    }
</style>

<div class="profile-wrap">
    <div class="profile-container">

        <div class="profile-header">
            <h1>My Profile</h1>
            <p>Manage your account information and preferences</p>
        </div>

        <div class="profile-grid">

            <!-- LEFT: Profile card -->
            <div>
                <div class="cardx">
                    <div class="photo-shell">
                        <div class="photo-box">
                            @{
                                var fallbackAvatar = "https://ui-avatars.com/api/?name="
                                + (Model.FirstName + "+" + Model.LastName)
                                + "&background=60a5fa&color=fff&size=256";

                                var avatarSrc = string.IsNullOrEmpty(Model.ProfilePicturePath)
                                ? fallbackAvatar
                                : Url.Content(Model.ProfilePicturePath);
                            }

                            @if (!string.IsNullOrEmpty(avatarSrc))
                            {
                                <img src="@avatarSrc" alt="Profile" />
                            }
                            else
                            {
                                <div class="photo-fallback">
                                    <i class="fa-regular fa-user"></i>
                                </div>
                            }

                            <!-- Camera opens SAME edit modal (one edit target) -->
                            <button type="button" class="photo-action" id="btnOpenEditFromPhoto" title="Edit profile">
                                <i class="fa-solid fa-camera"></i>
                            </button>
                        </div>
                    </div>

                    <div class="cardx-body">
                        <div class="name-row">
                            <h2>@Model.FirstName @Model.LastName</h2>

                            <span class="status-badge" title="@(Model.IsActive ? "Active" : "Inactive")">
                                @if (Model.IsActive)
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <polygon points="12.0,0.5 15.01,3.73 19.39,3.19 19.62,7.6 23.33,10.0 20.67,13.53 21.96,17.75 17.66,18.74 15.93,22.81 12.0,20.8 8.07,22.81 6.34,18.74 2.04,17.75 3.33,13.53 0.67,10.0 4.38,7.6 4.61,3.19 8.99,3.73" fill="#22c55e"></polygon>
                                        <path d="M8.5 12.5l2.5 2.5 5-5.5" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
                                    </svg>
                                }
                                else
                                {
                                    <svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                        <polygon points="12.0,0.5 15.01,3.73 19.39,3.19 19.62,7.6 23.33,10.0 20.67,13.53 21.96,17.75 17.66,18.74 15.93,22.81 12.0,20.8 8.07,22.81 6.34,18.74 2.04,17.75 3.33,13.53 0.67,10.0 4.38,7.6 4.61,3.19 8.99,3.73" fill="#f87171"></polygon>
                                        <path d="M9.5 9.5l5 5M14.5 9.5l-5 5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"></path>
                                    </svg>
                                }
                            </span>
                        </div>

                        <div class="subtext">@Model.RoleName</div>

                        <div class="divider"></div>

                        <div class="stats-row">
                            <div class="stat">
                                <i class="fa-regular fa-id-card"></i>
                                <span>@(string.IsNullOrWhiteSpace(Model.UserName) ? "—" : Model.UserName)</span>
                            </div>
                            <div class="stat">
                                <i class="fa-solid fa-user-tag"></i>
                                <span>@(string.IsNullOrWhiteSpace(Model.RoleName) ? "—" : Model.RoleName)</span>
                            </div>
                        </div>

                        @if (Model.Created.HasValue)
                        {
                            <div class="since">
                                Member since @Model.Created.Value.ToString("MMMM yyyy")
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- RIGHT: Personal info -->
            <div>
                <div class="cardx">
                    <div class="cardx-body">

                        <div class="cardx-title-row">
                            <h3 class="cardx-title">Personal Information</h3>

                            <!-- single edit button -->
                            <button type="button" class="btnx btnx-primary" id="btnOpenEdit">
                                <i class="fa-solid fa-pen-to-square"></i>
                                <span>Edit</span>
                            </button>
                        </div>

                        <div class="field">
                            <label>Full Name</label>
                            <div class="readonly-row">
                                <i class="fa-regular fa-user"></i>
                                <span>@Model.FirstName @Model.LastName</span>
                            </div>
                        </div>

                        <div class="field">
                            <label>Email Address</label>
                            <div class="readonly-row">
                                <i class="fa-regular fa-envelope"></i>
                                <span class="muted">@Model.Email</span>
                                <span class="readonly-chip">Cannot be changed</span>
                            </div>
                        </div>

                        <div class="field">
                            <label>Phone</label>
                            <div class="readonly-row">
                                <i class="fa-solid fa-phone"></i>
                                <span>@(string.IsNullOrWhiteSpace(Model.Phone) ? "—" : Model.Phone)</span>
                            </div>
                        </div>

                        <div class="field">
                            <label>Address</label>
                            <div class="readonly-row">
                                <i class="fa-solid fa-location-dot"></i>
                                <span>@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</span>
                            </div>
                        </div>

                        <div class="field">
                            <label>Gender</label>
                            <div class="readonly-row">
                                <i class="fa-solid fa-venus-mars"></i>
                                <span>@(string.IsNullOrWhiteSpace(Model.Gender) ? "—" : Model.Gender)</span>
                            </div>
                        </div>

                        <div class="divider"></div>

                        <h3 class="cardx-title" style="margin:0 0 12px 0;">Account Information</h3>

                        <div class="field">
                            <label>Role</label>
                            <div class="readonly-row">
                                <i class="fa-solid fa-user-tag"></i>
                                <span class="muted">@Model.RoleName</span>
                                <span class="readonly-chip">Read only</span>
                            </div>
                        </div>

                        <div class="field">
                            <label>Notes</label>
                            <div class="readonly-row" style="align-items:flex-start;">
                                <i class="fa-regular fa-note-sticky" style="margin-top:2px;"></i>
                                <span class="muted">@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</span>
                            </div>
                        </div>

                        <div class="info-grid">
                            <div class="info-box">
                                <div class="k">Member Since</div>
                                <div class="v">
                                    @(Model.Created.HasValue? Model.Created.Value.ToString("MMMM dd, yyyy") : "—")
                                </div>
                            </div>
                            <div class="info-box indigo">
                                <div class="k">Account Status</div>
                                <div class="v @(Model.IsActive ? "ok" : "bad")">
                                    @(Model.IsActive ? "Active" : "Inactive")
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- REMOVED: Security card + security note -->
            </div>

        </div>
    </div>
</div>

<!-- ===========================
     EDIT PROFILE MODAL
     (ALL editable fields are here)
=========================== -->
<div class="modal fade" id="editProfileModal" tabindex="-1" role="dialog" aria-labelledby="editProfileModalLabel" aria-hidden="true" style="z-index: 10000;">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <div style="font-size:.82rem;color:#6b7280;font-weight:800;letter-spacing:.08em;text-transform:uppercase;">
                        Edit
                    </div>
                    <h5 class="modal-title" id="editProfileModalLabel" style="margin:2px 0 0 0;">
                        Profile Settings
                    </h5>
                </div>
                <button type="button" class="modal-close-btn" id="btnCloseEdit" aria-label="Close">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="modal-body">
                @{
                    var modalFallbackAvatar = "https://ui-avatars.com/api/?name="
                    + (Model.FirstName + "+" + Model.LastName)
                    + "&background=60a5fa&color=fff&size=256";

                    var modalAvatarSrc = string.IsNullOrEmpty(Model.ProfilePicturePath)
                    ? modalFallbackAvatar
                    : Url.Content(Model.ProfilePicturePath);
                }

                <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
                    <img src="@modalAvatarSrc"
                         alt="Profile picture"
                         style="width:64px;height:64px;border-radius:999px;object-fit:cover;border:2px solid #e5e7eb;box-shadow:0 12px 28px rgba(15,23,42,.18);" />
                    <div>
                        <div style="font-weight:900;color:#111827;line-height:1.1;">@Model.FirstName @Model.LastName</div>
                        <div style="color:#6b7280;font-size:.86rem;">@Model.UserName</div>
                    </div>
                </div>

                <form asp-action="UpdateProfile"
                      method="post"
                      enctype="multipart/form-data"
                      id="editProfileForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-2"></div>

                    <!-- Hidden fields -->
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProfilePicturePath" />
                    <input type="hidden" asp-for="Created" />
                    <input type="hidden" asp-for="Modified" />
                    <input type="hidden" asp-for="IsActive" />
                    <input type="hidden" asp-for="UserName" />
                    <!-- Hidden CurrentPassword filled by SweetAlert -->
                    <input type="hidden" asp-for="CurrentPassword" id="CurrentPasswordHidden" />

                    <div class="form-row two" style="margin-bottom:12px;">
                        <div>
                            <label style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;">
                                New Profile Picture
                            </label>
                            <input asp-for="Picture" class="inputx" type="file" />
                            <span asp-validation-for="Picture" class="text-danger"></span>
                            <div class="upload-hint">Leave empty to keep current picture.</div>
                        </div>

                        <div>
                            <label asp-for="Email" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="Email" class="inputx" readonly />
                            <span asp-validation-for="Email" class="text-danger"></span>
                            <div class="upload-hint">Email cannot be changed.</div>
                        </div>
                    </div>

                    <div class="form-row two" style="margin-bottom:12px;">
                        <div>
                            <label asp-for="FirstName" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="FirstName" class="inputx" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="LastName" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="LastName" class="inputx" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row two" style="margin-bottom:12px;">
                        <div>
                            <label asp-for="Phone" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="Phone" class="inputx" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Address" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="Address" class="inputx" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-row three" style="margin-bottom:12px;">
                        <!-- Role editable; server will only save if Admin -->
                        <div>
                            <label asp-for="RoleName" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="RoleName" class="inputx" />
                            <span asp-validation-for="RoleName" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="Gender" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="Gender" class="inputx" />
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div>
                            <label asp-for="DateOfBirth" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="DateOfBirth" class="inputx" type="date" />
                            <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                        </div>
                    </div>

                    <div style="margin-bottom:12px;">
                        <label asp-for="Notes" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                        <textarea asp-for="Notes" class="textareax" rows="2"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="divider"></div>

                    <h5 style="font-weight:900;color:#111827;margin:0 0 10px 0;">Change Password</h5>

                    <div class="form-row two">
                        <div>
                            <label asp-for="NewPassword" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;">
                                New password (optional)
                            </label>
                            <input asp-for="NewPassword" class="inputx" type="password" autocomplete="new-password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                            <div class="upload-hint">Leave blank if you don't want to change your password.</div>
                        </div>

                        <div>
                            <label asp-for="ConfirmNewPassword" style="display:block;margin-bottom:6px;color:#6b7280;font-weight:800;font-size:.78rem;letter-spacing:.02em;text-transform:uppercase;"></label>
                            <input asp-for="ConfirmNewPassword" class="inputx" type="password" autocomplete="new-password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                        </div>
                    </div>
                </form>
            </div>

            <div class="modal-footer">
                <button type="button" class="btnx btnx-ghost" id="btnCancelEdit">
                    <i class="fa-solid fa-xmark"></i>
                    Cancel
                </button>
                <button type="button" class="btnx btnx-primary" id="btnSaveProfileModal">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const editBtn = document.getElementById('btnOpenEdit');
            const editFromPhoto = document.getElementById('btnOpenEditFromPhoto');

            const form = document.getElementById('editProfileForm');
            const saveBtn = document.getElementById('btnSaveProfileModal');
            const hiddenPwd = document.getElementById('CurrentPasswordHidden');

            const modalElement = document.getElementById('editProfileModal');
            const cancelBtn = document.getElementById('btnCancelEdit');
            const closeBtn = document.getElementById('btnCloseEdit');

            function showModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
                    modal.show();
                } else if (window.$ && typeof $(modalElement).modal === 'function') {
                    $(modalElement).modal('show');
                }
            }

            function hideModal() {
                if (window.bootstrap && bootstrap.Modal) {
                    const instance = bootstrap.Modal.getInstance(modalElement);
                    if (instance) instance.hide();
                } else if (window.$ && typeof $(modalElement).modal === 'function') {
                    $(modalElement).modal('hide');
                }
            }

            if (editBtn) editBtn.addEventListener('click', showModal);
            if (editFromPhoto) editFromPhoto.addEventListener('click', showModal);

            if (cancelBtn) cancelBtn.addEventListener('click', hideModal);
            if (closeBtn) closeBtn.addEventListener('click', hideModal);

            if (form && saveBtn && hiddenPwd) {
                saveBtn.addEventListener('click', async function (e) {
                    e.preventDefault();

                    // client-side validation if available
                    if (typeof $ !== 'undefined' && typeof $(form).valid === 'function') {
                        if (!$(form).valid()) {
                            return;
                        }
                    }

                    hideModal();

                    const result = await Swal.fire({
                        title: 'Confirm changes',
                        text: 'Enter your current password to save profile changes.',
                        input: 'password',
                        inputLabel: 'Current password',
                        inputPlaceholder: '••••••••',
                        inputAttributes: {
                            autocapitalize: 'off',
                            autocomplete: 'current-password'
                        },
                        showCancelButton: true,
                        confirmButtonText: 'Confirm & Save',
                        cancelButtonText: 'Cancel',
                        reverseButtons: true,
                        allowOutsideClick: false,
                        allowEscapeKey: true,
                        preConfirm: (value) => {
                            if (!value) {
                                Swal.showValidationMessage('Current password is required.');
                            }
                            return value;
                        }
                    });

                    if (!result.isConfirmed || !result.value) {
                        // user cancelled -> reopen modal so they can keep editing
                        showModal();
                        return;
                    }

                    hiddenPwd.value = result.value;
                    form.submit();
                });
            }

            const successMsg = '@(TempData["ProfileSuccess"] ?? "")';
            const errorMsg = '@(TempData["ProfileError"] ?? "")';
            const openEdit = '@(TempData["OpenEditModal"] ?? "")';

            if (successMsg) {
                Swal.fire({
                    icon: 'success',
                    title: 'Profile updated',
                    text: successMsg
                });
            }

            if (errorMsg) {
                Swal.fire({
                    icon: 'error',
                    title: 'Update failed',
                    text: errorMsg
                }).then(() => {
                    showModal();
                });
            } else if (openEdit) {
                showModal();
            }
        });
    </script>
}