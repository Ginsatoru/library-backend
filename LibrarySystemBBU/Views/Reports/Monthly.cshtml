@using System.Linq
@model LibrarySystemBBU.ViewModels.MonthlyReportViewModel

@{
    ViewData["Title"] = "Library Report";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<style>
    .rpt-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .rpt-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: .25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .rpt-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .rpt-subtitle {
        font-size: .85rem;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .rpt-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none !important;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .rpt-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none !important;
        }

    .rpt-btn-primary {
        background: #000080;
        color: #fff !important;
        border-color: #000080;
    }

        .rpt-btn-primary:hover {
            background: #00006a;
            border-color: #00006a;
        }

    .rpt-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .rpt-card-header {
        padding: 12px 16px;
        background: #f9fafb;
        border-bottom: 1px solid #e5e7eb;
        font-weight: 600;
        color: #111827;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        border-radius: 14px 14px 0 0;
    }

    .rpt-card-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .95rem;
    }

        .rpt-card-header-left::before {
            content: '';
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .rpt-card-body {
        padding: 1.25rem;
    }

    .rpt-card-noborder {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        margin-bottom: 1rem;
        overflow: hidden;
    }

    .rpt-filter-row {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .rpt-filter-group {
        min-width: 150px;
    }

    .rpt-filter-label {
        font-size: .75rem;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: .05em;
        display: block;
    }

    .rpt-filter-input, .rpt-filter-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        font-family: 'Inter', sans-serif;
        background: #fff;
    }

        .rpt-filter-input:focus, .rpt-filter-select:focus {
            outline: none;
            border-color: #000080;
        }

    .rpt-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 992px) {
        .rpt-kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 576px) {
        .rpt-kpi-grid {
            grid-template-columns: 1fr;
        }
    }

    .rpt-kpi-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 16px;
        text-decoration: none !important;
        display: block;
        transition: box-shadow .15s, transform .15s, border-color .15s;
    }

        .rpt-kpi-card:hover {
            border-color: #000080;
            text-decoration: none !important;
        }

    .rpt-kpi-icon {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        background: #eef0ff;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000080;
        font-size: 1.1rem;
        margin-bottom: .6rem;
    }

    .rpt-kpi-label {
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: #6b7280;
        margin-bottom: .2rem;
    }

    .rpt-kpi-val {
        font-size: 1.25rem;
        font-weight: 800;
        color: #000080;
        margin-bottom: .15rem;
    }

    .rpt-kpi-sub {
        font-size: .78rem;
        color: #9ca3af;
    }

    .rpt-pill {
        font-size: .75rem;
        color: #374151;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 3px 10px;
        white-space: nowrap;
        font-weight: 500;
    }

    .rpt-table-wrap {
        overflow-x: auto;
        padding: 0 1.25rem 1.25rem;
    }

    .rpt-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .rpt-table thead th {
            padding: 9px 12px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .73rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .rpt-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .rpt-table tbody tr:last-child {
                border-bottom: none;
            }

            .rpt-table tbody tr:hover {
                background: #f9fafb;
            }

        .rpt-table tbody td {
            padding: 9px 12px;
            color: #374151;
            vertical-align: middle;
        }

        .rpt-table tfoot tr {
            border-top: 2px solid #e5e7eb;
        }

        .rpt-table tfoot th {
            padding: 9px 12px;
            color: #000080;
            font-weight: 700;
            font-size: .83rem;
        }

        .rpt-table .text-end {
            text-align: right;
        }

    .rpt-empty {
        padding: 2rem;
        text-align: center;
        color: #9ca3af;
        font-size: .85rem;
    }

    @@media print {
        body {
            background: #fff !important;
        }

        .rpt-card, .rpt-card-noborder {
            box-shadow: none !important;
            border: 1px solid #000 !important;
            page-break-inside: avoid;
        }
    }
</style>

<div class="rpt-page">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
        <div>
            <div class="rpt-page-title">@ViewData["Title"]</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-action="MonthlyExcel"
               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
               class="rpt-btn rpt-btn-primary">
                <i class="bi bi-file-earmark-excel"></i> Export Excel
            </a>
            <button type="button" class="rpt-btn" onclick="window.print()">
                <i class="bi bi-printer"></i> Print
            </button>
        </div>
    </div>

    <!-- Filter -->
    <div class="rpt-card">
        <form method="get" class="rpt-filter-row">
            <div class="rpt-filter-group">
                <label class="rpt-filter-label">Start Date</label>
                <input type="date" name="startDate" class="rpt-filter-input"
                       value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="rpt-filter-group">
                <label class="rpt-filter-label">End Date</label>
                <input type="date" name="endDate" class="rpt-filter-input"
                       value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="rpt-filter-group">
                <label class="rpt-filter-label">&nbsp;</label>
                <button type="submit" class="rpt-btn rpt-btn-primary" style="width:100%;">
                    <i class="bi bi-search"></i> View Report
                </button>
            </div>
        </form>
    </div>

    <!-- KPI Cards -->
    <div class="rpt-kpi-grid">
        <a href="#borrow-report" class="rpt-kpi-card">
            <div class="rpt-kpi-icon"><i class="bi bi-book"></i></div>
            <div class="rpt-kpi-label">Borrowed (Take Home)</div>
            <div class="rpt-kpi-val">@Model.StudentTakeHomeItemsBorrowed</div>
            <div class="rpt-kpi-sub">items borrowed in range</div>
        </a>
        <a href="#return-report" class="rpt-kpi-card">
            <div class="rpt-kpi-icon"><i class="bi bi-arrow-return-left"></i></div>
            <div class="rpt-kpi-label">Returned (Take Home)</div>
            <div class="rpt-kpi-val">@Model.StudentTakeHomeReturns</div>
            <div class="rpt-kpi-sub">items returned in range</div>
        </a>
        <a href="#inlibrary-report" class="rpt-kpi-card">
            <div class="rpt-kpi-icon"><i class="bi bi-building"></i></div>
            <div class="rpt-kpi-label">In-Library Reading</div>
            <div class="rpt-kpi-val">@Model.InLibraryItemsRead</div>
            <div class="rpt-kpi-sub">Logs: @Model.InLibraryBorrowCount &middot; Returned: @Model.InLibraryReturnCount</div>
        </a>
        <a href="#financial-report" class="rpt-kpi-card">
            @{
                var totalIncome = Model.IncomeBorrowingFees + Model.IncomeFines + Model.IncomeExtraCharges;
            }
            <div class="rpt-kpi-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="rpt-kpi-label">Net Cash Flow</div>
            <div class="rpt-kpi-val">$@Model.NetCashFlow.ToString("N0")</div>
            <div class="rpt-kpi-sub">Income: $@totalIncome.ToString("N0")</div>
        </a>
    </div>

    <!-- 1. Borrow Report -->
    <a id="borrow-report"></a>
    <div class="rpt-card-noborder mb-3">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">1. Borrow Book Report (Student Take-Home)</div>
            <span class="rpt-pill">@Model.StudentTakeHomeItemsBorrowed items &middot; @Model.StudentTakeHomeLoans loans</span>
        </div>
        @if (Model.StudentBorrowDetails.Any())
        {
            var totalRows = Model.StudentBorrowDetails.Count;
            var totalStudents = Model.StudentBorrowDetails.Select(b => b.MemberId).Distinct().Count();
            var totalDeposit = Model.StudentBorrowDetails.Sum(x => x.DepositAmount);
            var totalFine = Model.StudentBorrowDetails.Sum(x => x.FineAmount);
            var totalExtra = Model.StudentBorrowDetails.Sum(x => x.ExtraCharge);
            <div class="rpt-table-wrap">
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th>Loan Date</th>
                            <th>Due</th>
                            <th>Return</th>
                            <th>Member</th>
                            <th>Type</th>
                            <th>Catalog Title</th>
                            <th>Barcode</th>
                            <th class="text-end">Deposit</th>
                            <th class="text-end">Fine</th>
                            <th class="text-end">Extra</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.StudentBorrowDetails)
                        {
                            <tr>
                                <td>@b.LoanDate.ToString("yyyy-MM-dd")</td>
                                <td>@(b.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@(b.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@b.MemberName</td>
                                <td>@b.MemberType</td>
                                <td>@b.CatalogTitle</td>
                                <td>@b.Barcode</td>
                                <td class="text-end">$@b.DepositAmount.ToString("N0")</td>
                                <td class="text-end">$@b.FineAmount.ToString("N0")</td>
                                <td class="text-end">$@b.ExtraCharge.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">Totals</th>
                            <th>@totalStudents student(s)</th>
                            <th></th>
                            <th>@totalRows item(s)</th>
                            <th></th>
                            <th class="text-end">$@totalDeposit.ToString("N0")</th>
                            <th class="text-end">$@totalFine.ToString("N0")</th>
                            <th class="text-end">$@totalExtra.ToString("N0")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="rpt-empty"><i class="bi bi-inbox"></i><div class="mt-1">No borrowing records for this range.</div></div>
        }
    </div>

    <!-- 1b. Return Report -->
    <a id="return-report"></a>
    <div class="rpt-card-noborder mb-3">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">1b. Return Update Report (Student Take-Home)</div>
            <span class="rpt-pill">@Model.StudentTakeHomeReturns returned items</span>
        </div>
        @if (Model.StudentReturnDetails != null && Model.StudentReturnDetails.Any())
        {
            var totalRows = Model.StudentReturnDetails.Count;
            var totalStudents = Model.StudentReturnDetails.Select(b => b.MemberId).Distinct().Count();
            var totalFine = Model.StudentReturnDetails.Sum(x => x.FineAmount);
            var totalExtra = Model.StudentReturnDetails.Sum(x => x.ExtraCharge);
            <div class="rpt-table-wrap">
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th>Return Date</th>
                            <th>Loan Date</th>
                            <th>Due</th>
                            <th>Member</th>
                            <th>Type</th>
                            <th>Catalog Title</th>
                            <th>Barcode</th>
                            <th class="text-end">Fine</th>
                            <th class="text-end">Extra</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.StudentReturnDetails)
                        {
                            <tr>
                                <td>@(r.ReturnDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@r.LoanDate.ToString("yyyy-MM-dd")</td>
                                <td>@(r.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@r.MemberName</td>
                                <td>@r.MemberType</td>
                                <td>@r.CatalogTitle</td>
                                <td>@r.Barcode</td>
                                <td class="text-end">$@r.FineAmount.ToString("N0")</td>
                                <td class="text-end">$@r.ExtraCharge.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">Totals</th>
                            <th>@totalStudents student(s)</th>
                            <th></th>
                            <th>@totalRows item(s)</th>
                            <th></th>
                            <th class="text-end">$@totalFine.ToString("N0")</th>
                            <th class="text-end">$@totalExtra.ToString("N0")</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="rpt-empty"><i class="bi bi-inbox"></i><div class="mt-1">No return records for this range.</div></div>
        }
    </div>

    <!-- 2. In-Library Reading -->
    <a id="inlibrary-report"></a>
    <div class="rpt-card-noborder mb-3">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">2. In-Library Reading (Library Log)</div>
            <span class="rpt-pill">@Model.InLibraryItemsRead items &middot; @Model.InLibraryBorrowCount logs</span>
        </div>
        @if (Model.InLibraryDetails.Any())
        {
            var totalRows = Model.InLibraryDetails.Count;
            var totalStudents = Model.InLibraryDetails.Select(x => x.StudentName).Distinct().Count();
            <div class="rpt-table-wrap">
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th>Visit Date</th>
                            <th>Student</th>
                            <th>Gender</th>
                            <th>Purpose</th>
                            <th>Book Title</th>
                            <th>Catalog Title</th>
                            <th>Barcode</th>
                            <th>Status</th>
                            <th>Returned Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.InLibraryDetails)
                        {
                            <tr>
                                <td>@r.VisitDate.ToString("yyyy-MM-dd")</td>
                                <td>@r.StudentName</td>
                                <td>@r.Gender</td>
                                <td>@r.Purpose</td>
                                <td>@r.BookTitle</td>
                                <td>@r.CatalogTitle</td>
                                <td>@r.Barcode</td>
                                <td>@r.Status</td>
                                <td>@(r.ReturnedDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="2">@totalStudents student(s)</th>
                            <th colspan="7">@totalRows items read in library</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="rpt-empty"><i class="bi bi-inbox"></i><div class="mt-1">No in-library reading records for this range.</div></div>
        }
    </div>

    <!-- 3. Purchases -->
    <a id="purchases-report"></a>
    <div class="rpt-card-noborder mb-3">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">3. Purchases Report</div>
            <span class="rpt-pill">@Model.PurchaseTotalQuantity copies &middot; @Model.PurchaseTransactions transactions</span>
        </div>
        @if (Model.PurchaseItems.Any())
        {
            var totalRows = Model.PurchaseItems.Count;
            var totalQty = Model.PurchaseItems.Sum(x => x.Quantity);
            var totalCost = Model.PurchaseItems.Sum(x => x.Cost);
            <div class="rpt-table-wrap">
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Supplier</th>
                            <th>Book Title</th>
                            <th class="text-end">Quantity</th>
                            <th class="text-end">Cost</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.PurchaseItems)
                        {
                            <tr>
                                <td>@p.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                <td>@p.Supplier</td>
                                <td>@p.BookTitle</td>
                                <td class="text-end">@p.Quantity</td>
                                <td class="text-end">$@p.Cost.ToString("N0")</td>
                                <td>@p.Notes</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">@totalRows Purchases</th>
                            <th class="text-end">@totalQty</th>
                            <th class="text-end">$@totalCost.ToString("N0")</th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="rpt-empty"><i class="bi bi-inbox"></i><div class="mt-1">No purchases recorded for this range.</div></div>
        }
    </div>

    <!-- 4. Adjustments -->
    <a id="adjustments-report"></a>
    <div class="rpt-card-noborder mb-3">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">4. Adjustments Report</div>
            <span class="rpt-pill">@Model.TotalAdjustments adjustments &middot; Net @Model.TotalAdjustmentQtyChange copies</span>
        </div>
        @if (Model.AdjustmentItems.Any())
        {
            var totalRows = Model.AdjustmentItems.Count;
            var totalQty = Model.AdjustmentItems.Sum(x => x.QuantityChanged);
            <div class="rpt-table-wrap">
                <table class="rpt-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Catalog Title</th>
                            <th class="text-end">Qty Change</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in Model.AdjustmentItems)
                        {
                            <tr>
                                <td>@d.AdjustmentDate.ToString("yyyy-MM-dd")</td>
                                <td>@d.AdjustmentType</td>
                                <td>@d.CatalogTitle</td>
                                <td class="text-end">@d.QuantityChanged</td>
                                <td>@d.Reason</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3">@totalRows Adjustments</th>
                            <th class="text-end">@totalQty</th>
                            <th></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        }
        else
        {
            <div class="rpt-empty"><i class="bi bi-inbox"></i><div class="mt-1">No adjustment details for this range.</div></div>
        }
    </div>

    <!-- 5. Financial Summary -->
    <a id="financial-report"></a>
    <div class="rpt-card-noborder mb-5">
        <div class="rpt-card-header">
            <div class="rpt-card-header-left">5. Financial Summary</div>
        </div>
        <div class="rpt-table-wrap">
            <table class="rpt-table">
                <thead>
                    <tr><th>Category</th><th>Type</th><th class="text-end">Amount</th></tr>
                </thead>
                <tbody>
                    <tr><td>Borrowing fees</td><td>Income</td><td class="text-end">$@Model.IncomeBorrowingFees.ToString("N0")</td></tr>
                    <tr><td>Late fines</td><td>Income</td><td class="text-end">$@Model.IncomeFines.ToString("N0")</td></tr>
                    <tr><td>Extra charges (damage, etc.)</td><td>Income</td><td class="text-end">$@Model.IncomeExtraCharges.ToString("N0")</td></tr>
                    <tr><td>Book purchases</td><td>Expense</td><td class="text-end">$@Model.ExpensePurchases.ToString("N0")</td></tr>
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="2">Net Cash Flow (Income - Expense)</th>
                        <th class="text-end">$@Model.NetCashFlow.ToString("N0")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>