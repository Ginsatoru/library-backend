<!-- STYLES -->
<style>
    :root {
        --brand: #000080;
        --sidebar-bg: #000080;
        --sidebar-hover: rgba(255,255,255,.10);
        --sidebar-active: rgba(255,255,255,.18);
        --sidebar-border: rgba(255,255,255,.14);
    }

    html, body, .wrapper {
        overflow-x: hidden;
    }

    .main-sidebar {
        width: 250px !important;
        min-height: 100vh;
        background: linear-gradient(160deg, #000099 0%, #00007a 100%) !important;
        color: #fff !important;
        display: flex;
        flex-direction: column;
        transition: width .24s cubic-bezier(0.22, 0.61, 0.36, 1);
        box-shadow: 0 20px 60px rgba(0,0,0,.4);
        border-right: 1px solid rgba(255,255,255,.12);
        overflow: hidden;
    }

    .brand-logo {
        width: 40px;
        height: 40px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .brand-text {
        font-size: 1.1rem;
        color: #fff;
        white-space: nowrap;
    }

    .nav-scroll {
        flex: 1 1 auto;
        padding-bottom: 1rem;
        overflow-y: auto;
        overflow-x: hidden;
    }

        .nav-scroll::-webkit-scrollbar {
            width: 4px;
        }

        .nav-scroll::-webkit-scrollbar-track {
            background: transparent;
        }

        .nav-scroll::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,.2);
            border-radius: 8px;
        }

    .nav-section {
        font-size: .68rem;
        letter-spacing: .12rem;
        color: rgba(255,255,255,.55);
        padding: .75rem .75rem .25rem;
        margin-top: .25rem;
        white-space: nowrap;
        user-select: none;
    }

    .nav-link {
        color: rgba(255,255,255,.9) !important;
        border-radius: .65rem;
        padding: .6rem .8rem;
        transition: background-color .15s ease, box-shadow .15s ease;
        position: relative;
        display: flex;
        align-items: center;
        gap: .5rem;
        white-space: nowrap;
        text-decoration: none !important;
        background: none;
        border: none;
        width: 100%;
    }

        .nav-link i {
            min-width: 18px;
            text-align: center;
        }

        .nav-link:hover {
            background: var(--sidebar-hover) !important;
            color: #fff !important;
            text-decoration: none !important;
            transform: none;
        }

        .nav-link.active,
        .nav-link[aria-current="page"] {
            background: var(--sidebar-active) !important;
            box-shadow: inset 0 0 0 1px var(--sidebar-border);
            color: #fff !important;
        }

    .nav-sublink {
        display: block;
        color: rgba(255,255,255,.85);
        padding: .45rem .75rem;
        border-radius: .5rem;
        margin: .1rem 0;
        transition: background-color .15s ease;
        font-size: .88rem;
        white-space: nowrap;
        text-decoration: none !important;
    }

        .nav-sublink:hover {
            background: var(--sidebar-hover);
            color: #fff;
            text-decoration: none !important;
        }

        .nav-sublink.active {
            background: var(--sidebar-active);
            color: #fff;
        }

    .chevron {
        transition: transform .2s ease;
        font-size: .75rem;
        opacity: .7;
    }

    button.nav-link[aria-expanded="true"] .chevron {
        transform: rotate(180deg);
    }

    .nav-link:focus,
    .nav-sublink:focus {
        outline: none;
        box-shadow: 0 0 0 2px rgba(147,197,253,.4);
    }

    /* Content wrapper offset */
    .content-wrapper {
        margin-left: 250px;
        transition: margin-left .24s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    /* Compact mode */
    body.bbu-sidebar-mini .main-sidebar {
        width: 68px !important;
    }

    body.bbu-sidebar-mini .content-wrapper {
        margin-left: 68px;
    }

    body.bbu-sidebar-mini .main-sidebar .brand-text,
    body.bbu-sidebar-mini .main-sidebar .nav-section,
    body.bbu-sidebar-mini .main-sidebar .nav-link span,
    body.bbu-sidebar-mini .main-sidebar .nav-link .badge {
        opacity: 0;
        pointer-events: none;
    }

    body.bbu-sidebar-mini .main-sidebar .nav-link,
    body.bbu-sidebar-mini .main-sidebar .nav-sublink {
        justify-content: center;
    }

    body.bbu-sidebar-mini .main-sidebar:hover {
        width: 250px !important;
    }

        body.bbu-sidebar-mini .main-sidebar:hover .brand-text,
        body.bbu-sidebar-mini .main-sidebar:hover .nav-section,
        body.bbu-sidebar-mini .main-sidebar:hover .nav-link span,
        body.bbu-sidebar-mini .main-sidebar:hover .nav-link .badge {
            opacity: 1;
            pointer-events: auto;
        }

    /* Kill AdminLTE overrides */
    .sidebar-mini .main-sidebar .nav-link,
    .sidebar-mini-md .main-sidebar .nav-link,
    .sidebar-mini-xs .main-sidebar .nav-link {
        color: rgba(255,255,255,.9) !important;
    }

    .layout-navbar-fixed.layout-fixed .wrapper .sidebar {
        margin-top: 0 !important;
    }

    /* Remove any underlines globally in sidebar */
    .main-sidebar a,
    .main-sidebar a:hover,
    .main-sidebar a:focus,
    .main-sidebar a:visited {
        text-decoration: none !important;
    }
</style>

<!-- JS -->
<script>
    (function () {
        // 1) ACTIVE LINK + OPEN PARENT COLLAPSE
        try {
            var path = location.pathname.toLowerCase();
            document.querySelectorAll('.main-sidebar a.nav-link, .main-sidebar a.nav-sublink')
                .forEach(function (a) {
                    var href = (a.getAttribute('href') || '').toLowerCase();
                    if (!href) return;
                    if (href === path || (href !== '/' && path.startsWith(href))) {
                        a.classList.add('active');
                        var parentCollapse = a.closest('.collapse');
                        if (parentCollapse) {
                            new bootstrap.Collapse(parentCollapse, { toggle: false }).show();
                        }
                    }
                });
        } catch (e) { }

        // 2) PERSIST COLLAPSED MENUS
        var keyPrefix = 'bbu.sidebar.collapse.';
        if (typeof bootstrap === 'undefined') return;
        document.querySelectorAll('.main-sidebar .collapse[data-persist="true"]').forEach(function (el) {
            var id = el.id; if (!id) return;
            var saved = localStorage.getItem(keyPrefix + id);
            if (saved === '1') {
                new bootstrap.Collapse(el, { toggle: false }).show();
            }
            el.addEventListener('shown.bs.collapse', function () {
                localStorage.setItem(keyPrefix + id, '1');
            });
            el.addEventListener('hidden.bs.collapse', function () {
                localStorage.setItem(keyPrefix + id, '0');
            });
        });
    })();
</script>
