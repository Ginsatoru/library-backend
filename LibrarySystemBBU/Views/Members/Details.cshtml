@model LibrarySystemBBU.Models.Member

@{
    ViewData["Title"] = "Member Details";
    var tgConnected = !string.IsNullOrWhiteSpace(Model.TelegramChatId);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .mem-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .mem-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .mem-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .mem-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .mem-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .mem-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

    .mem-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .mem-btn-primary:hover {
            background: #00006a;
            color: #fff;
        }

    .mem-detail-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .mem-detail-profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 28px 24px 20px;
        border-bottom: 1px solid #f3f4f6;
        background: #f9fafb;
    }

    .mem-detail-avatar {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e5e7eb;
        background: #f3f4f6;
        margin-bottom: 12px;
    }

    .mem-detail-name {
        font-size: 1.1rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 6px;
    }

    .mem-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-size: .72rem;
        font-weight: 500;
        border-radius: 20px;
        padding: 3px 10px;
        border: 1px solid transparent;
    }

    .mem-badge-active {
        background: #dcfce7;
        color: #166534;
        border-color: #bbf7d0;
    }

    .mem-badge-inactive {
        background: #f3f4f6;
        color: #6b7280;
        border-color: #e5e7eb;
    }

    .mem-badge-type {
        background: #dbeafe;
        color: #1e40af;
        border-color: #bfdbfe;
    }

    .mem-detail-badges {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 6px;
    }

    .mem-detail-body {
        padding: 24px;
    }

    .mem-detail-section {
        margin-bottom: 24px;
    }

    .mem-section-divider {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 14px;
        color: #6b7280;
        font-size: .72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

        .mem-section-divider::before, .mem-section-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f3f4f6;
        }

    .mem-dl {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 0;
    }

    .mem-dt {
        padding: 9px 12px;
        font-size: .78rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .04em;
        display: flex;
        align-items: center;
        gap: 5px;
        border-bottom: 1px solid #f9fafb;
    }

    .mem-dd {
        padding: 9px 12px;
        font-size: .85rem;
        color: #374151;
        border-bottom: 1px solid #f9fafb;
    }

        .mem-dt:last-of-type, .mem-dd:last-of-type {
            border-bottom: none;
        }

    @@media (max-width: 540px) {
        .mem-dl {
            grid-template-columns: 1fr;
        }

        .mem-dt {
            border-bottom: none;
            padding-bottom: 2px;
        }

        .mem-dd {
            padding-top: 2px;
        }
    }

    .mem-tg-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .8rem;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid transparent;
    }

    .mem-tg-connected {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    .mem-tg-disconnected {
        background: #f9fafb;
        border-color: #e5e7eb;
        color: #6b7280;
    }

    .mem-detail-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding: 16px 24px;
        border-top: 1px solid #f3f4f6;
        background: #f9fafb;
    }
</style>

<div class="mem-page">

    <div class="mem-page-title">Member Details</div>

    <div class="mem-toolbar">
        <a class="mem-btn" asp-action="Index"><i class="bi bi-arrow-left"></i> Back to List</a>
        <a class="mem-btn mem-btn-primary" asp-action="Edit" asp-route-id="@Model?.MemberId">
            <i class="bi bi-pencil-square"></i> Edit Member
        </a>
    </div>

    <div class="mem-detail-card">

        <!-- Profile Header -->
        <div class="mem-detail-profile">
            <img src="@(string.IsNullOrWhiteSpace(Model.ProfilePicturePath)
                                 ? "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(Model.FullName ?? "Member") + "&background=60a5fa&color=fff&size=128"
                                 : Model.ProfilePicturePath)"
                 class="mem-detail-avatar" alt="Profile" />
            <div class="mem-detail-name">@Model.FullName</div>
            <div class="mem-detail-badges">
                <span class="mem-badge mem-badge-type"><i class="bi bi-person-badge"></i> @Model.MemberType</span>
                @if (Model.IsActive)
                {
                    <span class="mem-badge mem-badge-active"><i class="bi bi-check-circle-fill"></i> Active</span>
                }
                else
                {
                    <span class="mem-badge mem-badge-inactive"><i class="bi bi-x-circle"></i> Inactive</span>
                }
            </div>
        </div>

        <!-- Detail Body -->
        <div class="mem-detail-body">

            <div class="mem-detail-section">
                <div class="mem-section-divider">Basic Info</div>
                <div class="mem-dl">
                    <div class="mem-dt"><i class="bi bi-gender-ambiguous"></i> Gender</div>
                    <div class="mem-dd">@(Model.Gender ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-envelope"></i> Email</div>
                    <div class="mem-dd">@(Model.Email ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-phone"></i> Phone</div>
                    <div class="mem-dd">@(Model.Phone ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-geo-alt"></i> Address</div>
                    <div class="mem-dd">@(Model.Address ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-building"></i> Faculty</div>
                    <div class="mem-dd">@(Model.Faculty ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-credit-card"></i> Library ID</div>
                    <div class="mem-dd">@(Model.DICardNumber ?? "—")</div>
                </div>
            </div>

            <div class="mem-detail-section">
                <div class="mem-section-divider">Telegram</div>
                <div class="mem-dl">
                    <div class="mem-dt"><i class="bi bi-telegram"></i> Telegram</div>
                    <div class="mem-dd">
                        @if (tgConnected)
                        {
                            <span class="mem-tg-badge mem-tg-connected">
                                <i class="bi bi-telegram"></i> Connected
                                @if (!string.IsNullOrWhiteSpace(Model.TelegramUsername))
                                {
                                    <span>— @@@Model.TelegramUsername</span>
                                }
                            </span>
                        }
                        else
                        {
                            <span class="mem-tg-badge mem-tg-disconnected">
                                <i class="bi bi-telegram"></i> Not connected
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="mem-detail-section">
                <div class="mem-section-divider">Account</div>
                <div class="mem-dl">
                    <div class="mem-dt"><i class="bi bi-calendar-plus"></i> Joined</div>
                    <div class="mem-dd">@Model.JoinDate.ToString("yyyy-MM-dd")</div>

                    <div class="mem-dt"><i class="bi bi-clock-history"></i> Modified</div>
                    <div class="mem-dd">@Model.Modified.ToString("yyyy-MM-dd HH:mm")</div>

                    <div class="mem-dt"><i class="bi bi-person-workspace"></i> Linked User</div>
                    <div class="mem-dd">@(Model.Users?.UserName ?? "—")</div>

                    <div class="mem-dt"><i class="bi bi-person"></i> Created By</div>
                    <div class="mem-dd">@(Model.CreatedBy ?? "—")</div>

                    @if (!string.IsNullOrWhiteSpace(Model.Notes))
                    {
                        <div class="mem-dt"><i class="bi bi-sticky"></i> Notes</div>
                        <div class="mem-dd">@Model.Notes</div>
                    }
                </div>
            </div>

        </div>

        <div class="mem-detail-actions">
            <a asp-action="Index" class="mem-btn"><i class="bi bi-arrow-left"></i> Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.MemberId" class="mem-btn mem-btn-primary">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
        </div>
    </div>

</div>
