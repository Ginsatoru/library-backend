@model IEnumerable<LibrarySystemBBU.Models.Member>
@using System.Linq

@{
    ViewData["Title"] = "Members";
    var total = Model?.Count() ?? 0;
    var active = Model?.Count(m => m.IsActive) ?? 0;
    var inactive = total - active;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .mem-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .mem-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .mem-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .mem-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .mem-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .mem-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .mem-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .mem-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .mem-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .mem-segmented {
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .mem-seg-btn {
        padding: 6px 14px;
        font-size: .82rem;
        font-weight: 500;
        border: none;
        background: #fff;
        color: #6b7280;
        cursor: pointer;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
    }

        .mem-seg-btn:not(:last-child) {
            border-right: 1px solid #e5e7eb;
        }

        .mem-seg-btn.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

    .mem-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        background: #fff;
        flex: 1;
        min-width: 200px;
        max-width: 360px;
        transition: border-color .15s;
    }

        .mem-search-wrap:focus-within {
            border-color: #000080;
        }

        .mem-search-wrap i {
            color: #9ca3af;
            font-size: .85rem;
        }

    .mem-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: .83rem;
        color: #111827;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

        .mem-search-input::placeholder {
            color: #9ca3af;
        }

    .mem-search-clear {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        padding: 0;
        font-size: .85rem;
    }

        .mem-search-clear:hover {
            color: #6b7280;
        }

    .mem-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
        flex-wrap: wrap;
    }

    .mem-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .mem-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    /* ── Table ── */
    .mem-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .mem-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .mem-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .mem-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .mem-table tbody tr:last-child {
                border-bottom: none;
            }

            .mem-table tbody tr:hover {
                background: #f9fafb;
            }

        .mem-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

            .mem-table tbody td.muted {
                color: #6b7280;
            }

    .mem-pager {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 12px 0;
    }

    /* ── Cards ── */
    .mem-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 18px;
        margin-bottom: 1rem;
    }

    .mem-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: box-shadow .2s, transform .2s;
    }

        .mem-card:hover {
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            transform: translateY(-2px);
        }

    .mem-card-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #e5e7eb;
        margin: 18px auto 0;
        display: block;
        background: #f3f4f6;
    }

    .mem-card-body {
        padding: 10px 14px 8px;
        flex: 1;
        text-align: center;
    }

    .mem-card-title {
        font-size: .875rem;
        font-weight: 600;
        color: #111827;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mem-card-meta {
        font-size: .74rem;
        color: #6b7280;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        margin-bottom: 3px;
    }

        .mem-card-meta i {
            font-size: .7rem;
            flex-shrink: 0;
        }

    .mem-badge {
        display: inline-flex;
        align-items: center;
        gap: 3px;
        font-size: .68rem;
        font-weight: 500;
        border-radius: 20px;
        padding: 2px 8px;
        border: 1px solid transparent;
    }

    .mem-badge-active {
        background: #dcfce7;
        color: #166534;
        border-color: #bbf7d0;
    }

    .mem-badge-inactive {
        background: #f3f4f6;
        color: #6b7280;
        border-color: #e5e7eb;
    }

    .mem-badge-type {
        background: #dbeafe;
        color: #1e40af;
        border-color: #bfdbfe;
    }

    .mem-card-stats {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 4px;
        padding: 8px 14px 10px;
        border-top: 1px solid #f3f4f6;
        margin-top: 8px;
    }

    .mem-card-chip {
        font-size: .68rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 2px 7px;
        display: flex;
        align-items: center;
        gap: 3px;
    }

    .mem-card-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        padding: 8px 14px 12px;
        border-top: 1px solid #f3f4f6;
    }

        .mem-card-actions a {
            flex: 1;
            text-align: center;
            padding: 5px 4px;
            font-size: .72rem;
            font-weight: 500;
            border-radius: 7px;
            border: 1px solid #e5e7eb;
            color: #374151;
            text-decoration: none;
            background: #fff;
            transition: background .15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 3px;
            font-family: 'Inter', sans-serif;
        }

            .mem-card-actions a:hover {
                background: #f3f4f6;
                color: #111827;
                text-decoration: none;
            }
</style>

<div class="mem-page">

    <div class="mem-page-title">Members</div>

    <div class="mem-toolbar">
        <a class="mem-btn mem-btn-primary" asp-action="Create"><i class="bi bi-person-plus"></i> Create New</a>

        <div class="mem-segmented">
            <button type="button" class="mem-seg-btn active" data-view="list"><i class="bi bi-list-ul"></i> List</button>
            <button type="button" class="mem-seg-btn" data-view="cards"><i class="bi bi-grid-3x3-gap"></i> Cards</button>
        </div>

        <div class="mem-search-wrap">
            <i class="bi bi-search"></i>
            <input id="memberSearch" class="mem-search-input" placeholder="Search name, email, phone, type, ID, Telegram…" autocomplete="off" />
            <button class="mem-search-clear" type="button" id="clearSearch"><i class="bi bi-x-circle"></i></button>
        </div>

        <a class="mem-btn" asp-action="Export" asp-route-format="xls"><i class="bi bi-download"></i> Export</a>

        <div class="mem-stats">
            <span class="mem-stat-pill"><i class="bi bi-people"></i> Total: <strong id="statTotal">@total</strong></span>
            <span class="mem-stat-pill"><i class="bi bi-check-circle" style="color:#16a34a"></i> Active: <strong id="statActive">@active</strong></span>
            <span class="mem-stat-pill"><i class="bi bi-x-circle" style="color:#9ca3af"></i> Inactive: <strong id="statInactive">@inactive</strong></span>
        </div>
    </div>

    <!-- LIST VIEW -->
    <div id="view-list">
        <div class="mem-table-wrap">
            <table class="mem-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Type</th>
                        <th>Library ID</th>
                        <th>Telegram</th>
                        <th>Status</th>
                        <th>Loans</th>
                        <th>Join Date</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="memberTableBody"></tbody>
            </table>
        </div>
        <div class="mem-pager" id="listPager">
            <button type="button" class="mem-btn" id="prevPage"><i class="bi bi-chevron-left"></i> Prev</button>
            <span id="pageInfo" style="font-size:.82rem;color:#6b7280;">Page 1 / 1</span>
            <button type="button" class="mem-btn" id="nextPage">Next <i class="bi bi-chevron-right"></i></button>
        </div>
    </div>

    <!-- CARD VIEW -->
    <div class="mem-cards-grid" id="view-cards" style="display:none;"></div>
    <div class="mem-pager" id="cardPager" style="display:none;">
        <button type="button" class="mem-btn" id="cardPrevPage"><i class="bi bi-chevron-left"></i> Prev</button>
        <span id="cardPageInfo" style="font-size:.82rem;color:#6b7280;">Page 1 / 1</span>
        <button type="button" class="mem-btn" id="cardNextPage">Next <i class="bi bi-chevron-right"></i></button>
    </div>

</div>

@section Scripts {
    <script>
        (function () {
            // Serialize model data into JS
            const allMembers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model?.Select(m => new {
                    memberId    = m.MemberId,
                    fullName    = m.FullName,
                    email       = m.Email,
                    phone       = m.Phone,
                    memberType  = m.MemberType,
                    diCardNumber= m.DICardNumber,
                    telegramUsername = m.TelegramUsername,
                    telegramChatId   = m.TelegramChatId,
                    isActive    = m.IsActive,
                    joinDate    = m.JoinDate.ToString("yyyy-MM-dd"),
                    totalLoans  = m.BookLoans?.Count ?? 0,
                    activeLoans = m.BookLoans?.Count(b => b != null && !b.IsReturned) ?? 0,
                    profilePicturePath = m.ProfilePicturePath,
                    faculty     = m.Faculty,
                    gender      = m.Gender,
                }) ?? Enumerable.Empty<object>()
            ));

            let filtered = [];
            let pageIndex = 1, cardPageIndex = 1;
            const pageSize = 50, cardPageSize = 20;
            let viewMode = 'list';

            const search       = document.getElementById('memberSearch');
            const clearBtn     = document.getElementById('clearSearch');
            const statTotal    = document.getElementById('statTotal');
            const statActive   = document.getElementById('statActive');
            const statInactive = document.getElementById('statInactive');
            const btns         = document.querySelectorAll('.mem-seg-btn');
            const viewList     = document.getElementById('view-list');
            const viewCards    = document.getElementById('view-cards');
            const tbody        = document.getElementById('memberTableBody');
            const prevBtn      = document.getElementById('prevPage');
            const nextBtn      = document.getElementById('nextPage');
            const pageInfo     = document.getElementById('pageInfo');
            const cardPager    = document.getElementById('cardPager');
            const cardPrevBtn  = document.getElementById('cardPrevPage');
            const cardNextBtn  = document.getElementById('cardNextPage');
            const cardPageInfo = document.getElementById('cardPageInfo');

            function applyFilter() {
                const q = (search.value || '').trim().toLowerCase();
                filtered = !q ? allMembers : allMembers.filter(m =>
                    [m.fullName, m.email, m.phone, m.memberType, m.diCardNumber,
                     m.telegramUsername, m.telegramChatId, m.faculty, m.gender]
                    .join(' ').toLowerCase().includes(q));
            }

            function updateStats() {
                statTotal.textContent    = filtered.length;
                statActive.textContent   = filtered.filter(m => m.isActive).length;
                statInactive.textContent = filtered.filter(m => !m.isActive).length;
            }

            function renderList() {
                const tp = Math.max(1, Math.ceil(filtered.length / pageSize));
                pageIndex = Math.min(Math.max(1, pageIndex), tp);
                const slice = filtered.slice((pageIndex-1)*pageSize, pageIndex*pageSize);
                tbody.innerHTML = slice.length === 0
                    ? '<tr><td colspan="10" style="text-align:center;color:#9ca3af;padding:2rem;">No members found.</td></tr>'
                    : slice.map(m => `<tr>
                        <td style="font-weight:500;color:#111827;">${esc(m.fullName)}</td>
                        <td class="muted">${esc(m.email)}</td>
                        <td class="muted">${esc(m.phone)}</td>
                        <td class="muted">${esc(m.memberType)}</td>
                        <td class="muted">${esc(m.diCardNumber)}</td>
                        <td class="muted">${m.telegramUsername ? '\u0040'+esc(m.telegramUsername) : '\u2014'}</td>
                        <td>${m.isActive
                            ? '<span style="display:inline-flex;align-items:center;gap:3px;font-size:.72rem;font-weight:500;background:#dcfce7;color:#166534;border:1px solid #bbf7d0;border-radius:20px;padding:2px 8px;"><i class="bi bi-check-circle-fill"></i>Active</span>'
                            : '<span style="display:inline-flex;align-items:center;gap:3px;font-size:.72rem;font-weight:500;background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;border-radius:20px;padding:2px 8px;"><i class="bi bi-x-circle"></i>Inactive</span>'
                        }</td>
                        <td class="muted">${m.totalLoans} / ${m.activeLoans} active</td>
                        <td class="muted">${esc(m.joinDate)}</td>
                        <td style="white-space:nowrap;display:flex;gap:4px;padding:8px 16px;">
                            <a class="mem-btn" style="padding:4px 10px;font-size:.74rem;" href="/Members/Details/${m.memberId}"><i class="bi bi-eye"></i> Details</a>
                            <a class="mem-btn" style="padding:4px 10px;font-size:.74rem;" href="/Members/Edit/${m.memberId}"><i class="bi bi-pencil-square"></i> Edit</a>
                            <a class="mem-btn" style="padding:4px 10px;font-size:.74rem;" href="/Histories/Index?q=${encodeURIComponent(m.fullName)}"><i class="bi bi-clock-history"></i> History</a>
                            <a class="mem-btn" style="padding:4px 10px;font-size:.74rem;" href="/Members/Delete/${m.memberId}"><i class="bi bi-trash3"></i> Delete</a>
                        </td></tr>`).join('');
                pageInfo.textContent = `Page ${filtered.length ? pageIndex : 0} / ${filtered.length ? tp : 0}`;
                prevBtn.disabled = pageIndex <= 1 || !filtered.length;
                nextBtn.disabled = pageIndex >= tp || !filtered.length;
            }

            function renderCards() {
                const tp = Math.max(1, Math.ceil(filtered.length / cardPageSize));
                cardPageIndex = Math.min(Math.max(1, cardPageIndex), tp);
                const slice = filtered.slice((cardPageIndex-1)*cardPageSize, cardPageIndex*cardPageSize);
                viewCards.innerHTML = slice.map(m => {
                    const avatar = m.profilePicturePath
                        ? esc(m.profilePicturePath)
                        : `https://ui-avatars.com/api/?name=${encodeURIComponent(m.fullName||'M')}&background=60a5fa&color=fff&size=128`;
                    return `
                    <div class="mem-card">
                        <img src="${avatar}" class="mem-card-avatar" alt="${esc(m.fullName)}" onerror="this.src='https://ui-avatars.com/api/?name=M&background=60a5fa&color=fff&size=128'" />
                        <div class="mem-card-body">
                            <div class="mem-card-title">${esc(m.fullName)}</div>
                            <div class="mem-card-meta"><i class="bi bi-envelope"></i>${esc(m.email)||'—'}</div>
                            <div class="mem-card-meta"><i class="bi bi-phone"></i>${esc(m.phone)||'—'}</div>
                            <div class="mem-card-meta"><i class="bi bi-credit-card"></i>${esc(m.diCardNumber)||'—'}</div>
                            ${m.telegramUsername ? '<div class="mem-card-meta"><i class="bi bi-telegram"></i>\u0040'+esc(m.telegramUsername)+'</div>' : ''}
                            <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:4px;margin-top:6px;">
                                <span class="mem-badge mem-badge-type">${esc(m.memberType)||'—'}</span>
                                <span class="mem-badge ${m.isActive ? 'mem-badge-active' : 'mem-badge-inactive'}">
                                    <i class="bi bi-${m.isActive ? 'check-circle-fill' : 'x-circle'}"></i>
                                    ${m.isActive ? 'Active' : 'Inactive'}
                                </span>
                            </div>
                        </div>
                        <div class="mem-card-stats">
                            <span class="mem-card-chip"><i class="bi bi-book"></i>Total ${m.totalLoans}</span>
                            <span class="mem-card-chip"><i class="bi bi-hourglass-split"></i>Active ${m.activeLoans}</span>
                            <span class="mem-card-chip"><i class="bi bi-calendar"></i>${esc(m.joinDate)}</span>
                        </div>
                        <div class="mem-card-actions">
                            <a href="/Members/Details/${m.memberId}"><i class="bi bi-eye"></i>Details</a>
                            <a href="/Members/Edit/${m.memberId}"><i class="bi bi-pencil-square"></i>Edit</a>
                            <a href="/Histories/Index?q=${encodeURIComponent(m.fullName)}"><i class="bi bi-clock-history"></i>History</a>
                            <a href="/Members/Delete/${m.memberId}"><i class="bi bi-trash3"></i>Delete</a>
                        </div>
                    </div>`;
                }).join('');
                cardPageInfo.textContent = `Page ${filtered.length ? cardPageIndex : 0} / ${filtered.length ? tp : 0}`;
                cardPrevBtn.disabled = cardPageIndex <= 1 || !filtered.length;
                cardNextBtn.disabled = cardPageIndex >= tp || !filtered.length;
            }

            function apply() { applyFilter(); updateStats(); viewMode === 'list' ? renderList() : renderCards(); }

            function esc(s) { return s ? String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;') : ''; }

            btns.forEach(b => b.addEventListener('click', () => {
                btns.forEach(x => x.classList.remove('active'));
                b.classList.add('active');
                viewMode = b.getAttribute('data-view');
                if (viewMode === 'cards') {
                    viewCards.style.display = 'grid'; viewList.style.display = 'none';
                    cardPager.style.display = 'flex'; cardPageIndex = 1;
                } else {
                    viewCards.style.display = 'none'; cardPager.style.display = 'none';
                    viewList.style.display = 'block'; pageIndex = 1;
                }
                apply();
            }));

            let st;
            search.addEventListener('input', () => { clearTimeout(st); st = setTimeout(() => { pageIndex = 1; cardPageIndex = 1; apply(); }, 200); });
            clearBtn.addEventListener('click', () => { search.value = ''; search.focus(); pageIndex = 1; cardPageIndex = 1; apply(); });

            prevBtn.addEventListener('click',     () => { pageIndex--;     apply(); });
            nextBtn.addEventListener('click',     () => { pageIndex++;     apply(); });
            cardPrevBtn.addEventListener('click', () => { cardPageIndex--; apply(); });
            cardNextBtn.addEventListener('click', () => { cardPageIndex++; apply(); });

            apply();
        })();
    </script>
}
