@model Guid
@{
    ViewData["Title"] = "Reset Member Password";
    var memberName = ViewBag.MemberName as string ?? "Member";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .mem-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .mem-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .mem-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .mem-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .mem-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .mem-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .mem-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
            pointer-events: none;
        }

    .mem-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .mem-btn-primary:hover {
            background: #00006a;
            color: #fff;
        }

    .mem-form-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        max-width: 540px;
    }

    .mem-form-card-header {
        padding: 16px 24px;
        border-bottom: 1px solid #f3f4f6;
        display: flex;
        align-items: center;
        gap: 8px;
        background: #f9fafb;
    }

        .mem-form-card-header h5 {
            margin: 0;
            font-size: .95rem;
            font-weight: 700;
            color: #111827;
        }

    .mem-form-body {
        padding: 24px;
    }

    .mem-label {
        display: block;
        font-size: .78rem;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 5px;
    }

    .mem-input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        color: #111827;
        background: #fff;
        font-family: 'Inter', sans-serif;
        transition: border-color .15s;
        outline: none;
    }

        .mem-input:focus {
            border-color: #000080;
        }

        .mem-input::placeholder {
            color: #9ca3af;
        }

    .mem-input-group {
        display: flex;
    }

        .mem-input-group .mem-input {
            border-radius: 8px 0 0 8px;
            flex: 1;
        }

    .mem-input-toggle {
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-left: none;
        border-radius: 0 8px 8px 0;
        background: #fff;
        cursor: pointer;
        color: #6b7280;
        font-size: .8rem;
        transition: background .15s;
    }

        .mem-input-toggle:hover {
            background: #f3f4f6;
        }

    .mem-field {
        margin-bottom: 16px;
    }

    .mem-hint-box {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 10px 12px;
        border-radius: 8px;
        font-size: .8rem;
        background: #eff6ff;
        border: 1px solid #bfdbfe;
        color: #1e40af;
        margin-bottom: 20px;
    }

    .mem-pw-meter {
        height: 6px;
        border-radius: 999px;
        background: #e5e7eb;
        overflow: hidden;
        margin-top: 6px;
    }

    .mem-pw-bar {
        height: 100%;
        width: 0%;
        border-radius: 999px;
        transition: width .25s, background .25s;
    }

    .mem-pw-strength {
        font-size: .73rem;
        color: #6b7280;
        margin-top: 4px;
    }

    .mem-match-msg {
        font-size: .75rem;
        margin-top: 4px;
    }

    .mem-match-ok {
        color: #166534;
    }

    .mem-match-err {
        color: #dc2626;
    }

    .mem-form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        padding-top: 20px;
        border-top: 1px solid #f3f4f6;
        margin-top: 4px;
    }
</style>

<div class="mem-page">

    <div class="mem-page-title">Reset Password</div>

    <div class="mem-toolbar">
        <a class="mem-btn" asp-action="Details" asp-route-id="@Model"><i class="bi bi-arrow-left"></i> Back to Details</a>
    </div>

    <div class="mem-form-card">
        <div class="mem-form-card-header">
            <i class="bi bi-key" style="color:#000080;"></i>
            <h5>Reset Password — @memberName</h5>
        </div>
        <div class="mem-form-body">

            <div class="mem-hint-box">
                <i class="bi bi-lightbulb" style="flex-shrink:0;margin-top:1px;"></i>
                <span>Password length 5–20. Recommend at least 8+ with letters, numbers, and symbols.</span>
            </div>

            <form asp-action="ResetPassword" asp-controller="Members" method="post" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model" />
                <div asp-validation-summary="ModelOnly" style="font-size:.8rem;color:#dc2626;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:10px 14px;margin-bottom:14px;"></div>

                <!-- New Password -->
                <div class="mem-field">
                    <label class="mem-label">New Password</label>
                    <div class="mem-input-group">
                        <input id="NewPassword" name="NewPassword" type="password" class="mem-input"
                               placeholder="5–20 characters" required minlength="5" maxlength="20" />
                        <button class="mem-input-toggle" type="button" onclick="togglePw('NewPassword',this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="mem-pw-meter"><div class="mem-pw-bar" id="pwBar"></div></div>
                    <div class="mem-pw-strength" id="pwHint">Strength: —</div>
                </div>

                <!-- Confirm Password -->
                <div class="mem-field">
                    <label class="mem-label">Confirm New Password</label>
                    <div class="mem-input-group">
                        <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="mem-input"
                               required minlength="5" maxlength="20" />
                        <button class="mem-input-toggle" type="button" onclick="togglePw('ConfirmPassword',this)">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="mem-match-msg" id="matchMsg"></div>
                </div>

                <div class="mem-form-actions">
                    <a class="mem-btn" asp-action="Details" asp-route-id="@Model">
                        <i class="bi bi-arrow-left"></i> Cancel
                    </a>
                    <button type="submit" id="submitBtn" class="mem-btn mem-btn-primary" disabled>
                        <i class="bi bi-arrow-clockwise"></i> Reset Password
                    </button>
                </div>
            </form>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        function togglePw(id, btn) {
            var inp = document.getElementById(id);
            if (!inp) return;
            var isPw = inp.type === 'password';
            inp.type = isPw ? 'text' : 'password';
            btn.innerHTML = isPw ? '<i class="bi bi-eye-slash"></i>' : '<i class="bi bi-eye"></i>';
        }

        var newPw = document.getElementById('NewPassword');
        var confPw = document.getElementById('ConfirmPassword');
        var pwBar = document.getElementById('pwBar');
        var pwHint = document.getElementById('pwHint');
        var matchMsg = document.getElementById('matchMsg');
        var submitBtn = document.getElementById('submitBtn');

        function pwScore(pw) {
            if (!pw) return 0;
            var s = 0;
            if (pw.length >= 5) s++;
            if (pw.length >= 8) s++;
            if (/[A-Z]/.test(pw)) s++;
            if (/[a-z]/.test(pw)) s++;
            if (/[0-9]/.test(pw)) s++;
            if (/[^A-Za-z0-9]/.test(pw)) s++;
            return Math.min(s, 5);
        }

        function updateStrength() {
            var pw = newPw.value || '';
            var score = pwScore(pw);
            var configs = [
                { w: '0%',   bg: '#e5e7eb', label: '—' },
                { w: '20%',  bg: '#ef4444', label: 'Very Weak' },
                { w: '40%',  bg: '#ef4444', label: 'Weak' },
                { w: '60%',  bg: '#f59e0b', label: 'Fair' },
                { w: '80%',  bg: '#10b981', label: 'Good' },
                { w: '100%', bg: '#22c55e', label: 'Strong' },
            ];
            var c = configs[score] || configs[0];
            pwBar.style.width = c.w;
            pwBar.style.background = c.bg;
            pwHint.textContent = 'Strength: ' + c.label;
        }

        function validate() {
            var a = newPw.value, b = confPw.value;
            if (b) {
                if (a === b) {
                    matchMsg.className = 'mem-match-msg mem-match-ok';
                    matchMsg.innerHTML = '<i class="bi bi-check-circle-fill"></i> Passwords match';
                } else {
                    matchMsg.className = 'mem-match-msg mem-match-err';
                    matchMsg.innerHTML = '<i class="bi bi-exclamation-circle-fill"></i> Passwords do not match';
                }
            } else {
                matchMsg.textContent = '';
            }
            var lenOk = a.length >= 5 && a.length <= 20;
            submitBtn.disabled = !(lenOk && a && b && a === b);
        }

        ['input', 'keyup', 'change'].forEach(function (evt) {
            newPw.addEventListener(evt, function () { updateStrength(); validate(); });
            confPw.addEventListener(evt, validate);
        });

        updateStrength();
        validate();
    </script>
}
