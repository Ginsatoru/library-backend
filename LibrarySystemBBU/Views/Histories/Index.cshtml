@using LibrarySystemBBU.Models
@model IEnumerable<History>

@{
    ViewData["Title"] = "History";

    string entityType = (string?)ViewData["entityType"] ?? "All";
    string actionType = (string?)ViewData["actionType"] ?? "All";
    string location = (string?)ViewData["location"] ?? "All";
    string q = (string?)ViewData["q"] ?? "";
    string from = (string?)ViewData["from"] ?? "";
    string to = (string?)ViewData["to"] ?? "";

    int total = (int)(ViewData["totalCount"] ?? 0);
    int homeCount = (int)(ViewData["homeCount"] ?? 0);
    int libraryCount = (int)(ViewData["libraryCount"] ?? 0);

    string Active(string current, string value)
        => string.Equals(current, value, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    TimeZoneInfo khTz;
    try { khTz = TimeZoneInfo.FindSystemTimeZoneById("SE Asia Standard Time"); }
    catch { khTz = TimeZoneInfo.FindSystemTimeZoneById("Asia/Bangkok"); }

    Func<DateTime, DateTime> ToKhTime = dt =>
        TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(dt, DateTimeKind.Utc), khTz);
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .hist-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .hist-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .hist-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    /* ---- toolbar ---- */
    .hist-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1rem;
    }

    /* ---- segmented tabs ---- */
    .hist-segmented {
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .hist-seg-btn {
        padding: 6px 14px;
        font-size: .82rem;
        font-weight: 500;
        border: none;
        background: #fff;
        color: #6b7280;
        cursor: pointer;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
        text-decoration: none !important;
        white-space: nowrap;
    }

        .hist-seg-btn:not(:last-child) {
            border-right: 1px solid #e5e7eb;
        }

        .hist-seg-btn:hover {
            background: #f3f4f6;
            color: #111827;
            text-decoration: none !important;
        }

        .hist-seg-btn.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

    /* ---- search ---- */
    .hist-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        background: #fff;
        flex: 1;
        min-width: 200px;
        max-width: 360px;
        transition: border-color .15s;
    }

        .hist-search-wrap:focus-within {
            border-color: #000080;
        }

        .hist-search-wrap i {
            color: #9ca3af;
            font-size: .85rem;
        }

    .hist-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: .83rem;
        color: #111827;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

        .hist-search-input::placeholder {
            color: #9ca3af;
        }

    .hist-search-clear {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        padding: 0;
        font-size: .85rem;
    }

        .hist-search-clear:hover {
            color: #6b7280;
        }

    /* ---- stats / buttons ---- */
    .hist-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
        flex-wrap: wrap;
    }

    .hist-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .hist-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .hist-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none !important;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .hist-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none !important;
        }

    .hist-btn-primary {
        background: #000080;
        color: #fff !important;
        border-color: #000080;
    }

        .hist-btn-primary:hover {
            background: #00006a;
            border-color: #00006a;
        }

    /* ---- filter card ---- */
    .hist-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .hist-card-header {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .hist-filter-row {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .hist-filter-group {
        min-width: 150px;
    }

    .hist-filter-label {
        font-size: .75rem;
        font-weight: 500;
        color: #6b7280;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: .05em;
        display: block;
    }

    .hist-filter-input,
    .hist-filter-select {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        font-family: 'Inter', sans-serif;
        background: #fff;
    }

        .hist-filter-input:focus,
        .hist-filter-select:focus {
            outline: none;
            border-color: #000080;
        }

    .hist-hint {
        font-size: .78rem;
        color: #6b7280;
        margin-top: .5rem;
    }

    /* ---- table ---- */
    .hist-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .hist-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .hist-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .hist-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .hist-table tbody tr:last-child {
                border-bottom: none;
            }

            .hist-table tbody tr:hover {
                background: #f9fafb;
            }

        .hist-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

    /* ---- badges ---- */
    .hist-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: .74rem;
        font-weight: 500;
        white-space: nowrap;
    }

    .hist-badge-home {
        background: #e0f2fe;
        color: #075985;
    }

    .hist-badge-library {
        background: #f3e8ff;
        color: #6b21a8;
    }

    .hist-badge-action {
        background: #f3f4f6;
        color: #374151;
    }

    /* ---- no results ---- */
    #histNoMatches {
        border-radius: 12px;
        background: #fffbeb;
        border: 1px solid #fef3c7;
        color: #92400e;
        padding: 12px 16px;
        margin-top: 1rem;
        font-size: .85rem;
    }

    @@media (max-width: 768px) {
        .hist-toolbar {
            flex-direction: column;
            align-items: stretch;
        }

        .hist-stats {
            margin-left: 0;
        }
    }
</style>

<div class="hist-page">
    <div class="hist-page-title">History</div>

    <!-- Toolbar -->
    <div class="hist-toolbar">
        <!-- Entity tabs -->
        <div class="hist-segmented">
            <button type="button" class="hist-seg-btn js-entity @Active(entityType, "All")" data-value="All">
                <i class="bi bi-collection"></i> All
            </button>
            <button type="button" class="hist-seg-btn js-entity @Active(entityType, "Borrow")" data-value="Borrow">
                <i class="bi bi-journal-arrow-down"></i> Home
            </button>
            <button type="button" class="hist-seg-btn js-entity @Active(entityType, "LibraryLog")" data-value="LibraryLog">
                <i class="bi bi-journal-bookmark"></i> Library
            </button>
            <button type="button" class="hist-seg-btn js-entity @Active(entityType, "Return")" data-value="Return">
                <i class="bi bi-arrow-return-left"></i> Returns
            </button>
        </div>

        <!-- Search -->
        <div class="hist-search-wrap">
            <i class="bi bi-search"></i>
            <input id="qInput" class="hist-search-input" placeholder="Search member, title, notes…" value="@q" />
            <button class="hist-search-clear" type="button" id="clearSearch">
                <i class="bi bi-x-circle"></i>
            </button>
        </div>

        <!-- Stats + export -->
        <div class="hist-stats">
            <span class="hist-stat-pill">
                <i class="bi bi-layers"></i> Total: <strong id="totalSpan">@total</strong>
            </span>
            <span class="hist-stat-pill">
                <i class="bi bi-house"></i> Home: <strong id="homeSpan">@homeCount</strong>
            </span>
            <span class="hist-stat-pill">
                <i class="bi bi-building"></i> Library: <strong id="librarySpan">@libraryCount</strong>
            </span>
            <a asp-action="Export"
               asp-route-entityType="@entityType"
               asp-route-actionType="@actionType"
               asp-route-location="@location"
               asp-route-q="@q"
               asp-route-from="@from"
               asp-route-to="@to"
               asp-route-format="xls"
               class="hist-btn hist-btn-primary">
                <i class="bi bi-file-earmark-excel"></i> Export
            </a>
        </div>
    </div>

    <!-- Filters -->
    <div class="hist-card">
        <div class="hist-filter-row">
            <div class="hist-filter-group">
                <label class="hist-filter-label">From</label>
                <input id="fromInput" value="@from" type="date" class="hist-filter-input" />
            </div>
            <div class="hist-filter-group">
                <label class="hist-filter-label">To</label>
                <input id="toInput" value="@to" type="date" class="hist-filter-input" />
            </div>
            <div class="hist-filter-group">
                <label class="hist-filter-label">Action</label>
                <select id="actionTypeSelect" class="hist-filter-select">
                    <option value="All" selected="@("All".Equals(actionType, StringComparison.OrdinalIgnoreCase))">All</option>
                    <option value="BorrowHome" selected="@("BorrowHome".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Borrow Home</option>
                    <option value="BorrowInLibrary" selected="@("BorrowInLibrary".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Borrow In Library</option>
                    <option value="ReturnHome" selected="@("ReturnHome".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Return (Home)</option>
                    <option value="ReturnLibrary" selected="@("ReturnLibrary".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Return (Library)</option>
                    <option value="Approve" selected="@("Approve".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Approve</option>
                    <option value="Unreturn" selected="@("Unreturn".Equals(actionType, StringComparison.OrdinalIgnoreCase))">Unreturn</option>
                    <option value="ToPending" selected="@("ToPending".Equals(actionType, StringComparison.OrdinalIgnoreCase))">To Pending</option>
                </select>
            </div>
            <div class="hist-filter-group">
                <label class="hist-filter-label">Location</label>
                <select id="locationSelect" class="hist-filter-select">
                    <option value="All" selected="@("All".Equals(location, StringComparison.OrdinalIgnoreCase))">All</option>
                    <option value="Home" selected="@("Home".Equals(location, StringComparison.OrdinalIgnoreCase))">Home</option>
                    <option value="Library" selected="@("Library".Equals(location, StringComparison.OrdinalIgnoreCase))">Library</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="hist-card" style="padding:0;">
        <div style="padding:14px 16px; background:#f9fafb; border-bottom:1px solid #e5e7eb; font-weight:600; color:#111827; display:flex; align-items:center; gap:8px; border-radius:14px 14px 0 0;">
            <i class="bi bi-activity"></i> Timeline
        </div>

        <div style="overflow:auto; max-height:70vh;">
            @if (Model == null || !Model.Any())
            {
                <div style="text-align:center; padding:3rem; color:#9ca3af;">
                    <i class="bi bi-inboxes" style="font-size:2rem;"></i>
                    <div class="mt-2">No history records found.</div>
                </div>
            }
            else
            {
                <table class="hist-table" id="historyTable">
                    <thead>
                        <tr>
                            <th>Time (KH)</th>
                            <th>Action</th>
                            <th>Location</th>
                            <th>Member</th>
                            <th>Book / Catalog</th>
                            <th>Qty</th>
                            <th style="text-align:right;">Fees / Fines</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model)
                        {
                            string mainTitle = !string.IsNullOrWhiteSpace(h.BookTitle)
                            ? h.BookTitle!
                            : (!string.IsNullOrWhiteSpace(h.CatalogTitle) ? h.CatalogTitle! : "-");

                            string feeText = "";
                            if (h.BorrowingFee.HasValue && h.BorrowingFee.Value != 0) feeText += "B: " + h.BorrowingFee.Value.ToString("0.00") + "  ";
                            if (h.FineAmount.HasValue && h.FineAmount.Value != 0) feeText += "F: " + h.FineAmount.Value.ToString("0.00") + "  ";
                            if (h.AmountPaid.HasValue && h.AmountPaid.Value != 0) feeText += "P: " + h.AmountPaid.Value.ToString("0.00") + "  ";
                            if (h.DepositAmount.HasValue && h.DepositAmount.Value != 0) feeText += "D: " + h.DepositAmount.Value.ToString("0.00") + "  ";
                            if (string.IsNullOrWhiteSpace(feeText)) feeText = "-";

                            string actionLabel;
                            if (h.ActionType == "BorrowHome") actionLabel = "Borrow (Home)";
                            else if (h.ActionType == "BorrowInLibrary") actionLabel = "Borrow (Library)";
                            else if (h.ActionType == "ReturnHome") actionLabel = "Return (Home)";
                            else if (h.ActionType == "ReturnLibrary") actionLabel = "Return (Library)";
                            else if (h.ActionType == "Approve") actionLabel = "Approve";
                            else if (h.ActionType == "Unreturn") actionLabel = "Unreturn";
                            else if (h.ActionType == "ToPending") actionLabel = "To Pending";
                            else actionLabel = h.ActionType ?? "-";

                            var localTime = ToKhTime(h.OccurredUtc);
                            var localDateString = localTime.ToString("yyyy-MM-dd");

                            string locBadgeClass;
                            if (h.LocationType == "Home") locBadgeClass = "hist-badge-home";
                            else if (h.LocationType == "Library") locBadgeClass = "hist-badge-library";
                            else locBadgeClass = "";

                            <tr data-entity="@h.EntityType"
                                data-action="@h.ActionType"
                                data-location="@h.LocationType"
                                data-member="@h.MemberName"
                                data-book="@h.BookTitle"
                                data-catalog="@h.CatalogTitle"
                                data-notes="@h.Notes"
                                data-date="@localDateString">
                                <td style="white-space:nowrap;">@localTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <span class="hist-badge hist-badge-action">@actionLabel</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(h.LocationType))
                                    {
                                        <span class="hist-badge @locBadgeClass">@h.LocationType</span>
                                    }
                                    else
                                    {
                                        <text>-</text>
                                    }
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(h.MemberName) ? "-" : h.MemberName)</td>
                                <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@mainTitle</td>
                                <td>@(h.Quantity?.ToString() ?? "-")</td>
                                <td style="text-align:right; white-space:nowrap;">@feeText</td>
                                <td style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                    @(string.IsNullOrWhiteSpace(h.Notes) ? "-" : h.Notes)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    <div id="histNoMatches" style="display:none;">
        <i class="bi bi-question-circle"></i> No matching results for your search.
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var entityField    = document.getElementById('entityTypeField');
            var qInput         = document.getElementById('qInput');
            var clearSearch    = document.getElementById('clearSearch');
            var fromInput      = document.getElementById('fromInput');
            var toInput        = document.getElementById('toInput');
            var actionSelect   = document.getElementById('actionTypeSelect');
            var locationSelect = document.getElementById('locationSelect');
            var btnApply       = document.getElementById('btnApplyFilters');
            var totalSpan      = document.getElementById('totalSpan');
            var homeSpan       = document.getElementById('homeSpan');
            var librarySpan    = document.getElementById('librarySpan');
            var noMatches      = document.getElementById('histNoMatches');

            // hidden field to track active entity tab
            var entityVal = '@entityType';

            function applyFilters() {
                var q       = (qInput.value || '').trim().toLowerCase();
                var fromVal = fromInput.value;
                var toVal   = toInput.value;
                var actVal  = actionSelect.value  || 'All';
                var locVal  = locationSelect.value || 'All';

                var fromDate = fromVal ? new Date(fromVal) : null;
                var toDate   = toVal   ? new Date(toVal)   : null;

                var rows = document.querySelectorAll('#historyTable tbody tr');
                var total = 0, home = 0, library = 0;

                rows.forEach(function (row) {
                    var rowEntity  = (row.dataset.entity   || '').trim();
                    var rowAction  = (row.dataset.action   || '').trim();
                    var rowLoc     = (row.dataset.location || '').trim();
                    var rowMember  = (row.dataset.member   || '').toLowerCase();
                    var rowBook    = (row.dataset.book     || '').toLowerCase();
                    var rowCatalog = (row.dataset.catalog  || '').toLowerCase();
                    var rowNotes   = (row.dataset.notes    || '').toLowerCase();
                    var rowDate    = row.dataset.date ? new Date(row.dataset.date) : null;

                    var visible = true;

                            if (entityVal !== 'All') {
            if (entityVal === 'Return') {
                if (rowAction !== 'ReturnHome' && rowAction !== 'ReturnLibrary') visible = false;
            } else if (entityVal === 'Loan') {
                if (rowEntity !== 'Loan') visible = false;
            } else if (entityVal === 'LibraryLog') {
                if (rowEntity !== 'LibraryLog') visible = false;
            } else {
                if (rowEntity !== entityVal) visible = false;
            }
        }
                    if (visible && actVal !== 'All' && rowAction !== actVal)    visible = false;
                    if (visible && locVal !== 'All' && rowLoc !== locVal)       visible = false;
                    if (visible && fromDate && rowDate && rowDate < fromDate)   visible = false;
                    if (visible && toDate   && rowDate && rowDate > toDate)     visible = false;
                    if (visible && q) {
                        var text = rowMember + ' ' + rowBook + ' ' + rowCatalog + ' ' + rowNotes;
                        if (!text.includes(q)) visible = false;
                    }

                    row.style.display = visible ? '' : 'none';

                    if (visible) {
                        total++;
                        if (rowLoc === 'Home')    home++;
                        if (rowLoc === 'Library') library++;
                    }
                });

                totalSpan.textContent   = total.toString();
                homeSpan.textContent    = home.toString();
                librarySpan.textContent = library.toString();

                noMatches.style.display = (total === 0) ? '' : 'none';
            }

            // Entity tab clicks
            document.querySelectorAll('.js-entity').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    entityVal = btn.getAttribute('data-value') || 'All';
                    document.querySelectorAll('.js-entity').forEach(function (b) {
                        b.classList.remove('active');
                    });
                    btn.classList.add('active');
                    applyFilters();
                });
            });

            qInput.addEventListener('input', applyFilters);

            clearSearch.addEventListener('click', function () {
                qInput.value = '';
                qInput.focus();
                applyFilters();
            });

            fromInput.addEventListener('change',      applyFilters);
            toInput.addEventListener('change',        applyFilters);
            actionSelect.addEventListener('change',   applyFilters);
            locationSelect.addEventListener('change', applyFilters);
            btnApply.addEventListener('click',        applyFilters);

            applyFilters();
        })();
    </script>
}
