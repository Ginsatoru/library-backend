@model LibrarySystemBBU.Models.ReturnReceiptVm
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Return Receipt - @Model.ReturnId</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #fff;
            color: #111827;
        }

        /* Hide everything on screen — only show on print */
        .receipt-wrapper {
            display: none;
        }

        @@media print {
            body {
                background: #fff;
            }

            .receipt-wrapper {
                display: block;
                max-width: 600px;
                margin: 0 auto;
                padding: 20px;
            }

            .receipt-header {
                text-align: center;
                margin-bottom: 24px;
                padding-bottom: 16px;
                border-bottom: 1px solid #e5e7eb;
            }

            .receipt-title {
                font-size: 1.5rem;
                font-weight: 700;
                color: #000080;
                margin-bottom: 4px;
            }

            .receipt-subtitle {
                font-size: .8rem;
                color: #6b7280;
            }

            .info-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 12px;
                margin-bottom: 24px;
            }

            .info-item {
                font-size: .85rem;
            }

            .info-label {
                color: #6b7280;
                margin-bottom: 2px;
            }

            .info-value {
                font-weight: 600;
                color: #111827;
            }

            .section-title {
                font-size: 1rem;
                font-weight: 600;
                color: #000080;
                margin-bottom: 12px;
            }

            .books-list {
                list-style: none;
                padding: 0;
                margin: 0 0 24px;
            }

                .books-list li {
                    padding: 8px 12px;
                    background: #f9fafb;
                    border: 1px solid #e5e7eb;
                    border-radius: 8px;
                    margin-bottom: 6px;
                    font-size: .85rem;
                }

            .finance-table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 24px;
            }

                .finance-table td {
                    padding: 8px 12px;
                    font-size: .85rem;
                    border-bottom: 1px solid #f3f4f6;
                }

                    .finance-table td:first-child {
                        font-weight: 500;
                        color: #6b7280;
                    }

                    .finance-table td:last-child {
                        font-weight: 600;
                        text-align: right;
                    }

                .finance-table tr:last-child td {
                    border-bottom: none;
                    padding-top: 12px;
                    font-size: .95rem;
                    color: #000080;
                }

            .note {
                background: #fffbeb;
                border: 1px solid #fef3c7;
                border-radius: 8px;
                padding: 12px;
                font-size: .8rem;
                color: #92400e;
                margin-bottom: 24px;
            }

            .footer {
                text-align: center;
                font-size: .75rem;
                color: #9ca3af;
                padding-top: 16px;
                border-top: 1px solid #e5e7eb;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-wrapper">
        <div class="receipt-header">
            <div class="receipt-title">Return Receipt</div>
            <div class="receipt-subtitle">Return #@Model.ReturnId</div>
        </div>

        <div class="info-grid">
            <div class="info-item">
                <div class="info-label">Borrow #</div>
                <div class="info-value">@Model.LoanId</div>
            </div>
            <div class="info-item">
                <div class="info-label">Member</div>
                <div class="info-value">@Model.MemberName</div>
            </div>
            <div class="info-item">
                <div class="info-label">Borrow Date</div>
                <div class="info-value">@Model.LoanDate.ToString("yyyy-MM-dd")</div>
            </div>
            <div class="info-item">
                <div class="info-label">Due Date</div>
                <div class="info-value">@Model.DueDate.ToString("yyyy-MM-dd")</div>
            </div>
            <div class="info-item">
                <div class="info-label">Return Date</div>
                <div class="info-value">@Model.ReturnDate.ToString("yyyy-MM-dd")</div>
            </div>
        </div>

        <div class="section-title">Books Returned</div>
        <ul class="books-list">
            @foreach (var title in Model.BookTitles)
            {
                <li>@title</li>
            }
        </ul>

        <div class="section-title">Financial Summary</div>
        <table class="finance-table">
            <tr>
                <td>Borrowing Fee</td>
                <td>$@Model.BorrowingFee.ToString("0.00")</td>
            </tr>
            <tr>
                <td>Deposit</td>
                <td>$@(Model.DepositAmount?.ToString("0.00") ?? "0.00")</td>
            </tr>
            <tr>
                <td>Late Days</td>
                <td>@Model.LateDays</td>
            </tr>
            <tr>
                <td>Fine Amount</td>
                <td>$@Model.FineAmount.ToString("0.00")</td>
            </tr>
            <tr>
                <td>Extra Charge</td>
                <td>$@Model.ExtraCharge.ToString("0.00")</td>
            </tr>
            <tr>
                <td>Total Paid (Fine + Extra)</td>
                <td>$@Model.AmountPaid.ToString("0.00")</td>
            </tr>
            <tr>
                <td style="color:#000080;">Refund Amount</td>
                <td style="color:#000080;">$@(Model.RefundAmount?.ToString("0.00") ?? "0.00")</td>
            </tr>
        </table>

        @if (!string.IsNullOrWhiteSpace(Model.ConditionOnReturn) || !string.IsNullOrWhiteSpace(Model.Notes))
        {
            <div class="section-title">Condition & Notes</div>
            <table class="finance-table">
                @if (!string.IsNullOrWhiteSpace(Model.ConditionOnReturn))
                {
                    <tr>
                        <td>Condition on Return</td>
                        <td>@Model.ConditionOnReturn</td>
                    </tr>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <tr>
                        <td>Notes</td>
                        <td>@Model.Notes</td>
                    </tr>
                }
            </table>
        }

        <div class="note">
            This receipt is for the member as proof of return. You do not need to bring this receipt back to the library.
        </div>

        <div class="footer">
            Printed on @DateTime.Now.ToString("yyyy-MM-dd HH:mm")
        </div>
    </div>

    <script>
        window.onload = function () {
            window.print();
            window.addEventListener('afterprint', function () {
                window.close();
            });
        };
    </script>
</body>
</html>
