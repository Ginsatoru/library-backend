@model LibrarySystemBBU.Models.BookBorrow
@{
    ViewData["Title"] = "Delete Loan";
}

<form id="__af" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .borrow-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .borrow-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .borrow-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .borrow-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .borrow-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .borrow-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

    .borrow-btn-danger {
        background: #fee2e2;
        color: #991b1b;
        border-color: #fecaca;
    }

        .borrow-btn-danger:hover {
            background: #fecaca;
            color: #7f1d1d;
        }

    .borrow-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .borrow-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .borrow-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .borrow-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
    }

    .borrow-info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .borrow-info-label {
        font-size: .75rem;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .borrow-info-value {
        font-size: .95rem;
        font-weight: 500;
        color: #111827;
    }

    .borrow-alert-danger {
        background: #fee2e2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 1rem;
        color: #991b1b;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .borrow-checkbox {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

        .borrow-checkbox input {
            width: 16px;
            height: 16px;
            cursor: pointer;
        }
</style>

<div class="borrow-page">
    <div class="borrow-page-title">Delete Borrowed #@Model.LoanId</div>

    <div class="borrow-toolbar">
        <a asp-action="Index" class="borrow-btn">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
        <div class="ms-auto d-flex gap-2">
            <span class="borrow-stat-pill">
                <i class="bi bi-calendar3"></i> Date: <strong>@Model.LoanDate.ToString("yyyy-MM-dd")</strong>
            </span>
            <span class="borrow-stat-pill">
                <i class="bi bi-person"></i> Member: <strong>@(Model.LibraryMember?.FullName ?? "—")</strong>
            </span>
        </div>
    </div>

    <div class="borrow-alert-danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div>
            <strong>Are you sure?</strong><br />
            Deleting this borrowed will also delete its item details and return records. This action cannot be undone.
        </div>
    </div>

    <div class="borrow-card">
        <div class="borrow-info-grid">
            <div class="borrow-info-item">
                <span class="borrow-info-label">Member</span>
                <span class="borrow-info-value">@(Model.LibraryMember?.FullName ?? "—")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Borrow Date</span>
                <span class="borrow-info-value">@Model.LoanDate.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Due Date</span>
                <span class="borrow-info-value">@Model.DueDate.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Borrowing Fee</span>
                <span class="borrow-info-value">@Model.BorrowingFee.ToString("0.00") ៛</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Deposit</span>
                <span class="borrow-info-value">@(Model.DepositAmount?.ToString("0.00") ?? "0.00") ៛</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Items Count</span>
                <span class="borrow-info-value">@(Model.LoanBookDetails?.Count ?? 0)</span>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 align-items-center">
        <label class="borrow-checkbox">
            <input type="checkbox" id="confirmChk">
            <span>I understand this will permanently delete this borrow.</span>
        </label>
        <button type="button" id="btnDelete" class="borrow-btn borrow-btn-danger" disabled>
            <i class="bi bi-trash3"></i> Delete
        </button>
        <a asp-action="Index" class="borrow-btn">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header" style="background:#fee2e2; border-bottom:1px solid #fecaca;">
                <h5 class="modal-title d-flex align-items-center gap-2" style="color:#991b1b;">
                    <i class="bi bi-trash3"></i> Confirm Deletion
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding:1.5rem;">
                You are about to permanently delete this borrow. This cannot be undone.
            </div>
            <div class="modal-footer" style="border-top:1px solid #e5e7eb;">
                <button type="button" class="borrow-btn" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="borrow-btn borrow-btn-danger" id="confirmDelete">
                    <i class="bi bi-trash3"></i> Yes, delete it
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function() {
            function getToken() {
                const el = document.querySelector('#__af input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            const chk = document.getElementById('confirmChk');
            const btn = document.getElementById('btnDelete');
            const modalEl = document.getElementById('confirmModal');
            const confirmBtn = document.getElementById('confirmDelete');

            if (chk && btn) {
                chk.addEventListener('change', () => {
                    btn.disabled = !chk.checked;
                });
            }

            if (btn && modalEl) {
                btn.addEventListener('click', () => {
                    const modal = new bootstrap.Modal(modalEl);
                    modal.show();
                });
            }

            if (confirmBtn) {
                confirmBtn.addEventListener('click', function() {
                    fetch('/BookBorrows/Delete/@Model.LoanId', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getToken()
                        },
                        body: '{}'
                    }).then(async rsp => {
                        if (rsp.ok) {
                            const modal = bootstrap.Modal.getInstance(modalEl);
                            if (modal) modal.hide();

                            await Swal.fire({
                                title: 'Deleted!',
                                text: 'Loan deleted successfully.',
                                icon: 'success',
                                confirmButtonColor: '#000080'
                            });
                            window.location.href = '@Url.Action("Index", "BookBorrows")';
                        } else {
                            const msg = await rsp.text();
                            Swal.fire({
                                title: 'Error',
                                text: msg || 'Delete failed.',
                                icon: 'error',
                                confirmButtonColor: '#000080'
                            });
                        }
                    }).catch(() => {
                        Swal.fire({
                            title: 'Error',
                            text: 'Network error.',
                            icon: 'error',
                            confirmButtonColor: '#000080'
                        });
                    });
                });
            }
        })();
    </script>
}