@model LibrarySystemBBU.Models.BookBorrow
@{
    ViewData["Title"] = "Loan Details";
    var today = DateTime.Today;
}

<form id="__af" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .borrow-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .borrow-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .borrow-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .borrow-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .borrow-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .borrow-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

    .borrow-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .borrow-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .borrow-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .borrow-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .borrow-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 1.25rem;
        margin-bottom: 1rem;
    }

    .borrow-section-title {
        font-size: 1rem;
        font-weight: 600;
        color: #111827;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .borrow-info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
    }

    .borrow-info-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .borrow-info-label {
        font-size: .75rem;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .borrow-info-value {
        font-size: .95rem;
        font-weight: 500;
        color: #111827;
    }

    .borrow-status {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .74rem;
        font-weight: 500;
    }

    .status-success {
        background: #dcfce7;
        color: #166534;
    }

    .status-warning {
        background: #fef3c7;
        color: #92400e;
    }

    .status-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .borrow-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
    }

    .borrow-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .borrow-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .borrow-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
            border-bottom: 1px solid #f3f4f6;
        }

        .borrow-table tbody tr:last-child td {
            border-bottom: none;
        }

    /* SweetAlert2 styles */
    .swal2-container {
        z-index: 10000 !important;
    }

    .swal2-popup.borrow-popup {
        border-radius: 14px;
        padding: 1.4rem;
        border: 1px solid #e5e7eb;
        font-family: 'Inter', sans-serif;
    }

    .return-dialog {
        text-align: left;
    }

    .return-label {
        font-size: .8rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: .25rem;
    }

    .return-input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        margin-bottom: .75rem;
    }

        .return-input:focus {
            outline: none;
            border-color: #000080;
        }

    .return-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .75rem;
    }

    .return-summary {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem;
        font-size: .85rem;
        margin-bottom: .75rem;
    }

        .return-summary strong {
            color: #000080;
        }
</style>

<div class="borrow-page">
    @if (TempData["Msg"] != null)
    {
        <div class="alert alert-info" style="border-radius:12px;">@TempData["Msg"]</div>
    }

    <div class="borrow-page-title">Borrow Book's Details</div>

    <div class="borrow-toolbar">
        <div class="borrow-stat-pill">
            <i class="bi bi-info-circle"></i> Quick overview of the Borrow, items, and returns.
        </div>
        <div class="ms-auto d-flex gap-2">
            @if (!Model.IsReturned)
            {
                <button type="button" class="borrow-btn borrow-btn-primary btn-return"
                        data-loanid="@Model.LoanId"
                        data-deposit="@(Model.DepositAmount?.ToString("0.00") ?? "0")">
                    <i class="bi bi-arrow-return-left"></i> Return
                </button>
            }
            <a asp-action="Edit" asp-route-id="@Model.LoanId" class="borrow-btn">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
            <a asp-action="Index" class="borrow-btn">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- HEADER SUMMARY -->
    <div class="borrow-card">
        <div class="borrow-section-title">
            <i class="bi bi-clipboard-data"></i> Borrow Summary
        </div>
        <div class="borrow-info-grid">
            <div class="borrow-info-item">
                <span class="borrow-info-label">Borrowing Fee</span>
                <span class="borrow-info-value">$@Model.BorrowingFee.ToString("0.00")</span>
            </div>
            ...
            <div class="borrow-info-item">
                <span class="borrow-info-label">Deposit</span>
                <span class="borrow-info-value">$@(Model.DepositAmount?.ToString("0.00") ?? "-")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Borrow Date</span>
                <span class="borrow-info-value">@Model.LoanDate.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Due Date</span>
                <span class="borrow-info-value">@Model.DueDate.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Status</span>
                <span class="borrow-info-value">
                    @if (Model.IsReturned)
                    {
                        <span class="borrow-status status-success">
                            <i class="bi bi-check-circle-fill"></i> Returned
                        </span>
                    }
                    else if (Model.DueDate.Date <= today)
                    {
                        <span class="borrow-status status-danger">
                            <i class="bi bi-exclamation-octagon-fill"></i> Overdue
                        </span>
                    }
                    else
                    {
                        <span class="borrow-status status-warning">
                            <i class="bi bi-hourglass-split"></i> In Progress
                        </span>
                    }
                </span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Borrowing Fee</span>
                <span class="borrow-info-value">@Model.BorrowingFee.ToString("0.00") ៛</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Paid</span>
                <span class="borrow-info-value">@(Model.IsPaid ? "Yes" : "No")</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Deposit</span>
                <span class="borrow-info-value">@(Model.DepositAmount?.ToString("0.00") ?? "-") ៛</span>
            </div>
            <div class="borrow-info-item">
                <span class="borrow-info-label">Items / Returns</span>
                <span class="borrow-info-value">@((Model.LoanBookDetails?.Count ?? 0)) / @((Model.BookReturns?.Count ?? 0))</span>
            </div>
        </div>
    </div>

    <!-- ITEMS -->
    <div class="borrow-card">
        <div class="borrow-section-title">
            <i class="bi bi-journal-bookmark"></i> Borrow Items
        </div>
        <div class="borrow-table-wrap">
            <table class="borrow-table">
                <thead>
                    <tr>
                        <th>Book</th>
                        <th>Catalog</th>
                        <th>Condition Out</th>
                        <th>Condition In</th>
                        <th>Fine</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.LoanBookDetails != null && Model.LoanBookDetails.Any())
                    {
                        foreach (var d in Model.LoanBookDetails)
                        {
                            <tr>
                                <td>@(d.Book != null ? d.Book.Barcode : d.BookId.ToString())</td>
                                <td>@(string.IsNullOrWhiteSpace(d.Book?.Catalog?.Title) ? d.CatalogId.ToString() : d.Book!.Catalog!.Title)</td>
                                <td>@d.ConditionOut</td>
                                <td>@d.ConditionIn</td>
                                <td>@(d.FineDetailAmount?.ToString("0.00") ?? "-")</td>
                                <td>@d.FineDetailReason</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="text-align:center; color:#9ca3af; padding:2rem;">No items.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- RETURNS -->
    <div class="borrow-card">
        <div class="borrow-section-title">
            <i class="bi bi-arrow-return-left"></i> Returns
        </div>
        <div class="borrow-table-wrap">
            <table class="borrow-table">
                <thead>
                    <tr>
                        <th>Return Date</th>
                        <th>Late Days</th>
                        <th>Fine</th>
                        <th>Extra Charge</th>
                        <th>Amount Paid</th>
                        <th>Refund</th>
                        <th>Condition</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.BookReturns != null && Model.BookReturns.Any())
                    {
                        foreach (var r in Model.BookReturns.OrderByDescending(x => x.ReturnDate))
                        {
                            <tr>
                                <td>@r.ReturnDate.ToString("yyyy-MM-dd")</td>
                                <td>@r.LateDays</td>
                                <td>$@r.FineAmount.ToString("0.00")</td>
                                <td>$@r.ExtraCharge.ToString("0.00")</td>
                                <td>$@r.AmountPaid.ToString("0.00")</td>
                                <td>$@(r.RefundAmount?.ToString("0.00") ?? "-")</td>
                                <td>@r.ConditionOnReturn</td>
                                <td>@r.Notes</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" style="text-align:center; color:#9ca3af; padding:2rem;">No returns recorded.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function() {
            function getToken() {
                const el = document.querySelector('#__af input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            const swalTheme = {
                buttonsStyling: false,
                customClass: {
                    popup: 'swal2-popup borrow-popup',
                    confirmButton: 'borrow-btn borrow-btn-primary',
                    cancelButton: 'borrow-btn'
                }
            };

            const btn = document.querySelector('.btn-return');
            if (!btn) return;

            btn.addEventListener('click', function() {
                const loanId = this.getAttribute('data-loanid');
                const depositStr = this.getAttribute('data-deposit') || "0";
                const deposit = parseFloat(depositStr) || 0;

                Swal.fire({
                    title: `Return Loan #${loanId}`,
                    html: `
                        <div class="return-dialog">
                            <div>
                                <label class="return-label">Return Date</label>
                                <input id="r-date" type="date" class="return-input"
                                       value="${new Date().toISOString().slice(0, 10)}" />
                            </div>

                            <div class="return-grid">
                                <div>
                                    <label class="return-label">Late Days</label>
                                    <input id="r-late" type="number" class="return-input" value="0" min="0" />
                                </div>
                                <div>
                                    <label class="return-label">Fine Amount ($)</label>
                                    <input id="r-fine" type="number" class="return-input" step="0.01" value="0" min="0" />
                                </div>
                                <div>
                                    <label class="return-label">Extra Charge ($)</label>
                                    <input id="r-extra" type="number" class="return-input" step="0.01" value="0" min="0" />
                                </div>
                            </div>

                            <div id="r-summary" class="return-summary"></div>

                            <div>
                                <label class="return-label">Condition</label>
                                <input id="r-cond" class="return-input" placeholder="Condition on return" />
                            </div>

                            <div>
                                <label class="return-label">Notes</label>
                                <textarea id="r-notes" class="return-input" rows="2" placeholder="Notes"></textarea>
                            </div>
                        </div>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Confirm Return',
                    cancelButtonText: 'Cancel',
                    ...swalTheme,
                    didOpen: () => {
                        const fineInput = document.getElementById('r-fine');
                        const extraInput = document.getElementById('r-extra');
                        const summary = document.getElementById('r-summary');

                        function updateSummary() {
                            const fine = parseFloat(fineInput.value || '0');
                            const extra = parseFloat(extraInput.value || '0');
                            const paid = fine + extra;

                            summary.innerHTML = `
                                <div>Deposit: <strong>$${deposit.toFixed(2)}</strong></div>
                                <div>Fine + Extra: <strong>$${paid.toFixed(2)}</strong></div>
                                <div style="color:#000080; font-weight:600; margin-top:4px;">
                                    Refund: $${(deposit - paid).toFixed(2)}
                                </div>
                            `;
                        }

                        fineInput.addEventListener('input', updateSummary);
                        extraInput.addEventListener('input', updateSummary);
                        updateSummary();
                    },
                    preConfirm: () => {
                        const date = document.getElementById('r-date').value;
                        if (!date) {
                            Swal.showValidationMessage('Return date is required');
                            return false;
                        }

                        return {
                            LoanId: parseInt(loanId),
                            ReturnDate: date,
                            LateDays: parseInt(document.getElementById('r-late').value || '0'),
                            FineAmount: parseFloat(document.getElementById('r-fine').value || '0'),
                            ExtraCharge: parseFloat(document.getElementById('r-extra').value || '0'),
                            ConditionOnReturn: document.getElementById('r-cond').value || null,
                            Notes: document.getElementById('r-notes').value || null
                        };
                    }
                }).then(res => {
                    if (!res.isConfirmed) return;

                    fetch('/BookBorrows/Return/' + loanId, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': getToken()
                        },
                        body: JSON.stringify(res.value)
                    }).then(async rsp => {
                        if (!rsp.ok) {
                            return Swal.fire({ title: 'Error', text: 'Return failed', icon: 'error', ...swalTheme });
                        }

                        const data = await rsp.json();

                        return Swal.fire({
                            title: 'Returned!',
                            text: 'Return recorded successfully. Print receipt?',
                            icon: 'success',
                            showCancelButton: true,
                            confirmButtonText: 'Yes, Print',
                            cancelButtonText: 'No',
                            ...swalTheme
                        }).then(result => {
                            if (result.isConfirmed && data.loanId) {
                                window.open('/BookBorrows/ReturnReceipt/' + data.loanId, '_blank');
                            }
                            location.reload();
                        });
                    });
                });
            });
        })();
    </script>
}