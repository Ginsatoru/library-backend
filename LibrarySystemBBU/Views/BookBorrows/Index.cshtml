@using Microsoft.AspNetCore.Mvc.Rendering
@model IEnumerable<LibrarySystemBBU.Models.BookBorrow>

@{
    ViewData["Title"] = "Book Borrow";
    var today = DateTime.Today;
    var returnedCount = Model.Count(x => x.IsReturned);
    var notReturnedCount = Model.Count(x => !x.IsReturned);
    var dueTodayCount = Model.Count(x => !x.IsReturned && x.DueDate.Date <= today);

    var memberOptions = (IEnumerable<SelectListItem>)(ViewBag.MemberId ?? new List<SelectListItem>());
    var bookOptions = (IEnumerable<SelectListItem>)(ViewBag.BookId ?? new List<SelectListItem>());
    var catalogOptions = (IEnumerable<SelectListItem>)(ViewBag.CatalogId ?? new List<SelectListItem>());
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .borrow-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .borrow-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .borrow-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #000080;
            display: inline-block;
            flex-shrink: 0;
        }

    .borrow-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.5rem;
    }

    .borrow-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s, border-color .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .borrow-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

    .borrow-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .borrow-btn-primary:hover {
            background: #00006a;
            color: #fff;
            border-color: #00006a;
        }

    .borrow-segmented {
        display: flex;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .borrow-seg-btn {
        padding: 6px 14px;
        font-size: .82rem;
        font-weight: 500;
        border: none;
        background: #fff;
        color: #6b7280;
        cursor: pointer;
        transition: background .15s, color .15s;
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: 'Inter', sans-serif;
    }

        .borrow-seg-btn:not(:last-child) {
            border-right: 1px solid #e5e7eb;
        }

        .borrow-seg-btn.active {
            background: #f3f4f6;
            color: #111827;
            font-weight: 600;
        }

    .borrow-search-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 6px 12px;
        background: #fff;
        flex: 1;
        min-width: 200px;
        max-width: 360px;
        transition: border-color .15s;
    }

        .borrow-search-wrap:focus-within {
            border-color: #000080;
        }

        .borrow-search-wrap i {
            color: #9ca3af;
            font-size: .85rem;
        }

    .borrow-search-input {
        border: none;
        outline: none;
        background: transparent;
        font-size: .83rem;
        color: #111827;
        width: 100%;
        font-family: 'Inter', sans-serif;
    }

        .borrow-search-input::placeholder {
            color: #9ca3af;
        }

    .borrow-search-clear {
        background: none;
        border: none;
        cursor: pointer;
        color: #d1d5db;
        padding: 0;
        font-size: .85rem;
    }

        .borrow-search-clear:hover {
            color: #6b7280;
        }

    .borrow-stats {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-left: auto;
        flex-wrap: wrap;
    }

    .borrow-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .borrow-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .borrow-table-wrap {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        overflow: hidden;
        margin-bottom: 1rem;
    }

    .borrow-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .83rem;
    }

        .borrow-table thead th {
            padding: 11px 16px;
            text-align: left;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .75rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        .borrow-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
            transition: background .1s;
        }

            .borrow-table tbody tr:last-child {
                border-bottom: none;
            }

            .borrow-table tbody tr:hover {
                background: #f9fafb;
            }

        .borrow-table tbody td {
            padding: 11px 16px;
            color: #374151;
            vertical-align: middle;
        }

            .borrow-table tbody td.muted {
                color: #6b7280;
            }

    .borrow-actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .borrow-action-btn {
        padding: 4px 10px;
        font-size: .74rem;
        border-radius: 6px;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: background .15s;
        white-space: nowrap;
    }

        .borrow-action-btn:hover {
            background: #f3f4f6;
            color: #111827;
            text-decoration: none;
        }

    .borrow-action-btn-primary {
        background: #000080;
        color: #fff;
        border-color: #000080;
    }

        .borrow-action-btn-primary:hover {
            background: #00006a;
            color: #fff;
        }

    .borrow-action-btn-success {
        background: #f0fdf4;
        color: #15803d;
        border-color: #bbf7d0;
    }

        .borrow-action-btn-success:hover {
            background: #dcfce7;
            color: #166534;
        }

    .borrow-status {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: .74rem;
        font-weight: 500;
    }

    .status-success {
        background: #dcfce7;
        color: #166534;
    }

    .status-warning {
        background: #fef3c7;
        color: #92400e;
    }

    .status-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    /* SweetAlert2 styles */
    .swal2-container {
        z-index: 10000 !important;
    }

        .swal2-container.swal2-backdrop-show {
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            background: rgba(0,0,0,0.3);
        }

    .swal2-popup.borrow-popup {
        border-radius: 14px;
        padding: 1.4rem;
        border: 1px solid #e5e7eb;
        font-family: 'Inter', sans-serif;
    }

    .borrow-dialog {
        text-align: left;
        font-size: .9rem;
    }

    .borrow-dialog-label {
        display: block;
        font-size: .8rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: .25rem;
    }

    .borrow-dialog-input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        font-size: .85rem;
        margin-bottom: .75rem;
    }

        .borrow-dialog-input:focus {
            outline: none;
            border-color: #000080;
        }

    .borrow-dialog-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .75rem;
        margin-bottom: .75rem;
    }

    .borrow-dialog-summary {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: .75rem;
        font-size: .85rem;
        margin-bottom: .75rem;
    }

        .borrow-dialog-summary div {
            margin-bottom: .25rem;
        }

        .borrow-dialog-summary strong {
            color: #000080;
        }

    .btn-confirm {
        background: #000080;
        color: #fff;
        border: none;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 500;
    }

    .btn-cancel {
        background: #fff;
        color: #374151;
        border: 1px solid #e5e7eb;
        padding: 8px 16px;
        border-radius: 8px;
        font-weight: 500;
    }
</style>

<div class="borrow-page">
    <div class="borrow-page-title">Book Borrow</div>

    <div class="borrow-toolbar">
        <a asp-action="Create" class="borrow-btn borrow-btn-primary" id="btn-create-link">
            <i class="bi bi-plus-circle"></i> Create Borrow
        </a>

        <div class="borrow-segmented">
            <button type="button" class="borrow-seg-btn active" data-filter="all">
                <i class="bi bi-grid"></i> All
            </button>
            <button type="button" class="borrow-seg-btn" data-filter="returned">
                <i class="bi bi-check2-circle"></i> Returned
                <span class="badge text-bg-success ms-1">@returnedCount</span>
            </button>
            <button type="button" class="borrow-seg-btn" data-filter="notreturned">
                <i class="bi bi-arrow-counterclockwise"></i> Not Returned
                <span class="badge text-bg-warning ms-1">@notReturnedCount</span>
            </button>
            <button type="button" class="borrow-seg-btn" data-filter="due">
                <i class="bi bi-exclamation-triangle"></i> Due/Overdue
                <span class="badge text-bg-danger ms-1">@dueTodayCount</span>
            </button>
        </div>

        <div class="borrow-search-wrap">
            <i class="bi bi-search"></i>
            <input id="globalSearch" class="borrow-search-input" placeholder="Search member, date, status…" />
            <button class="borrow-search-clear" type="button" id="clearSearch"><i class="bi bi-x-circle"></i></button>
        </div>

        <a asp-action="Export" class="borrow-btn">
            <i class="bi bi-download"></i> Export
        </a>

        <div class="borrow-stats">
            <span class="borrow-stat-pill">
                <i class="bi bi-layers"></i> Total: <strong id="statTotal">@Model.Count()</strong>
            </span>
            <span class="borrow-stat-pill">
                <i class="bi bi-check2-circle" style="color:#22c55e"></i>
                Returned: <strong id="statReturned">@returnedCount</strong>
            </span>
            <span class="borrow-stat-pill">
                <i class="bi bi-arrow-counterclockwise" style="color:#f59e0b"></i>
                Not Returned: <strong id="statNotReturned">@notReturnedCount</strong>
            </span>
            <span class="borrow-stat-pill">
                <i class="bi bi-exclamation-octagon" style="color:#ef4444"></i>
                Due: <strong id="statDue">@dueTodayCount</strong>
            </span>
        </div>
    </div>

    <form id="__af" method="post" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <div class="borrow-table-wrap">
        <table class="borrow-table" id="loansTable">
            <thead>
                <tr>
                    <th>Borrow ID</th>
                    <th>Member</th>
                    <th>Borrow Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Is Paid</th>
                    <th class="text-end">Deposit</th>
                    <th class="text-end">Items</th>
                    <th class="text-end">Returns</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var memberName = item.LibraryMember?.FullName ?? "—";

                    <tr data-loanid="@item.LoanId"
                        data-member="@System.Net.WebUtility.HtmlEncode(memberName)"
                        data-loandate="@item.LoanDate.ToString("yyyy-MM-dd")"
                        data-duedate="@item.DueDate.ToString("yyyy-MM-dd")"
                        data-returned="@(item.IsReturned.ToString().ToLower())"
                        data-borrowingfee="@item.BorrowingFee.ToString("0.00")"
                        data-paid="@(item.IsPaid ? "paid" : "unpaid")"
                        data-deposit="@(item.DepositAmount?.ToString("0.00") ?? "-")"
                        data-items="@((item.LoanBookDetails?.Count ?? 0).ToString())"
                        data-returns="@((item.BookReturns?.Count ?? 0).ToString())">
                        <td>@item.LoanId</td>
                        <td class="muted">@memberName</td>
                        <td class="muted">@item.LoanDate.ToString("yyyy-MM-dd")</td>
                        <td class="muted">@item.DueDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.IsReturned)
                            {
                                <span class="borrow-status status-success">
                                    <i class="bi bi-check-circle-fill"></i> Returned
                                </span>
                            }
                            else if (item.DueDate.Date <= today)
                            {
                                <span class="borrow-status status-danger">
                                    <i class="bi bi-exclamation-octagon-fill"></i> Overdue
                                </span>
                            }
                            else
                            {
                                <span class="borrow-status status-warning">
                                    <i class="bi bi-hourglass-split"></i> In Progress
                                </span>
                            }
                        </td>
                        <td>@(item.IsPaid ? "Paid" : "Unpaid")</td>
                        <td class="text-end">@((item.DepositAmount ?? 0m).ToString("0.00"))</td>
                        <td class="text-end">@((item.LoanBookDetails?.Count ?? 0).ToString())</td>
                        <td class="text-end">@((item.BookReturns?.Count ?? 0).ToString())</td>
                        <td>
                            <div class="borrow-actions">
                                <a class="borrow-action-btn" asp-action="Details" asp-route-id="@item.LoanId">
                                    <i class="bi bi-eye"></i> Details
                                </a>
                                <a class="borrow-action-btn" asp-action="Edit" asp-route-id="@item.LoanId">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <button type="button" class="borrow-action-btn btn-delete">
                                    <i class="bi bi-trash3"></i> Delete
                                </button>

                                @if (!item.IsReturned)
                                {
                                    <button type="button" class="borrow-action-btn borrow-action-btn-primary btn-return">
                                        <i class="bi bi-arrow-return-left"></i> Return
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="borrow-action-btn borrow-action-btn-success btn-unreturn">
                                        <i class="bi bi-arrow-counterclockwise"></i> UnReturn
                                    </button>
                                }

                                <a class="borrow-action-btn" asp-action="BorrowReceipt" asp-route-id="@item.LoanId" target="_blank">
                                    <i class="bi bi-printer"></i> Borrow Receipt
                                </a>

                                @if (item.IsReturned && item.BookReturns?.Any() == true)
                                {
                                    <a class="borrow-action-btn" asp-action="ReturnReceipt" asp-route-id="@item.LoanId" target="_blank">
                                        <i class="bi bi-receipt"></i> Return Receipt
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div id="noMatches" class="alert alert-warning d-none" style="border-radius:12px; background:#fffbeb; border:1px solid #fef3c7; color:#92400e;">
        <i class="bi bi-question-circle"></i> No matching results for your filters.
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function() {
            function getToken() {
                const el = document.querySelector('#__af input[name="__RequestVerificationToken"]');
                return el ? el.value : '';
            }

            function parseYMD(d) {
                const [y, m, dd] = d.split('-').map(Number);
                return new Date(y, (m || 1) - 1, dd || 1);
            }

            const TODAY = new Date(new Date().toISOString().slice(0, 10));

            const statTotal = document.getElementById('statTotal');
            const statReturned = document.getElementById('statReturned');
            const statNotReturned = document.getElementById('statNotReturned');
            const statDue = document.getElementById('statDue');
            const noMatches = document.getElementById('noMatches');

            function applyFilter(type) {
                document.querySelectorAll('.borrow-seg-btn').forEach(b => b.classList.remove('active'));
                const activeBtn = document.querySelector(`.borrow-seg-btn[data-filter="${type}"]`);
                if (activeBtn) activeBtn.classList.add('active');

                const q = document.getElementById('globalSearch').value.trim().toLowerCase();

                let vis = 0, rtd = 0, nr = 0, due = 0;

                document.querySelectorAll('#loansTable tbody tr').forEach(r => {
                    const isReturned = r.getAttribute('data-returned') === 'true';
                    const dueDate = parseYMD(r.getAttribute('data-duedate'));
                    const isDue = dueDate <= TODAY && !isReturned;

                    let show = true;
                    if (type === 'returned') show = isReturned;
                    else if (type === 'notreturned') show = !isReturned;
                    else if (type === 'due') show = isDue;

                    if (q) {
                        const rowText = r.innerText.toLowerCase();
                        show = show && rowText.includes(q);
                    }

                    r.style.display = show ? '' : 'none';

                    if (show) {
                        vis++;
                        if (isReturned) rtd++; else nr++;
                        if (isDue) due++;
                    }
                });

                statTotal.textContent = vis;
                statReturned.textContent = rtd;
                statNotReturned.textContent = nr;
                statDue.textContent = due;

                noMatches.classList.toggle('d-none', vis > 0);
            }

            // Filter buttons
            document.querySelectorAll('.borrow-seg-btn').forEach(b =>
                b.addEventListener('click', () => applyFilter(b.getAttribute('data-filter')))
            );

            // Search with debounce
            let searchTimeout;
            document.getElementById('globalSearch').addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    const active = document.querySelector('.borrow-seg-btn.active')?.getAttribute('data-filter') || 'all';
                    applyFilter(active);
                }, 200);
            });

            // Clear search
            document.getElementById('clearSearch').addEventListener('click', () => {
                const input = document.getElementById('globalSearch');
                input.value = '';
                input.focus();
                const active = document.querySelector('.borrow-seg-btn.active')?.getAttribute('data-filter') || 'all';
                applyFilter(active);
            });

            // Initial filter
            applyFilter('all');

            // SweetAlert2 theme
            const swalTheme = {
                buttonsStyling: false,
                customClass: {
                    popup: 'swal2-popup borrow-popup',
                    confirmButton: 'borrow-action-btn borrow-action-btn-primary',
                    cancelButton: 'borrow-action-btn'
                }
            };

            function afHeaders() {
                return {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': getToken()
                };
            }

            // DELETE
            document.querySelectorAll('.btn-delete').forEach(btn => {
                btn.addEventListener('click', function() {
                    const r = this.closest('tr');
                    Swal.fire({
                        title: `Delete Borrow #${r.dataset.loanid}?`,
                        text: 'This will permanently remove the borrow and related details.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Delete',
                        cancelButtonText: 'Cancel',
                        ...swalTheme
                    }).then(res => {
                        if (!res.isConfirmed) return;
                        fetch('/BookBorrows/Delete/' + r.dataset.loanid, {
                            method: 'POST',
                            headers: afHeaders(),
                            body: '{}'
                        }).then(rsp =>
                            rsp.ok
                                ? Swal.fire({
                                    title: 'Deleted!',
                                    icon: 'success',
                                    ...swalTheme
                                }).then(() => location.reload())
                                : Swal.fire({
                                    title: 'Error',
                                    text: 'Delete failed',
                                    icon: 'error',
                                    ...swalTheme
                                })
                        );
                    });
                });
            });

            // RETURN
            document.querySelectorAll('.btn-return').forEach(btn => {
                btn.addEventListener('click', function() {
                    const r = this.closest('tr');
                    const depositStr = r.getAttribute('data-deposit') || "0";
                    const deposit = parseFloat(depositStr === "-" ? "0" : depositStr) || 0;

                    Swal.fire({
                        title: `Return Borrow #${r.dataset.loanid}`,
                        html: `
                            <div class="borrow-dialog">
                                <div>
                                    <label class="borrow-dialog-label">Return Date</label>
                                    <input id="r-date" type="date" class="borrow-dialog-input"
                                           value="${new Date().toISOString().slice(0, 10)}" />
                                </div>

                                <div class="borrow-dialog-grid">
                                    <div>
                                        <label class="borrow-dialog-label">Late Days</label>
                                        <input id="r-late" type="number" class="borrow-dialog-input" value="0" min="0" />
                                    </div>
                                    <div>
                                        <label class="borrow-dialog-label">Fine Amount ($)</label>
                                        <input id="r-fine" type="number" class="borrow-dialog-input" step="0.01" value="0" min="0" />
                                    </div>
                                    <div>
                                        <label class="borrow-dialog-label">Extra Charge ($)</label>
                                        <input id="r-extra" type="number" class="borrow-dialog-input" step="0.01" value="0" min="0" />
                                    </div>
                                </div>

                                <div id="r-summary" class="borrow-dialog-summary"></div>

                                <div>
                                    <label class="borrow-dialog-label">Condition</label>
                                    <input id="r-cond" class="borrow-dialog-input" placeholder="Condition on return" />
                                </div>

                                <div>
                                    <label class="borrow-dialog-label">Notes</label>
                                    <textarea id="r-notes" class="borrow-dialog-input" rows="2" placeholder="Notes"></textarea>
                                </div>
                            </div>
                        `,
                        showCancelButton: true,
                        confirmButtonText: 'Confirm Return',
                        cancelButtonText: 'Cancel',
                        ...swalTheme,
                        didOpen: () => {
                            const fineInput = document.getElementById('r-fine');
                            const extraInput = document.getElementById('r-extra');
                            const summary = document.getElementById('r-summary');

                            function updateSummary() {
                                const fine = parseFloat(fineInput.value || '0');
                                const extra = parseFloat(extraInput.value || '0');
                                const paid = fine + extra;

                                summary.innerHTML = `
                                    <div>Deposit: <strong>$${deposit.toFixed(2)}</strong></div>
                                    <div>Fine + Extra: <strong>$${paid.toFixed(2)}</strong></div>
                                    <div style="color:#000080; font-weight:600; margin-top:4px;">
                                        Refund: $${(deposit - paid).toFixed(2)}
                                    </div>
                                `;
                            }

                            fineInput.addEventListener('input', updateSummary);
                            extraInput.addEventListener('input', updateSummary);
                            updateSummary();
                        },
                        preConfirm: () => {
                            const date = document.getElementById('r-date').value;
                            if (!date) {
                                Swal.showValidationMessage('Return date is required');
                                return false;
                            }

                            return {
                                LoanId: parseInt(r.dataset.loanid),
                                ReturnDate: date,
                                LateDays: parseInt(document.getElementById('r-late').value || '0'),
                                FineAmount: parseFloat(document.getElementById('r-fine').value || '0'),
                                ExtraCharge: parseFloat(document.getElementById('r-extra').value || '0'),
                                ConditionOnReturn: document.getElementById('r-cond').value || null,
                                Notes: document.getElementById('r-notes').value || null
                            };
                        }
                    }).then(res => {
                        if (!res.isConfirmed) return;
                        fetch('/BookBorrows/Return/' + r.dataset.loanid, {
                            method: 'POST',
                            headers: afHeaders(),
                            body: JSON.stringify(res.value)
                        }).then(async rsp => {
                            if (!rsp.ok) {
                                return Swal.fire({
                                    title: 'Error',
                                    text: 'Return failed',
                                    icon: 'error',
                                    ...swalTheme
                                });
                            }

                            const data = await rsp.json();

                            return Swal.fire({
                                title: 'Returned!',
                                text: 'Return recorded successfully. Print receipt?',
                                icon: 'success',
                                showCancelButton: true,
                                confirmButtonText: 'Yes, Print',
                                cancelButtonText: 'No',
                                ...swalTheme
                            }).then(result => {
                                if (result.isConfirmed && data.loanId) {
                                    window.open('/BookBorrows/ReturnReceipt/' + data.loanId, '_blank');
                                }
                                location.reload();
                            });
                        });
                    });
                });
            });

            // UNRETURN
            document.querySelectorAll('.btn-unreturn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const r = this.closest('tr');
                    Swal.fire({
                        title: `UnReturn Borrow #${r.dataset.loanid}?`,
                        text: 'This will mark the borrow as Not Returned and remove return records.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Yes, UnReturn',
                        cancelButtonText: 'Cancel',
                        ...swalTheme
                    }).then(res => {
                        if (!res.isConfirmed) return;
                        fetch('/BookBorrows/UnReturn/' + r.dataset.loanid, {
                            method: 'POST',
                            headers: afHeaders(),
                            body: '{}'
                        }).then(rsp =>
                            rsp.ok
                                ? Swal.fire({
                                    title: 'Done',
                                    text: 'Borrow is now Not Returned.',
                                    icon: 'success',
                                    ...swalTheme
                                }).then(() => location.reload())
                                : Swal.fire({
                                    title: 'Error',
                                    text: 'UnReturn failed',
                                    icon: 'error',
                                    ...swalTheme
                                })
                        );
                    });
                });
            });
        })();
    </script>
}