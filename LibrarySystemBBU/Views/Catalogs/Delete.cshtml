@model LibrarySystemBBU.Controllers.CatalogsController.CatalogFormVM
@{
    ViewData["Title"] = "Delete Catalog";
    var booksCount = Model.Books?.Count ?? 0;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<style>
    .cat-page {
        font-family: 'Inter', sans-serif;
        color: #111827;
    }

    .cat-page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        margin-bottom: 1.25rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .cat-page-title::before {
            content: '';
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: #ef4444;
            display: inline-block;
            flex-shrink: 0;
        }

    .cat-toolbar {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 16px;
        margin-bottom: 1.25rem;
    }

    .cat-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border-radius: 8px;
        font-size: .82rem;
        font-weight: 500;
        cursor: pointer;
        border: 1px solid #e5e7eb;
        background: #fff;
        color: #374151;
        text-decoration: none;
        transition: background .15s;
        white-space: nowrap;
        font-family: 'Inter', sans-serif;
    }

        .cat-btn:hover {
            background: #f9fafb;
            color: #111827;
            text-decoration: none;
        }

        .cat-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

    .cat-btn-danger {
        background: #ef4444;
        color: #fff;
        border-color: #ef4444;
    }

        .cat-btn-danger:hover {
            background: #dc2626;
            color: #fff;
        }

    .cat-stat-pill {
        font-size: .78rem;
        color: #6b7280;
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 5px;
        white-space: nowrap;
    }

        .cat-stat-pill strong {
            color: #111827;
            font-weight: 600;
        }

    .cat-alert {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 1.25rem;
        font-size: .83rem;
        color: #7f1d1d;
    }

        .cat-alert i {
            color: #ef4444;
            font-size: 1rem;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .cat-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 20px 24px;
        margin-bottom: 16px;
    }

    .cat-card-header {
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #6b7280;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 6px;
        padding-bottom: 12px;
        border-bottom: 1px solid #f3f4f6;
    }

    .form-label {
        font-size: .82rem;
        font-weight: 500;
        color: #374151;
        margin-bottom: 4px;
        display: block;
    }

    .form-control {
        font-size: .83rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 7px 11px;
        font-family: 'Inter', sans-serif;
        color: #374151;
        width: 100%;
        background: #f9fafb;
    }

    .preview-img {
        max-height: 110px;
        border-radius: 9px;
        border: 1px solid #e5e7eb;
        object-fit: cover;
    }

    .embed-pdf {
        width: 100%;
        height: 280px;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        margin-top: 8px;
    }

    .cat-table-wrap {
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 16px;
    }

    .cat-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
    }

        .cat-table thead th {
            padding: 9px 14px;
            background: #f9fafb;
            color: #6b7280;
            font-weight: 600;
            font-size: .74rem;
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .cat-table tbody tr {
            border-bottom: 1px solid #f3f4f6;
        }

            .cat-table tbody tr:last-child {
                border-bottom: none;
            }

        .cat-table tbody td {
            padding: 9px 14px;
            color: #374151;
            vertical-align: middle;
        }

    .confirm-row {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 16px;
        font-size: .83rem;
        color: #374151;
    }

        .confirm-row input[type=checkbox] {
            width: 16px;
            height: 16px;
            accent-color: #ef4444;
            cursor: pointer;
            flex-shrink: 0;
        }

    .no-data {
        color: #9ca3af;
        font-size: .83rem;
    }
</style>

<div class="cat-page">
    <div class="cat-page-title">Delete Catalog</div>

    @if (TempData["Error"] != null)
    {
        <div class="cat-alert" style="background:#fef2f2; border-color:#fecaca; color:#7f1d1d;">
            <i class="bi bi-x-octagon-fill" style="color:#ef4444;"></i>
            <span>@TempData["Error"]</span>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="cat-alert" style="background:#f0fdf4; border-color:#bbf7d0; color:#14532d;">
            <i class="bi bi-check-circle-fill" style="color:#22c55e;"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    <div class="cat-alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Are you sure you want to delete this catalog? <strong>All @booksCount book(s) under this catalog will also be deleted.</strong> This action cannot be undone.</span>
    </div>

    <div class="cat-toolbar">
        <span class="cat-stat-pill"><i class="bi bi-journal-text"></i> <strong>@Model.Title</strong></span>
        <span class="cat-stat-pill"><i class="bi bi-collection"></i> Total: <strong>@Model.TotalCopies</strong></span>
        <span class="cat-stat-pill"><i class="bi bi-box-seam"></i> Available: <strong>@Model.AvailableCopies</strong></span>
        <span class="cat-stat-pill"><i class="bi bi-book"></i> Books: <strong>@booksCount</strong></span>
    </div>

    <form asp-action="Delete" method="post" id="deleteForm">
        @Html.AntiForgeryToken()
        <input asp-for="CatalogId" type="hidden" />

        <div class="cat-card">
            <div class="cat-card-header"><i class="bi bi-info-circle"></i> Catalog Info</div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Title</label>
                    <input class="form-control" value="@Model.Title" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Author</label>
                    <input class="form-control" value="@Model.Author" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">ISBN</label>
                    <input class="form-control" value="@Model.ISBN" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Faculty</label>
                    <input class="form-control" value="@Model.Faculty" disabled />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Category</label>
                    <input class="form-control" value="@Model.Category" disabled />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Total Copies</label>
                    <input class="form-control" value="@Model.TotalCopies" disabled />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Available</label>
                    <input class="form-control" value="@Model.AvailableCopies" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Cover Image</label>
                    @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                    {
                        <div class="d-flex align-items-center gap-2">
                            <img src="@Model.ImagePath" class="preview-img" alt="cover" />
                            <a href="@Model.ImagePath" target="_blank" class="cat-btn" style="padding:4px 10px;font-size:.75rem;"><i class="bi bi-box-arrow-up-right"></i> Open</a>
                        </div>
                    }
                    else
                    {
                        <div class="no-data">No image uploaded.</div>
                    }
                </div>
                <div class="col-md-6">
                    <label class="form-label">PDF</label>
                    @if (!string.IsNullOrWhiteSpace(Model.PdfFilePath))
                    {
                        <div class="mb-2">
                            <a href="@Model.PdfFilePath" target="_blank" class="cat-btn" style="padding:4px 10px;font-size:.75rem;"><i class="bi bi-box-arrow-up-right"></i> Open PDF</a>
                        </div>
                        <iframe class="embed-pdf" src="@Model.PdfFilePath"></iframe>
                    }
                    else
                    {
                        <div class="no-data">No PDF attached.</div>
                    }
                </div>
            </div>
        </div>

        <div class="cat-card">
            <div class="cat-card-header"><i class="bi bi-book"></i> Books</div>
            <div class="cat-table-wrap">
                <table class="cat-table">
                    <thead>
                        <tr>
                            <th>BookId</th>
                            <th>Barcode</th>
                            <th>Status</th>
                            <th>Location</th>
                            <th>Acquired</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Books != null && Model.Books.Any())
                        {
                            foreach (var b in Model.Books)
                            {
                                <tr>
                                    <td style="color:#9ca3af;">@b.BookId</td>
                                    <td style="font-weight:500;">@b.Barcode</td>
                                    <td>@b.Status</td>
                                    <td style="color:#6b7280;">@b.Location</td>
                                    <td style="color:#6b7280;">@b.AcquisitionDate.ToString("yyyy-MM-dd")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" style="text-align:center;color:#9ca3af;padding:1.5rem;">No books.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="confirm-row">
            <input type="checkbox" id="chkConfirm" />
            <label for="chkConfirm" style="cursor:pointer;margin:0;">I confirm that I want to delete this catalog and all its associated books.</label>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" id="btnDelete" class="cat-btn cat-btn-danger" disabled><i class="bi bi-trash3"></i> Confirm Delete</button>
            <a asp-action="Index" class="cat-btn"><i class="bi bi-x-circle"></i> Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            const chk  = document.getElementById('chkConfirm');
            const btn  = document.getElementById('btnDelete');
            const form = document.getElementById('deleteForm');

            chk?.addEventListener('change', () => { btn.disabled = !chk.checked; });

            form?.addEventListener('submit', function (e) {
                if (!chk.checked) { e.preventDefault(); return; }
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Delete this catalog?',
                    html: `This will permanently remove <b>@booksCount</b> book(s) along with this catalog.<br/>This cannot be undone.`,
                    showCancelButton: true,
                    confirmButtonText: 'Yes, delete',
                    cancelButtonText: 'Cancel',
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#6b7280',
                    reverseButtons: true,
                    borderRadius: '14px'
                }).then(res => { if (res.isConfirmed) form.submit(); });
            });
        })();
    </script>
}
